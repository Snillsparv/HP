---
import Base from '../layouts/Base.astro';
---

<Base title="Provpasssimulator – Högskoleprovet vt 2021 – HPMästaren">
  <div class="page-content">
    <div class="container" id="provpass-container">

      <!-- Selection screen -->
      <div id="selection-screen">
        <h1>Provpasssimulator</h1>
        <p class="page-intro">Kör ett helt provpass från Högskoleprovet vt 2021 under realistiska förhållanden. 40 frågor, 55 minuter, rättning efteråt.</p>

        <div class="tip-box">
          <strong>Så fungerar det</strong>
          Välj verbalt eller kvantitativt provpass. Alla 40 frågor visas samtidigt, precis som på riktiga provet. En nedräkningstimer håller koll på tiden. När du är klar klickar du "Lämna in" för att se ditt resultat.
        </div>

        <div class="card-grid" style="max-width: 600px; margin: 2rem auto;">
          <button class="card trana-card" id="start-verbal" style="cursor:pointer; border:none; text-align:left; font-family:var(--font-sans); background:var(--color-surface);">
            <span class="card-icon" style="font-size:2rem;">📝</span>
            <h3 style="margin-top:0.3rem; font-size:1.3rem;">Verbalt provpass</h3>
            <p style="font-size:0.9rem; color:var(--color-muted);">Provpass 1: ORD, LÄS, MEK, ELF</p>
            <p style="font-size:0.85rem; color:var(--color-muted);">40 frågor · 55 minuter</p>
          </button>
          <button class="card trana-card" id="start-kvant" style="cursor:pointer; border:none; text-align:left; font-family:var(--font-sans); background:var(--color-surface);">
            <span class="card-icon" style="font-size:2rem;">🔢</span>
            <h3 style="margin-top:0.3rem; font-size:1.3rem;">Kvantitativt provpass</h3>
            <p style="font-size:0.9rem; color:var(--color-muted);">Provpass 3: XYZ, KVA, NOG, DTK</p>
            <p style="font-size:0.85rem; color:var(--color-muted);">40 frågor · 55 minuter</p>
          </button>
        </div>

        <p style="text-align:center; font-size:0.85rem; color:var(--color-muted); margin-top:1rem;">
          Källa: Högskoleprovet vt 2021, Universitets- och högskolerådet (UHR)
        </p>
      </div>

      <!-- Exam screen -->
      <div id="exam-screen" style="display:none;">
        <!-- Sticky timer -->
        <div id="timer-bar">
          <div class="timer-inner">
            <button class="btn btn-outline btn-sm" id="exam-back-btn">← Avbryt</button>
            <span id="exam-title-bar">Verbalt provpass</span>
            <span id="timer-display">55:00</span>
          </div>
        </div>

        <div id="exam-header" style="margin-top:4.5rem;">
          <h1 id="exam-title">Högskoleprovet vt 2021</h1>
          <p id="exam-subtitle" style="color:var(--color-muted);">Provpass 1 — Verbal del · 40 uppgifter · 55 minuter</p>
          <div class="tip-box" style="margin-bottom:2rem;">
            Fyll alltid i ett svar för varje uppgift. Du får inte minuspoäng om du svarar fel. Klicka "Lämna in provpasset" längst ner när du är klar.
          </div>
        </div>

        <div id="exam-questions"></div>

        <div style="text-align:center; margin: 3rem 0;">
          <button class="btn btn-primary" id="submit-exam" style="font-size:1.1rem; padding:1rem 3rem;">Lämna in provpasset</button>
        </div>
      </div>

      <!-- Results screen -->
      <div id="results-screen" style="display:none;">
        <div class="results-card" style="text-align:center; padding:2rem 0;">
          <h1>Resultat</h1>
          <div id="results-total" style="font-size:3rem; font-weight:800; color:var(--color-primary); margin:1rem 0;"></div>
          <p id="results-percent" style="color:var(--color-muted); font-size:1.1rem;"></p>
          <div id="results-sections" style="max-width:400px; margin:2rem auto; text-align:left;"></div>
          <div id="results-detail" style="max-width:700px; margin:2rem auto; text-align:left;"></div>
          <div style="margin-top:2rem; display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
            <button class="btn btn-primary" id="results-retry">Försök igen</button>
            <button class="btn btn-outline" id="results-back">Välj annat provpass</button>
          </div>
          <p style="text-align:center; font-size:0.85rem; color:var(--color-muted); margin-top:2rem;">
            Källa: Högskoleprovet vt 2021, Universitets- och högskolerådet (UHR)
          </p>
        </div>
      </div>

    </div>
  </div>
</Base>

<style>
  #timer-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 200;
    background: var(--color-text);
    color: white;
    padding: 0.6rem 1.5rem;
    font-weight: 600;
  }
  .timer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  #timer-display {
    font-size: 1.4rem;
    font-variant-numeric: tabular-nums;
    min-width: 5ch;
    text-align: right;
  }
  #timer-display.warning { color: #fbbf24; }
  #timer-display.danger { color: #ef4444; }
  #timer-bar .btn-sm {
    color: white;
    border-color: rgba(255,255,255,0.4);
    padding: 0.3rem 0.8rem;
    font-size: 0.8rem;
  }
  #timer-bar .btn-sm:hover { background: rgba(255,255,255,0.15); }
  #exam-title-bar { font-size: 0.95rem; }

  .exam-section-header {
    background: var(--color-primary);
    color: white;
    padding: 0.8rem 1.2rem;
    border-radius: var(--radius);
    margin: 2.5rem 0 1.5rem;
    font-size: 1.1rem;
    font-weight: 700;
  }
  .exam-section-header:first-child { margin-top: 0; }
  .exam-section-info {
    color: var(--color-muted);
    font-size: 0.9rem;
    font-style: italic;
    margin-bottom: 1.5rem;
  }

  .reading-block {
    background: #f8fafc;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    line-height: 1.8;
    font-size: 0.95rem;
  }
  .reading-block h3 {
    margin-top: 0;
    margin-bottom: 0.8rem;
    color: var(--color-text);
  }
  .reading-block p { margin-bottom: 0.8rem; }
  .reading-block p:last-child { margin-bottom: 0; }

  .question-block {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.2rem 1.5rem;
    margin-bottom: 1rem;
    transition: border-color 0.15s;
  }
  .question-block.answered { border-color: var(--color-primary); }
  .question-block.result-correct { border-color: var(--color-success); background: #f0fdf4; }
  .question-block.result-incorrect { border-color: #ef4444; background: #fef2f2; }

  .question-number {
    font-weight: 700;
    color: var(--color-primary);
    margin-right: 0.5rem;
  }
  .question-text {
    font-weight: 600;
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .option-row {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    padding: 0.5rem 0.8rem;
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.1s;
  }
  .option-row:hover { background: #f1f5f9; }
  .option-row input[type="radio"] {
    margin-top: 0.25rem;
    accent-color: var(--color-primary);
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
  .option-row label {
    cursor: pointer;
    line-height: 1.5;
    flex: 1;
  }
  .option-letter {
    font-weight: 700;
    margin-right: 0.3rem;
    min-width: 1.2rem;
    display: inline-block;
  }

  .result-correct-marker { color: var(--color-success); font-weight: 700; }
  .result-incorrect-marker { color: #ef4444; font-weight: 700; }
  .correct-answer-note {
    margin-top: 0.5rem;
    padding: 0.5rem 0.8rem;
    background: #ecfdf5;
    border-radius: 4px;
    font-size: 0.9rem;
    color: #065f46;
  }

  .section-score {
    display: flex;
    justify-content: space-between;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--color-border);
    font-weight: 500;
  }
  .section-score:last-child { border-bottom: none; }

  @media (max-width: 768px) {
    #exam-header { margin-top: 3.5rem; }
    .reading-block { padding: 1rem; font-size: 0.9rem; }
    .question-block { padding: 1rem; }
  }
</style>

<script>
  // ============================================================
  // QUESTION DATA - Högskoleprovet vt 2021
  // ============================================================

  const verbalQuestions = [
    // ORD 1-10
    { section: "ORD", num: 1, q: "Vad betyder <strong>implicera</strong>?", opts: ["medföra","ställa upp","försvaga","hålla fast","undvika"], correct: 0 },
    { section: "ORD", num: 2, q: "Vad betyder <strong>ypperligt</strong>?", opts: ["uppenbart","typiskt","överdrivet","utmärkt","värdefullt"], correct: 3 },
    { section: "ORD", num: 3, q: "Vad betyder <strong>hieroglyf</strong>?", opts: ["gravsten","himlakropp","bönbok","skrivtecken","väggmålning"], correct: 3 },
    { section: "ORD", num: 4, q: "Vad betyder <strong>initial</strong>?", opts: ["väl insatt","pådrivande","sammanhängande","verkningsfull","inledande"], correct: 4 },
    { section: "ORD", num: 5, q: "Vad betyder <strong>surrogat</strong>?", opts: ["tillsats","ersättning","hjälpmedel","avvikelse","förmedling"], correct: 1 },
    { section: "ORD", num: 6, q: "Vad betyder <strong>strandsätta</strong>?", opts: ["överta","fullborda","misslyckas","säkerställa","överge"], correct: 4 },
    { section: "ORD", num: 7, q: "Vad betyder <strong>katharsis</strong>?", opts: ["kraftprov","undergång","själslig rening","höjdpunkt","kärlekssorg"], correct: 2 },
    { section: "ORD", num: 8, q: "Vad betyder <strong>anseende</strong>?", opts: ["rykte","hållning","uttryck","karaktär","ståndpunkt"], correct: 0 },
    { section: "ORD", num: 9, q: "Vad betyder <strong>perplex</strong>?", opts: ["häpen","envis","nyfiken","konstig","vaken"], correct: 0 },
    { section: "ORD", num: 10, q: "Vad betyder <strong>utlöpare</strong>?", opts: ["undantag","sidogren","felbedömning","varning","framkant"], correct: 1 },

    // LÄS 11-12 (Journalister)
    { section: "LÄS", num: 11, reading: "journalister", q: "I texten beskrivs de traditionella mediernas kris. Vilket av följande problem med denna kris lyfter textförfattaren fram?", opts: ["Att intresset för journalistik blir allt mindre.","Att förutsättningarna att bedriva oberoende journalistik blir allt sämre.","Att möjligheterna att kombinera journalistik med andra uppdrag begränsas.","Att god journalistik blir allt mindre viktig i samhället."], correct: 1 },
    { section: "LÄS", num: 12, reading: "journalister", q: "Vad framstår i texten som grundorsaken till att skickliga yrkesutövare lämnar journalistiken?", opts: ["Att andra branscher har börjat konkurrera om det journalistiska uppdraget.","Att journalistyrket successivt har tappat i status och anseende.","Att den stränga yrkesetiken har blivit föråldrad och irrelevant.","Att arbetsvillkoren har förändrats i samband med branschens kris."], correct: 3 },

    // LÄS 13-16 (Talande träd)
    { section: "LÄS", num: 13, reading: "trad", q: "Vilket alternativ beskriver bäst hur Peter Wohlleben uppfattade skogen i början av sitt yrkesliv respektive hur han uppfattar den i dag?", opts: ["Som ett samarbetande kollektiv respektive ett outforskat fält.","Som en källa till råvaror respektive en samling unika individer.","Som en ömtålig naturresurs respektive en naturlig ekonomisk näring.","Som ett livskraftigt tillväxtområde respektive ett konstgjort odlingslandskap."], correct: 1 },
    { section: "LÄS", num: 14, reading: "trad", q: "Träd verkar kunna göra något som i texten påstås hjälpa dem att överleva under plantageliknande förhållanden. Vad?", opts: ["Ta hjälp av äldre träd med näringstillförseln.","Agera utifrån sina erfarenheter.","Varna varandra för attacker från växtätande djur.","Utveckla egna personligheter."], correct: 1 },
    { section: "LÄS", num: 15, reading: "trad", q: "I texten diskuteras om träd kan ha känsel och hörsel. Vilken tycks vara Peter Wohllebens inställning i frågan?", opts: ["Att det är obekräftat av forskningen men ändå sannolikt.","Att det är fastslaget av vetenskapen och avgörande för trädens överlevnad.","Att det är nedtystat av skogsbolagen men på väg att nå allmän kännedom.","Att det är allmänt erkänt och lika uppenbart som i djurriket."], correct: 0 },
    { section: "LÄS", num: 16, reading: "trad", q: 'Vad ser Peter Wohlleben som ett tecken på att träd har "personligheter"?', opts: ["Att enskilda träd upprepar ett och samma beteende gång på gång.","Att ett träds beteende vid lövfällningen förändras efter hand som trädet åldras.","Att träds beteenden så tydligt är anpassade till växtplatsen.","Att enskilda träd via individanpassade signaler kan påverka andra träds beteenden."], correct: 0 },

    // LÄS 17-20 (Övergångar)
    { section: "LÄS", num: 17, reading: "overgangar", q: "Vilket av nedanstående påståenden hoppas Lina Lago att fler barn får höra inför sin skolstart, av texten att döma?", opts: ["I skolan är det ordning och reda.","I skolan är det mycket som är roligt.","I skolan arbetar man tillsammans.","I skolan är det inte som du tror."], correct: 1 },
    { section: "LÄS", num: 18, reading: "overgangar", q: "I texten citeras en pedagog som var frustrerad över vissa lärares uppfattningar om förskolan. Vad ville pedagogen rimligen ha sagt med sin kommentar?", opts: ["Att dessa lärare försöker påverka förskolans undervisningsinnehåll.","Att dessa lärare underskattar vad barnen får lära sig i förskolan.","Att dessa lärare försvårar barnens övergång från förskolan.","Att dessa lärare är ointresserade av att bidra till förskolans arbete."], correct: 1 },
    { section: "LÄS", num: 19, reading: "overgangar", q: "Vad bör man som lärare särskilt tänka på när det gäller övergångar, enligt Lina Lago?", opts: ["Man bör kommunicera med andra lärare och dela sina erfarenheter med dem.","Man bör påverka det man kan och i övrigt lita till barnens egen förmåga.","Man bör undvika standardlösningar och välja arbetssätt utifrån varje barngrupp.","Man bör inleda processen i tid och förvarna barnen om framtida övergångar."], correct: 2 },
    { section: "LÄS", num: 20, reading: "overgangar", q: "Vilken övergripande fråga kan texten sägas vara ett svar på?", opts: ["Vad kan forskningen lära oss om övergångar?","Hur lär sig barn att hantera övergångar?","Vad tycker lärare om övergångar?","Hur påverkas lärandet av övergångar?"], correct: 0 },

    // MEK 21-30
    { section: "MEK", num: 21, q: "De flesta av de barnfilmer som är under produktion är publika filmer som bygger på kända _____.", opts: ["inlagor","bilagor","pålagor","förlagor"], correct: 3 },
    { section: "MEK", num: 22, q: "Men _____ de båda partiledarnas spänstiga debatter tidigare i veckan och den täta duellen i radion i fredags kändes gårdagens tv-duell nästan lite _____.", opts: ["i paritet med – släpphänt","i kontrast till – avslagen","i enlighet med – sporadisk","i relation till – påflugen"], correct: 1 },
    { section: "MEK", num: 23, q: 'Det finns kvalitetsbrister i den högre utbildningen som behöver åtgärdas. I den första regeringsförklaringen _____ därför statsministern fast att "kvaliteten i högskolan ska höjas". Regeringen avsätter nu nära 900 miljoner kronor under _____ för att stärka kvaliteten inom _____ och samhällsvetenskap.', opts: ["skrev – framtidsprognosen – humanism","höll – högskolesatsningen – sociologi","slog – mandatperioden – humaniora","lade – inledningsskedet – socialism"], correct: 2 },
    { section: "MEK", num: 24, q: "En viktig slutsats som kan dras utifrån denna fallstudie är att strukturerade intervjuer kan användas för utvärdering på _____ nivå. Denna metod har vissa begränsningar vad gäller generaliserbarhet men kan ändå ha stor _____ i vissa sammanhang.", opts: ["lokal – giltighet","allmän – kompetens","officiell – driftighet","funktionell – preferens"], correct: 0 },
    { section: "MEK", num: 25, q: "Många av våra samtida artister har varit _____ en svensk hiphopkultur sedan de var barn, eller åtminstone väldigt unga.", opts: ["exponerade för","indifferenta till","exalterade av","inspirerande för"], correct: 0 },
    { section: "MEK", num: 26, q: 'Begreppet "kulturell appropriering" kan definieras som att medlemmar av en kultur _____ en annan kultur som historiskt anses ha haft en lägre status. Börje Salming fick till exempel kritik för sin hyllning till Sitting Bull, där han _____ siouxhövdingen i kalendern <em>Årets kvinnor och män</em>.', opts: ["går till angrepp mot – kritiserade","finner likheter med – tog fasta på","gör sig lustig över – skämtade om","övertar element från – poserade som"], correct: 3 },
    { section: "MEK", num: 27, q: "Från att tidigare ha förekommit i form av spridda insatser inom olika ämnen har teknikhistoria på senare tid utvecklats till en egen vetenskaplig _____.", opts: ["tendens","disciplin","egenart","substans"], correct: 1 },
    { section: "MEK", num: 28, q: "Sannolikt har både du och jag fått lära oss att inte visa oss nakna offentligt. Det finns ingen egentlig anledning till att vi inte får göra det, bortsett från det (för många av oss) rent _____ nedköpet. Likväl tar det emot. De flesta av oss skulle paradera i _____ på offentlig plats enbart om det _____ oss en riktigt fet belöning av något slag.", opts: ["ekonomiska – fulla munderingen – garanterade","praktiska – veka livet – presenterade","estetiska – bara mässingen – renderade","moraliska – rena okynnet – premierade"], correct: 2 },
    { section: "MEK", num: 29, q: "Utredningen har fått i uppgift att se över funktionen för _____ och kontroll hos brottsutsatta myndigheter och analysera de brottsbekämpande myndigheternas förutsättningar att utreda och _____ denna brottslighet.", opts: ["uppföljning – beivra","insamling – belägga","registrering – betona","efterlysning – bestraffa"], correct: 0 },
    { section: "MEK", num: 30, q: "Hon mindes precis hur det hade börjat. Det var blommorna. Hon brukade leverera dem i _____ till huvudingången i huset där han arbetade. Göran hade följt med henne ut för att visa var de skulle hänga.", opts: ["amplar","armaturer","alikor","amoriner"], correct: 0 },

    // ELF 31-40
    { section: "ELF", num: 31, reading: "neuroscience", q: "What is said about the academic discipline of neuroscience?", opts: ["There is a serious lack of qualified teachers in the field.","There is strong competition among applicants to the graduate courses.","There are many students who never finish their academic studies.","There are few research positions to match the number of graduates."], correct: 3 },
    { section: "ELF", num: 32, reading: "animalhacks", q: "What is the main point here?", opts: ["The ability to use tools can't be directly connected to greater mental capacity.","Human tool use might be older in origin than many researchers have assumed.","Relatively advanced thinking appears to be a requirement for the ability to use tools.","Animal tool use is much more common than indicated by previous research."], correct: 0 },
    { section: "ELF", num: 33, reading: "grimm", q: "What is said in the introduction about the Grimms' interest in stories?", opts: ["It was a result of hearing many stories in their own childhood.","They saw stories as a means to protect the culture of the German people.","It was a result of regularly encountering storytellers at local gatherings.","They saw stories as a chance to spread German ideals outside their own country."], correct: 1 },
    { section: "ELF", num: 34, reading: "grimm", q: "What is said about the Grimms' early collections?", opts: ["A large number of their early stories did not turn up in their later volumes.","The quality of the writing increased as new versions appeared.","All the now famous stories are included in the first two volumes.","The originality of their storytelling was immediately apparent."], correct: 1 },
    { section: "ELF", num: 35, reading: "grimm", q: "What are we told about the content in the different versions of the fairy tales?", opts: ["In later versions, the horror of the early editions is simply removed.","In early versions, mothers are consistently put in much less favourable light than fathers.","In later versions, the evildoers have changed into people less close to the children.","In early versions, parents are often just as much victims as the children."], correct: 2 },
    { section: "ELF", num: 36, reading: "grimm", q: "What is argued about the themes of poverty and starvation in the stories?", opts: ["They clearly mirror the historical period of the stories' creation.","They were added to the original stories by the brothers themselves.","They directly reflect the Grimms' own childhood and upbringing.","They were later toned down to focus on parent/child relations."], correct: 0 },
    { section: "ELF", num: 37, reading: "grimm", q: "What is claimed about later editions of the Grimms' collection of stories?", opts: ["The language was simplified in order to appeal to a wider audience.","The stories' popularity led them to make certain adaptations to the content.","The villains became even crueller while the punishments they received became harsher.","The stories were increasingly criticized for their lack of moral foundation."], correct: 1 },
    { section: "ELF", num: 38, reading: "somatic", q: "What is said here?", opts: ["Some people are unable to smile when they experience happiness.","Smiling is often the result of feelings unrelated to happiness.","The very act of smiling can make you feel good.","Smiling tends to be transmitted from one person to another."], correct: 2 },
    { section: "ELF", num: 39, reading: "somatic", q: "What else is pointed out here about 'somatic feedback'?", opts: ["It does not work if you believe in it.","It only works if you are already happy.","It does not work for truly happy people.","It only works if you strongly believe in it."], correct: 0 },
    { section: "ELF", num: 40, reading: "scifi", q: "What is argued here about science-fiction writers?", opts: ["They appear to be slightly better than other people at guessing the immediate future.","They are often very good at convincing readers of the realism in their stories.","Their stories reveal more about their own time than about the future.","Their predictions have a tendency to become self-fulfilling."], correct: 2 },
  ];

  const kvantQuestions = [
    // XYZ 1-12
    { section: "XYZ", num: 1, q: "2(x − 6) = 4(2 − x)<br><br>Vilket värde har <em>x</em>?", opts: ["2","10/3","14/3","5"], correct: 1 },
    { section: "XYZ", num: 2, q: "f(x) = 3x² − 12<br><br>Vilket svarsalternativ anger ett x-värde för vilket f(x) = 0?", opts: ["0","2","4","12"], correct: 1 },
    { section: "XYZ", num: 3, q: "Vad är 20 procent av 1/5?", opts: ["5/20","1/20","1/25","1/100"], correct: 2 },
    { section: "XYZ", num: 4, q: "En femhörning har måtten: botten 10 cm, höger sida 8 cm, toppen 4 cm bred, med en diagonal som skär av övre vänstra hörnet (höjd 4 cm från botten på vänster sida).<br><br>Hur stor är arean av femhörningen?", opts: ["60 cm²","66 cm²","68 cm²","80 cm²"], correct: 2 },
    { section: "XYZ", num: 5, q: "Vad är medianen av alla heltal från och med 1 till och med 10?", opts: ["4,5","5","5,5","6"], correct: 2 },
    { section: "XYZ", num: 6, q: "2<sup>x</sup> · 4<sup>y</sup> = 16<br><br>Vad är x + 2y?", opts: ["2","4","6","8"], correct: 1 },
