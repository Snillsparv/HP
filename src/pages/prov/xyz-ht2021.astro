---
import Base from '../../layouts/Base.astro';
---

<Base title="XYZ — Matematisk problemlösning (HT 2021) – HPAkuten" description="Öva på XYZ-delen från högskoleprovet HT 2021. 12 uppgifter med svarsalternativ, rätta direkt.">
  <div class="page-content">
    <div class="container" style="max-width: 700px;">

      <div class="prov-header">
        <h1>XYZ — Matematisk problemlösning</h1>
        <p class="prov-meta">Högskoleprov HT 2021 &middot; Delprov 1 &middot; 12 uppgifter &middot; Rekommenderad tid: 12 minuter</p>
        <div class="prov-timer" id="prov-timer">
          <button class="btn btn-outline btn-sm" id="timer-btn">Starta timer (12:00)</button>
          <span class="timer-display" id="timer-display" style="display:none;">⏱ <span id="timer-value">12:00</span></span>
        </div>
      </div>

      <div id="prov-app">
        <!-- Question navigation rendered by script -->
      </div>

    </div>
  </div>

  <script>
    const questions = [
      {
        num: 1,
        text: 'Vilket värde har <i>x</i> om <span class="math"><sup>1</sup>&frasl;<sub>2</sub> + <sup>1</sup>&frasl;<sub>3</sub> + <i>x</i> = 1</span>?',
        options: [
          '<sup>1</sup>&frasl;<sub>6</sub>',
          '<sup>1</sup>&frasl;<sub>5</sub>',
          '<sup>1</sup>&frasl;<sub>4</sub>',
          '<sup>1</sup>&frasl;<sub>3</sub>'
        ],
        correct: 0
      },
      {
        num: 2,
        text: 'En blombukett består av endast vita och röda rosor. Antalet röda rosor är tre gånger så stort som antalet vita rosor. <b>Vilket svarsalternativ kan motsvara antalet rosor i blombuketten?</b>',
        options: ['25', '26', '27', '28'],
        correct: 3
      },
      {
        num: 3,
        text: 'Vad är 5 + 3 &middot; 5 &minus; 4 + 8 &middot; 2?',
        options: ['0', '16', '32', '88'],
        correct: 2
      },
      {
        num: 4,
        text: 'Vilket svarsalternativ motsvarar ekvationen <i>y</i> = 4<i>x</i> &minus; 5?',
        options: [
          '<i>x</i> = <i>y</i> + <sup>5</sup>&frasl;<sub>4</sub>',
          '<i>x</i> = <sup><i>y</i></sup>&frasl;<sub>4</sub> + 5',
          '<i>x</i> = <sup>5 &minus; <i>y</i></sup>&frasl;<sub>4</sub>',
          '<i>x</i> = <sup><i>y</i> + 5</sup>&frasl;<sub>4</sub>'
        ],
        correct: 3
      },
      {
        num: 5,
        text: 'Fyra linjer skär varandra i samma punkt. <b>Vad är <i>x</i>?</b><br><br><em>(Vinklarna runt punkten är: x, 2x, 3x, 2x och resterande vertikalvinklar.)</em>',
        options: ['15°', '20°', '22,5°', '25°'],
        correct: 2
      },
      {
        num: 6,
        text: 'Vilket svarsalternativ är lika med 3<i>x</i>(2 &minus; 5<i>y</i>)?',
        options: [
          '6<i>x</i> &minus; 5<i>y</i>',
          '(6<i>x</i> &minus; 15)<i>y</i>',
          '&minus;5<i>x</i>(2 + 3<i>y</i>)',
          '&minus;(15<i>y</i> &minus; 6)<i>x</i>'
        ],
        correct: 3
      },
      {
        num: 7,
        text: 'Vilket svarsalternativ är ett intervall där <i>g</i>(<i>x</i>) > <i>f</i>(<i>x</i>) för alla <i>x</i> i intervallet?<br><br><em>(Se grafen i provhäftet med funktionerna y = f(x) och y = g(x), med punkter a, b, c, d, e markerade på x-axeln.)</em>',
        options: [
          '<i>x</i> > <i>a</i>',
          '<i>b</i> < <i>x</i> < <i>e</i>',
          '<i>c</i> < <i>x</i> < <i>e</i>',
          '<i>a</i> < <i>x</i> < <i>d</i>'
        ],
        correct: 3
      },
      {
        num: 8,
        text: 'I en påse finns det 28 enfärgade kulor: 10 röda, 7 vita och 11 svarta. <b>Om man drar en kula slumpmässigt, hur stor är då sannolikheten att den inte är vit?</b>',
        options: [
          '<sup>1</sup>&frasl;<sub>3</sub>',
          '<sup>1</sup>&frasl;<sub>4</sub>',
          '<sup>2</sup>&frasl;<sub>3</sub>',
          '<sup>3</sup>&frasl;<sub>4</sub>'
        ],
        correct: 3
      },
      {
        num: 9,
        text: 'Vilket svarsalternativ är lika med <span class="math"><sup>0,36</sup>&frasl;<sub>3 &middot; 0,024</sub></span>?',
        options: ['0,05', '0,5', '5', '50'],
        correct: 2
      },
      {
        num: 10,
        text: 'Rektangeln ABCD är sammansatt av 12 lika stora kvadrater, enligt figuren. Rektangelns area är 300 cm². <b>Hur lång är sidan AB?</b><br><br><em>(Rektangeln är 4 kvadrater bred och 3 kvadrater hög.)</em>',
        options: [
          '√300 cm',
          '20 cm',
          '<sup>4</sup>&frasl;<sub>3</sub>√300 cm',
          '25 cm'
        ],
        correct: 1
      },
      {
        num: 11,
        text: '<em>Fråga 11 — läggs till snart.</em>',
        options: ['A', 'B', 'C', 'D'],
        correct: 0
      },
      {
        num: 12,
        text: '<em>Fråga 12 — läggs till snart.</em>',
        options: ['A', 'B', 'C', 'D'],
        correct: 0
      }
    ];

    const answers: (number | null)[] = new Array(questions.length).fill(null);
    let current = 0;
    let submitted = false;

    const app = document.getElementById('prov-app')!;

    function render() {
      if (submitted) {
        renderResults();
        return;
      }
      const q = questions[current];
      const labels = ['A', 'B', 'C', 'D'];
      app.innerHTML = `
        <div class="prov-progress">Uppgift ${q.num} av ${questions.length}</div>
        <div class="prov-question">
          <div class="prov-question-num">${q.num}.</div>
          <div class="prov-question-text">${q.text}</div>
        </div>
        <div class="prov-options">
          ${q.options.map((opt, i) => `
            <label class="prov-option ${answers[current] === i ? 'selected' : ''}">
              <input type="radio" name="q${current}" value="${i}" ${answers[current] === i ? 'checked' : ''} />
              <span class="prov-option-letter">${labels[i]}</span>
              <span class="prov-option-text">${opt}</span>
            </label>
          `).join('')}
        </div>
        <div class="prov-nav">
          <button class="btn btn-outline btn-sm" id="btn-prev" ${current === 0 ? 'disabled' : ''}>Föregående</button>
          <button class="btn btn-outline btn-sm" id="btn-overview">Översikt</button>
          ${current === questions.length - 1
            ? '<button class="btn btn-primary btn-sm" id="btn-submit">Rätta provet</button>'
            : '<button class="btn btn-primary btn-sm" id="btn-next">Nästa</button>'}
        </div>
        <div class="prov-dots">
          ${questions.map((_, i) => `<span class="prov-dot ${i === current ? 'active' : ''} ${answers[i] !== null ? 'answered' : ''}" data-i="${i}">${i + 1}</span>`).join('')}
        </div>
      `;

      // Event listeners
      app.querySelectorAll('input[type="radio"]').forEach(el => {
        el.addEventListener('change', (e) => {
          answers[current] = Number((e.target as HTMLInputElement).value);
          render();
        });
      });
      document.getElementById('btn-prev')?.addEventListener('click', () => { current--; render(); });
      document.getElementById('btn-next')?.addEventListener('click', () => { current++; render(); });
      document.getElementById('btn-submit')?.addEventListener('click', () => { submitted = true; render(); });
      document.getElementById('btn-overview')?.addEventListener('click', () => { renderOverview(); });
      app.querySelectorAll('.prov-dot').forEach(el => {
        el.addEventListener('click', () => { current = Number(el.getAttribute('data-i')); render(); });
      });
    }

    function renderOverview() {
      const labels = ['A', 'B', 'C', 'D'];
      const answered = answers.filter(a => a !== null).length;
      app.innerHTML = `
        <h2 style="text-align:center; margin-top:0;">Översikt</h2>
        <p style="text-align:center; color: var(--color-muted);">${answered} av ${questions.length} besvarade</p>
        <div class="prov-overview-grid">
          ${questions.map((q, i) => `
            <button class="prov-overview-item ${answers[i] !== null ? 'answered' : ''}" data-i="${i}">
              <span class="prov-overview-num">${q.num}</span>
              <span class="prov-overview-ans">${answers[i] !== null ? labels[answers[i]!] : '—'}</span>
            </button>
          `).join('')}
        </div>
        <div class="prov-nav" style="margin-top: 1.5rem;">
          <button class="btn btn-outline btn-sm" id="btn-back-first">Tillbaka till fråga 1</button>
          <button class="btn btn-primary btn-sm" id="btn-submit-overview">Rätta provet</button>
        </div>
      `;
      app.querySelectorAll('.prov-overview-item').forEach(el => {
        el.addEventListener('click', () => { current = Number(el.getAttribute('data-i')); render(); });
      });
      document.getElementById('btn-back-first')?.addEventListener('click', () => { current = 0; render(); });
      document.getElementById('btn-submit-overview')?.addEventListener('click', () => { submitted = true; render(); });
    }

    function renderResults() {
      const labels = ['A', 'B', 'C', 'D'];
      let score = 0;
      questions.forEach((q, i) => { if (answers[i] === q.correct) score++; });

      app.innerHTML = `
        <div class="prov-result-header">
          <h2>Resultat</h2>
          <div class="prov-score">${score} / ${questions.length}</div>
          <p style="color: var(--color-muted);">rätt svar</p>
        </div>
        <div class="prov-result-list">
          ${questions.map((q, i) => {
            const isCorrect = answers[i] === q.correct;
            const icon = isCorrect ? '✓' : '✗';
            const cls = isCorrect ? 'correct' : 'wrong';
            return `
              <div class="prov-result-item ${cls}">
                <span class="prov-result-icon">${icon}</span>
                <span class="prov-result-num">${q.num}.</span>
                <span>Ditt svar: <strong>${answers[i] !== null ? labels[answers[i]!] : '—'}</strong></span>
                ${!isCorrect ? `<span class="prov-result-correct">Rätt: <strong>${labels[q.correct]}</strong></span>` : ''}
              </div>
            `;
          }).join('')}
        </div>
        <div class="prov-nav" style="margin-top: 2rem;">
          <button class="btn btn-outline btn-sm" id="btn-retry">Gör om provet</button>
          <a href="/trana" class="btn btn-primary btn-sm">Tillbaka</a>
        </div>
      `;
      document.getElementById('btn-retry')?.addEventListener('click', () => {
        answers.fill(null);
        current = 0;
        submitted = false;
        render();
      });
    }

    render();

    // Timer
    let timerRunning = false;
    let timerSeconds = 12 * 60;
    let timerInterval: number;
    const timerBtn = document.getElementById('timer-btn')!;
    const timerDisplay = document.getElementById('timer-display')!;
    const timerValue = document.getElementById('timer-value')!;

    function formatTime(s: number) {
      const m = Math.floor(s / 60);
      const sec = s % 60;
      return `${m}:${sec.toString().padStart(2, '0')}`;
    }

    timerBtn.addEventListener('click', () => {
      if (!timerRunning) {
        timerRunning = true;
        timerBtn.style.display = 'none';
        timerDisplay.style.display = 'inline';
        timerInterval = setInterval(() => {
          timerSeconds--;
          timerValue.textContent = formatTime(timerSeconds);
          if (timerSeconds <= 0) {
            clearInterval(timerInterval);
            timerValue.textContent = 'Tiden är slut!';
          }
        }, 1000) as unknown as number;
      }
    });
  </script>
</Base>

<style>
  .prov-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .prov-header h1 {
    font-size: 1.6rem;
    margin-bottom: 0.3rem;
  }

  .prov-meta {
    color: var(--color-muted);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .prov-timer {
    margin-bottom: 1rem;
  }

  .timer-display {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .btn-sm {
    padding: 0.5rem 1.2rem;
    font-size: 0.9rem;
  }

  .prov-progress {
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .prov-question {
    display: flex;
    gap: 0.6rem;
    margin-bottom: 1.5rem;
  }

  .prov-question-num {
    font-weight: 700;
    font-size: 1.1rem;
    flex-shrink: 0;
    min-width: 2rem;
  }

  .prov-question-text {
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .prov-options {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 2rem;
    padding-left: 2.6rem;
  }

  .prov-option {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.7rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    cursor: pointer;
    transition: all 0.15s;
    background: var(--color-surface);
  }

  .prov-option:hover {
    border-color: var(--color-primary);
    background: #f0f4ff;
  }

  .prov-option.selected {
    border-color: var(--color-primary);
    background: #eff3ff;
    box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.15);
  }

  .prov-option input {
    display: none;
  }

  .prov-option-letter {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.85rem;
    flex-shrink: 0;
  }

  .prov-option.selected .prov-option-letter {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
  }

  .prov-option-text {
    font-size: 1rem;
    line-height: 1.4;
  }

  .prov-nav {
    display: flex;
    justify-content: center;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .prov-dots {
    display: flex;
    justify-content: center;
    gap: 0.4rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }

  .prov-dot {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
    background: var(--color-surface);
  }

  .prov-dot.active {
    border-color: var(--color-primary);
    color: var(--color-primary);
    box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.2);
  }

  .prov-dot.answered {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
  }

  /* Overview */
  .prov-overview-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.8rem;
    max-width: 400px;
    margin: 1.5rem auto;
  }

  .prov-overview-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    padding: 0.8rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    cursor: pointer;
    transition: all 0.15s;
  }

  .prov-overview-item:hover {
    border-color: var(--color-primary);
  }

  .prov-overview-item.answered {
    border-color: var(--color-primary);
    background: #eff3ff;
  }

  .prov-overview-num {
    font-weight: 700;
    font-size: 0.9rem;
  }

  .prov-overview-ans {
    color: var(--color-muted);
    font-size: 0.85rem;
  }

  /* Results */
  .prov-result-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .prov-result-header h2 {
    margin-top: 0;
  }

  .prov-score {
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
  }

  .prov-result-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .prov-result-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 1rem;
    border-radius: var(--radius);
    font-size: 0.95rem;
  }

  .prov-result-item.correct {
    background: #ecfdf5;
  }

  .prov-result-item.wrong {
    background: #fef2f2;
  }

  .prov-result-icon {
    font-weight: 700;
    font-size: 1.1rem;
  }

  .prov-result-item.correct .prov-result-icon {
    color: var(--color-success);
  }

  .prov-result-item.wrong .prov-result-icon {
    color: #ef4444;
  }

  .prov-result-num {
    font-weight: 600;
    min-width: 1.5rem;
  }

  .prov-result-correct {
    margin-left: auto;
    color: var(--color-success);
  }
</style>
