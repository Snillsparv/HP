---
import Base from '../layouts/Base.astro';
---

<Base title="Träna på Högskoleprovet – HPAkuten" description="Öva på exempeluppgifter för alla åtta delprov på högskoleprovet. Välj delprov och träna med riktiga uppgifter.">
  <div class="page-content">
    <div class="container" style="max-width: 800px;">
      <h1>Träna på Högskoleprovet</h1>
      <p class="page-intro">Gör riktiga provuppgifter från HT 2021 — det prov där Jonas fick 160 av 160 poäng.</p>

      <h2 style="margin-top: 2rem;">Kvantitativa delprov</h2>
      <p style="color: var(--color-muted); margin-bottom: 1rem;">Börja med dessa — gör dem på tid som om det vore skarpt läge.</p>

      <div class="prov-list">
        <a href="/prov/xyz-ht2021" class="prov-list-item">
          <div class="prov-list-icon">1</div>
          <div>
            <h3>XYZ — Matematisk problemlösning</h3>
            <p>12 uppgifter · 12 minuter</p>
          </div>
        </a>
        <a href="/prov/kva-ht2021" class="prov-list-item">
          <div class="prov-list-icon">2</div>
          <div>
            <h3>KVA — Kvantitativa jämförelser</h3>
            <p>10 uppgifter · 18 minuter</p>
          </div>
        </a>
        <a href="/prov/nog-ht2021" class="prov-list-item">
          <div class="prov-list-icon">3</div>
          <div>
            <h3>NOG — Kvantitativa resonemang</h3>
            <p>6 uppgifter · 12 minuter</p>
          </div>
        </a>
        <a href="/prov/dtk-ht2021" class="prov-list-item">
          <div class="prov-list-icon">4</div>
          <div>
            <h3>DTK — Diagram, tabeller och kartor</h3>
            <p>12 uppgifter · 18 minuter</p>
          </div>
        </a>
      </div>

      <h2 style="margin-top: 3rem;">Verbala delprov</h2>
      <p style="color: var(--color-muted); margin-bottom: 1rem;">Kommer snart!</p>

      <div class="prov-list">
        <div class="prov-list-item prov-list-item--disabled">
          <div class="prov-list-icon">5</div>
          <div>
            <h3>ORD — Ordförståelse</h3>
            <p>10 uppgifter · Kommer snart</p>
          </div>
        </div>
        <div class="prov-list-item prov-list-item--disabled">
          <div class="prov-list-icon">6</div>
          <div>
            <h3>LÄS — Läsförståelse</h3>
            <p>10 uppgifter · Kommer snart</p>
          </div>
        </div>
        <div class="prov-list-item prov-list-item--disabled">
          <div class="prov-list-icon">7</div>
          <div>
            <h3>MEK — Meningskomplettering</h3>
            <p>5 uppgifter · Kommer snart</p>
          </div>
        </div>
        <div class="prov-list-item prov-list-item--disabled">
          <div class="prov-list-icon">8</div>
          <div>
            <h3>ELF — Engelsk läsförståelse</h3>
            <p>10 uppgifter · Kommer snart</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</Base>

<style>
  .prov-list {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .prov-list-item {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding: 1.2rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--color-text);
    transition: all 0.15s;
    box-shadow: var(--shadow);
  }

  a.prov-list-item:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
    text-decoration: none;
  }

  .prov-list-item--disabled {
    opacity: 0.5;
    cursor: default;
  }

  .prov-list-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .prov-list-item--disabled .prov-list-icon {
    background: var(--color-muted);
  }

  .prov-list-item h3 {
    margin: 0 0 0.2rem;
    font-size: 1.05rem;
  }

  .prov-list-item p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.9rem;
  }
</style>
