---
import Base from '../../layouts/Base.astro';
import { getSessionFromCookies } from '../../lib/auth.js';
const user = await getSessionFromCookies(Astro.request.headers.get('cookie'));
---

<Base title="Kvantitativt prov HT 2021 – HPAkuten" description="Gör hela den kvantitativa delen av högskoleprovet HT 2021. 40 uppgifter, 55 minuter.">
  <div class="page-content">
    <div class="container" style="max-width: 700px;">
      <div id="prov-root"></div>
    </div>
  </div>

  <script define:vars={{ isLoggedIn: !!user }}>
    window.__isLoggedIn = isLoggedIn;
  </script>

  <script>
    import { subTests } from '../../lib/questions-ht2021.js';
    import type { Question, SubTest } from '../../lib/questions-ht2021.js';

    const root = document.getElementById('prov-root')!;
    const allQuestions = subTests.flatMap(st => st.questions.map(q => ({ ...q, subTest: st })));
    const totalTime = 55 * 60;
    const answers: (number | null)[] = new Array(allQuestions.length).fill(null);
    let current = 0;
    let submitted = false;
    let timerSeconds = totalTime;
    let timerInterval: number | null = null;
    let timerPaused = false;
    let started = false;

    // Load KaTeX
    const css = document.createElement('link');
    css.rel = 'stylesheet';
    css.href = 'https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css';
    document.head.appendChild(css);
    const js = document.createElement('script');
    js.src = 'https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.js';
    document.head.appendChild(js);

    function renderTex() {
      if (typeof (window as any).katex === 'undefined') { setTimeout(renderTex, 50); return; }
      document.querySelectorAll('.tex').forEach(el => {
        (window as any).katex.render(el.textContent || '', el, { throwOnError: false });
      });
    }

    function fmt(s: number) { return `${Math.floor(s/60)}:${(s%60).toString().padStart(2,'0')}`; }

    function startTimer() {
      timerInterval = setInterval(() => {
        if (!timerPaused) {
          timerSeconds--;
          const el = document.getElementById('timer-val');
          if (el) el.textContent = fmt(timerSeconds);
          if (timerSeconds <= 0) {
            clearInterval(timerInterval!);
            submitted = true;
            render();
          }
        }
      }, 1000) as unknown as number;
    }

    function renderStart() {
      root.innerHTML = `
        <div style="text-align:center; padding: 3rem 0;">
          <h1 style="font-size:1.6rem;">Kvantitativt prov — HT 2021</h1>
          <p style="color:var(--color-muted); margin-bottom: 0.5rem;">Det prov där Jonas fick 160 av 160 poäng.</p>
          <div style="margin: 2rem 0;">
            <div style="font-size:2.5rem; font-weight:800; color:var(--color-primary);">40</div>
            <div style="color:var(--color-muted); font-size:0.9rem;">uppgifter</div>
          </div>
          <div style="margin-bottom: 2rem;">
            <div style="font-size:2.5rem; font-weight:800; color:var(--color-primary);">55:00</div>
            <div style="color:var(--color-muted); font-size:0.9rem;">minuter</div>
          </div>
          <p style="color:var(--color-muted); font-size:0.9rem; max-width:400px; margin:0 auto 2rem;">
            Provet består av fyra delprov: XYZ (12), KVA (10), NOG (6) och DTK (12).<br>Tiden startar automatiskt.
          </p>
          <button class="btn btn-primary" id="btn-start" style="font-size:1.1rem; padding:0.9rem 3rem;">Starta provet</button>
        </div>
      `;
      document.getElementById('btn-start')?.addEventListener('click', () => {
        started = true;
        startTimer();
        render();
      });
    }

    function currentSubTest(): SubTest {
      return allQuestions[current].subTest;
    }

    function render() {
      if (!started) { renderStart(); return; }
      if (submitted) { renderResults(); return; }
      const q = allQuestions[current];
      const st = q.subTest;
      const labels = ['A', 'B', 'C', 'D', 'E'];

      let questionHTML = '';
      if (st.type === 'kva' && q.q1) {
        questionHTML = `
          <div class="pq-question"><span class="pq-num">${q.num}.</span><span class="pq-text">
            ${q.text ? q.text + '<br><br>' : ''}
            <div class="kva-pair">
              <div class="kva-row"><span class="kva-label"><i>Kvantitet I:</i></span><span>${q.q1}</span></div>
              <div class="kva-row"><span class="kva-label"><i>Kvantitet II:</i></span><span>${q.q2}</span></div>
            </div>
          </span></div>`;
      } else if (st.type === 'nog' && q.s1) {
        questionHTML = `
          <div class="pq-question"><span class="pq-num">${q.num}.</span><span class="pq-text">${q.text}</span></div>
          <div class="nog-statements">
            <div class="nog-stmt"><span class="nog-stmt-num">(1)</span><span>${q.s1}</span></div>
            <div class="nog-stmt"><span class="nog-stmt-num">(2)</span><span>${q.s2}</span></div>
          </div>
          <div class="nog-header"><b>Tillräcklig information för lösningen erhålls</b></div>`;
      } else {
        questionHTML = `<div class="pq-question"><span class="pq-num">${q.num}.</span><span class="pq-text">${q.text}</span></div>`;
      }

      let diagramHTML = '';
      if (st.type === 'dtk' && q.diagram) {
        diagramHTML = `<div class="dtk-diagram"><img src="${q.diagram}" alt="${q.diagramAlt}" class="dtk-diagram-img ${q.rotate ? 'dtk-rotated' : ''}" data-fadein style="cursor:zoom-in;" /></div>`;
      }

      root.innerHTML = `
        <div class="prov-top-bar">
          <span class="prov-section-tag">${st.shortName}</span>
          <span class="prov-timer-bar">
            <span id="timer-val">${fmt(timerSeconds)}</span>
            <button class="btn-timer-toggle" id="btn-pause">${timerPaused ? '▶' : '⏸'}</button>
          </span>
        </div>
        <div class="pq-progress">Uppgift ${current + 1} av ${allQuestions.length}</div>
        ${diagramHTML}
        <div class="pq-card">
          ${questionHTML}
          <div class="pq-options">
            ${q.options.map((opt, i) => `
              <label class="pq-opt ${answers[current] === i ? 'pq-opt--sel' : ''}">
                <input type="radio" name="q${current}" value="${i}" ${answers[current] === i ? 'checked' : ''} />
                <span class="pq-letter">${labels[i]}</span>
                <span class="pq-opt-text">${opt}</span>
              </label>
            `).join('')}
          </div>
        </div>
        <div class="pq-nav">
          <button class="btn btn-outline btn-sm" id="btn-prev" ${current === 0 ? 'disabled' : ''}>Föregående</button>
          <button class="btn btn-outline btn-sm" id="btn-overview">Översikt</button>
          ${current === allQuestions.length - 1
            ? '<button class="btn btn-primary btn-sm" id="btn-submit">Rätta provet</button>'
            : '<button class="btn btn-primary btn-sm" id="btn-next">Nästa</button>'}
        </div>
        <div class="pq-dots">${allQuestions.map((_, i) => `<span class="pq-dot ${i === current ? 'pq-dot--cur' : ''} ${answers[i] !== null ? 'pq-dot--ans' : ''}" data-i="${i}">${i+1}</span>`).join('')}</div>
      `;
      bindEvents();
    }

    function bindEvents() {
      root.querySelectorAll('input[type="radio"]').forEach(el => {
        el.addEventListener('change', (e) => { answers[current] = Number((e.target as HTMLInputElement).value); render(); });
      });
      document.getElementById('btn-prev')?.addEventListener('click', () => { current--; render(); });
      document.getElementById('btn-next')?.addEventListener('click', () => { current++; render(); });
      document.getElementById('btn-submit')?.addEventListener('click', () => { submitted = true; if (timerInterval) clearInterval(timerInterval); render(); });
      document.getElementById('btn-overview')?.addEventListener('click', renderOverview);
      document.getElementById('btn-pause')?.addEventListener('click', () => { timerPaused = !timerPaused; render(); });
      root.querySelectorAll('.pq-dot').forEach(el => {
        el.addEventListener('click', () => { current = Number(el.getAttribute('data-i')); render(); });
      });
      // DTK zoom
      root.querySelectorAll('.dtk-diagram-img').forEach(img => {
        img.addEventListener('click', () => {
          const src = (img as HTMLImageElement).src;
          const isRotated = img.classList.contains('dtk-rotated');
          const overlay = document.createElement('div');
          overlay.className = 'dtk-zoom-overlay';
          overlay.innerHTML = `<div class="dtk-zoom-inner"><img src="${src}" class="${isRotated ? 'dtk-zoom-rotated' : ''}" /></div>`;
          document.body.appendChild(overlay);
          let touchMoved = false;
          overlay.addEventListener('touchstart', () => { touchMoved = false; });
          overlay.addEventListener('touchmove', () => { touchMoved = true; });
          overlay.addEventListener('click', () => { if (!touchMoved) overlay.remove(); });
        });
      });
      // Fade-in images
      root.querySelectorAll('img[data-fadein]').forEach(img => {
        const el = img as HTMLImageElement;
        if (el.complete && el.naturalHeight > 0) el.classList.add('loaded');
        else el.addEventListener('load', () => el.classList.add('loaded'));
      });
      renderTex();
    }

    function renderOverview() {
      const labels = ['A', 'B', 'C', 'D', 'E'];
      const answered = answers.filter(a => a !== null).length;
      let html = `
        <div class="prov-top-bar">
          <span>Översikt</span>
          <span class="prov-timer-bar"><span id="timer-val">${fmt(timerSeconds)}</span><button class="btn-timer-toggle" id="btn-pause">${timerPaused ? '▶' : '⏸'}</button></span>
        </div>
        <p style="text-align:center;color:var(--color-muted);">${answered} av ${allQuestions.length} besvarade</p>
      `;
      for (const st of subTests) {
        const qs = allQuestions.filter(q => q.subTest.id === st.id);
        const startIdx = allQuestions.indexOf(qs[0]);
        html += `<h3 style="margin:1.5rem 0 0.5rem; font-size:0.95rem;">${st.shortName}</h3><div class="pq-overview">`;
        qs.forEach((q, i) => {
          const gi = startIdx + i;
          html += `<button class="pq-ov-btn ${answers[gi] !== null ? 'pq-ov-btn--ans' : ''}" data-i="${gi}"><span class="pq-ov-num">${q.num}</span><span class="pq-ov-val">${answers[gi] !== null ? labels[answers[gi]!] : '—'}</span></button>`;
        });
        html += `</div>`;
      }
      html += `<div class="pq-nav" style="margin-top:1.5rem;">
        <button class="btn btn-outline btn-sm" id="btn-back">Tillbaka</button>
        <button class="btn btn-primary btn-sm" id="btn-submit">Rätta provet</button>
      </div>`;
      root.innerHTML = html;
      root.querySelectorAll('.pq-ov-btn').forEach(el => {
        el.addEventListener('click', () => { current = Number(el.getAttribute('data-i')); render(); });
      });
      document.getElementById('btn-back')?.addEventListener('click', () => render());
      document.getElementById('btn-submit')?.addEventListener('click', () => { submitted = true; if (timerInterval) clearInterval(timerInterval); render(); });
      document.getElementById('btn-pause')?.addEventListener('click', () => { timerPaused = !timerPaused; renderOverview(); });
    }

    async function renderResults() {
      const labels = ['A', 'B', 'C', 'D', 'E'];
      const elapsed = totalTime - timerSeconds;

      // Per-subtest scores
      let resultsHTML = '';
      let totalScore = 0;
      for (const st of subTests) {
        const qs = allQuestions.filter(q => q.subTest.id === st.id);
        const startIdx = allQuestions.indexOf(qs[0]);
        let score = 0;
        qs.forEach((q, i) => { if (answers[startIdx + i] === q.correct) score++; });
        totalScore += score;
        resultsHTML += `
          <h3 style="margin:1.5rem 0 0.5rem;">${st.shortName} — ${score}/${qs.length}</h3>
          <div class="pq-results">${qs.map((q, i) => {
            const gi = startIdx + i;
            const ok = answers[gi] === q.correct;
            return `<div class="pq-res ${ok ? 'pq-res--ok' : 'pq-res--no'}">
              <span class="pq-res-icon">${ok ? '✓' : '✗'}</span>
              <span class="pq-res-num">${q.num}.</span>
              <span>Ditt svar: <b>${answers[gi] !== null ? labels[answers[gi]!] : '—'}</b></span>
              ${!ok ? `<span class="pq-res-right">Rätt: <b>${labels[q.correct]}</b></span>` : ''}
            </div>`;
          }).join('')}</div>`;
      }

      root.innerHTML = `
        <div class="pq-result-head">
          <h2>Resultat</h2>
          <div class="pq-score">${totalScore}/${allQuestions.length}</div>
          <p style="color:var(--color-muted)">rätt svar · tid: ${fmt(elapsed)}</p>
        </div>
        ${resultsHTML}
        <div id="save-area" style="margin-top:2rem; text-align:center;"></div>
        <div class="pq-nav" style="margin-top:2rem;">
          <button class="btn btn-outline btn-sm" id="btn-retry">Gör om provet</button>
          <a href="/trana" class="btn btn-primary btn-sm">Tillbaka</a>
        </div>
      `;

      // Save results
      const saveArea = document.getElementById('save-area')!;
      if ((window as any).__isLoggedIn) {
        try {
          await fetch('/api/test/results', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ testId: 'kvant-ht2021', score: totalScore, total: allQuestions.length, answers, timeSeconds: elapsed }),
          });
          saveArea.innerHTML = '<div class="tip-box success"><strong>Resultat sparat!</strong></div>';
        } catch {
          saveArea.innerHTML = '<div class="tip-box warning"><strong>Kunde inte spara resultatet.</strong></div>';
        }
      } else {
        saveArea.innerHTML = `<div class="tip-box"><strong>Vill du spara ditt resultat?</strong> <a href="/konto/registrera">Skapa ett gratis konto</a> eller <a href="/konto/login">logga in</a>.</div>`;
      }

      document.getElementById('btn-retry')?.addEventListener('click', () => {
        answers.fill(null); current = 0; submitted = false; timerSeconds = totalTime; timerPaused = false; started = false;
        render();
      });
    }

    render();
  </script>
</Base>

<style is:global>
  .prov-top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; padding: 0.6rem 1rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); }
  .prov-section-tag { font-weight: 700; font-size: 0.85rem; color: var(--color-primary); text-transform: uppercase; letter-spacing: 0.06em; }
  .prov-timer-bar { display: flex; align-items: center; gap: 0.5rem; font-size: 1.1rem; font-weight: 700; font-variant-numeric: tabular-nums; }
  .btn-timer-toggle { background: none; border: none; font-size: 1rem; cursor: pointer; padding: 0.2rem; color: var(--color-muted); }
  .btn-timer-toggle:hover { color: var(--color-text); }

  .pq-progress { text-align: center; font-size: 0.8rem; color: var(--color-muted); margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.06em; }
  .pq-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 2rem 2rem 1.5rem; box-shadow: var(--shadow); margin-bottom: 2rem; }
  .pq-question { margin-bottom: 1.8rem; font-size: 1.05rem; line-height: 1.7; }
  .pq-num { font-weight: 700; margin-right: 0.5rem; }
  .pq-options { display: flex; flex-direction: column; gap: 0; margin-left: 1.2rem; }
  .pq-opt { display: flex; align-items: center; gap: 0.8rem; padding: 0.65rem 1rem; cursor: pointer; border-radius: var(--radius); transition: background 0.12s; border: 2px solid transparent; }
  .pq-opt:hover { background: #f5f7ff; }
  .pq-opt--sel { background: #eef2ff; border-color: var(--color-primary); }
  .pq-opt input { display: none; }
  .pq-letter { width: 30px; height: 30px; border-radius: 50%; background: #f1f5f9; border: 1.5px solid var(--color-border); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.85rem; flex-shrink: 0; }
  .pq-opt--sel .pq-letter { background: var(--color-primary); color: #fff; border-color: var(--color-primary); }
  .pq-opt-text { font-size: 1.05rem; line-height: 1.5; }
  .pq-nav { display: flex; justify-content: center; gap: 0.8rem; flex-wrap: wrap; }
  .pq-dots { display: flex; justify-content: center; gap: 0.25rem; margin-top: 1.5rem; flex-wrap: wrap; }
  .pq-dot { width: 28px; height: 28px; border-radius: 50%; border: 1.5px solid var(--color-border); display: flex; align-items: center; justify-content: center; font-size: 0.65rem; font-weight: 600; cursor: pointer; background: var(--color-surface); }
  .pq-dot:hover { border-color: var(--color-primary); color: var(--color-primary); }
  .pq-dot--cur { border-color: var(--color-primary); color: var(--color-primary); box-shadow: 0 0 0 2px rgba(37,99,235,0.15); }
  .pq-dot--ans { background: var(--color-primary); color: #fff; border-color: var(--color-primary); }
  .pq-overview { display: grid; grid-template-columns: repeat(6, 1fr); gap: 0.5rem; max-width: 400px; margin: 0 auto; }
  .pq-ov-btn { display: flex; flex-direction: column; align-items: center; gap: 0.1rem; padding: 0.5rem; border: 1.5px solid var(--color-border); border-radius: var(--radius); background: var(--color-surface); cursor: pointer; font-family: var(--font-sans); }
  .pq-ov-btn:hover { border-color: var(--color-primary); }
  .pq-ov-btn--ans { border-color: var(--color-primary); background: #eef2ff; }
  .pq-ov-num { font-weight: 700; font-size: 0.8rem; }
  .pq-ov-val { color: var(--color-muted); font-size: 0.7rem; }
  .pq-result-head { text-align: center; margin-bottom: 2rem; }
  .pq-result-head h2 { margin-top: 0; }
  .pq-score { font-size: 3rem; font-weight: 800; color: var(--color-primary); line-height: 1; }
  .pq-results { display: flex; flex-direction: column; gap: 0.4rem; }
  .pq-res { display: flex; align-items: center; gap: 0.6rem; padding: 0.55rem 1rem; border-radius: var(--radius); font-size: 0.95rem; }
  .pq-res--ok { background: #ecfdf5; }
  .pq-res--no { background: #fef2f2; }
  .pq-res-icon { font-weight: 700; font-size: 1.1rem; }
  .pq-res--ok .pq-res-icon { color: var(--color-success); }
  .pq-res--no .pq-res-icon { color: #ef4444; }
  .pq-res-num { font-weight: 600; min-width: 2rem; }
  .pq-res-right { margin-left: auto; color: var(--color-success); }
  .tex { font-size: 1.05em; }
  .btn-sm { padding: 0.5rem 1.2rem; font-size: 0.9rem; }
  .kva-pair { margin-top: 0.8rem; display: flex; flex-direction: column; gap: 0.4rem; }
  .kva-row { display: flex; align-items: baseline; gap: 1rem; }
  .kva-label { min-width: 90px; flex-shrink: 0; font-size: 0.95rem; }
  .nog-statements { margin: 1rem 0 1.2rem 1.5rem; display: flex; flex-direction: column; gap: 0.6rem; }
  .nog-stmt { display: flex; gap: 0.6rem; font-size: 1rem; line-height: 1.6; }
  .nog-stmt-num { font-weight: 600; flex-shrink: 0; min-width: 1.8rem; }
  .nog-header { margin: 1.2rem 0 0.8rem 1.5rem; padding-top: 1rem; border-top: 1px solid var(--color-border); font-size: 0.95rem; }
  .dtk-diagram { margin-bottom: 1.5rem; text-align: center; }
  .dtk-diagram-img { max-width: 100%; border: 1px solid var(--color-border); border-radius: var(--radius); background: #fff; cursor: zoom-in; }
  .dtk-rotated { transform: rotate(90deg); transform-origin: center center; margin: -10% 0; }
  .dtk-zoom-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.9); z-index: 1000; cursor: pointer; }
  .dtk-zoom-inner { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; padding: 1rem; }
  .dtk-zoom-inner img { max-width: 95vw; max-height: 95vh; background: #fff; border-radius: var(--radius); box-shadow: 0 8px 32px rgba(0,0,0,0.4); }
  .dtk-zoom-inner img.dtk-zoom-rotated { transform: rotate(90deg); max-width: 95vh; max-height: 95vw; }
  @media (max-width: 768px) { .dtk-rotated { max-width: 70%; margin: -5% auto; } }
  @media (max-width: 480px) { .pq-card { padding: 1.2rem; } .pq-options { margin-left: 0; } .nog-statements, .nog-header { margin-left: 0.5rem; } .kva-label { min-width: 75px; } }
</style>
