---
import Base from '../../layouts/Base.astro';
---

<Base title="LÄS — Läsförståelse (HT 2021) – HPAkuten" description="Öva på LÄS-delen från högskoleprovet HT 2021. 10 uppgifter baserade på tre texter, rätta direkt.">
  <div class="page-content">
    <div class="container" style="max-width: 700px;">

      <div class="prov-header">
        <h1>LÄS — Läsförståelse</h1>
        <p class="prov-meta">Högskoleprov HT 2021 · 10 uppgifter · Rekommenderad tid: 22 minuter</p>
        <div class="prov-timer">
          <button class="btn btn-outline btn-sm" id="timer-btn">Starta timer (22:00)</button>
          <span class="timer-display" id="timer-display">⏱ <span id="timer-value">22:00</span></span>
        </div>
      </div>

      <div id="prov-app"></div>

    </div>
  </div>

  <script>
    const textGroups = [
      {
        images: ['/prov-las1-text1.png'],
        title: 'Text 1: Ursäktens betydelse',
        questions: [
          { num: 11, text: '<b>Vad bör kritiserade företag undvika, enligt Peter Norbergs resonemang?</b>', options: ['Att öka insynen i företaget.', 'Att direkt ge kritikerna rätt.', 'Att redovisa sina motiv.', 'Att utlova ekonomisk kompensation.'], correct: 1 },
          { num: 12, text: '<b>Vad framhåller texten som orsak till de så kallade köttskandalerna?</b>', options: ['Företagens risktagande i jakten på lönsamhet.', 'Företagens underskattning av kundernas värderingar och krav.', 'Företagens tilltro till amerikanska metoder för krishantering.', 'Företagens rutiner vid hantering av oförutsedda händelser.'], correct: 0 },
        ]
      },
      {
        images: ['/prov-las1-text2a.png', '/prov-las1-text2b.png'],
        title: 'Text 2: Läkares hälsa',
        questions: [
          { num: 13, text: '<b>Vilket påstående om svenska läkares hälsa stämmer överens med det som framkommer i texten?</b>', options: ['Även om läkarna själva uppger att deras hälsa försämrats, så är den på en godtagbar nivå.', 'Psykiska besvär leder sällan till att läkare sjukskriver sig.', 'Trots en viss avsevärd negativ utveckling säger sig läkarna mår rätt bra.', 'Läkarna uppger bättre hälsa än män och kvinnor i övrigt.'], correct: 0 },
          { num: 14, text: '<b>Vad är följande har Ann Fridner studerat, enligt texten?</b>', options: ['Attityderna till den läkare psykiska ohälsan bland sjukvårdsanställda.', 'Sambandet mellan läkaryrkets krav och sjukskrivning bland sjukvårdsanställda.', 'Förekomsten av sjukskrivning bland tjänstegrupper.', 'Konsekvenserna av psykisk ohälsa bland sjukvårdsanställda.'], correct: 2 },
          { num: 15, text: '<b>Vilken av följande till synes motsägelsefulla förhållanden nämns i texten?</b>', options: ['Att läkare trots sin utbildning ofta har sämre hälsa än allmänheten.', 'Att hälsosammare av de sjukhus lediga arbetare i regel.', 'Att läkare trots en sunding livsstil drabbas av psykisk ohälsa.', 'Att det trots en allmän sjukvårdsutrymme skett en positiv.'], correct: 0 },
          { num: 16, text: '<b>Vilken av följande alternativa rubriker har mest med texten att göra?</b>', options: ['Effekterna av vårdreformer bland läkare.', 'Bristande kunskap om läkares arbetsförhållanden.', 'Sjukfrånvaron förklarar läkares arbetssituation.', 'Sjukfrånvaron förklarar läkares arbetssituation.'], correct: 1 },
        ]
      },
      {
        images: ['/prov-las1-text3a.png', '/prov-las1-text3b.png'],
        title: 'Text 3: Barnlitteratur',
        questions: [
          { num: 17, text: '<b>Vilket påstående överensstämmer bäst med hur texten beskriver barnlitteraturens nuvarande ställning?</b>', options: ['Barnlitteraturen är ännu i huvudsak ett nationellt och regionalt fenomen.', 'Barnlitteraturen har fått en global uppskattning till följd av gränser som en enskild uppfattning klassiker.', 'Barnlitteraturen har vuxit till en utbredning som gör en beskrivning av dess globala sammanhang nödvändig.', 'Barnlitteraturen bedöms fortfarande enligt samlade akademiska kriterier som en forskningsmässig gren.'], correct: 2 },
          { num: 18, text: '<b>Boken Kinderlitteratur har den tyska barnlitteraturens relevans som utgångspunkt. Hur kommenterar författaren detta, enligt texten?</b>', options: ['Den poängterar att utvecklingen i Tyskland typiskt speglar förhållanden i andra länder.', 'Den hävder att den tyska klassiska barnboken har fått fotfäste utanför landets gränser.', 'Den konstaterar att Tysklands roll har förblivit central.', 'Den menar att en viss förskjutning av det västliga förblivit.'], correct: 0 },
          { num: 19, text: '<b>Vad sägs i texten om litterära verk som börjar bli ålderstigna?</b>', options: ['De tillhör inte istället klassificerade som verk som man inte längre.', 'De har goda förutsättningar att leva upp till de krav som Kümmerling-Meibauer ställer på en och annan skrift.', 'De är tidigare så ursprungliga verksamhets originalitet.', 'De är estetiskt sätts likvärdsfulla men överträffas.'], correct: 1 },
          { num: 20, text: '<b>Vilka barnlitteratörer är det i första hand boken behandlar som klassiker, enligt Bettina Kümmerling?</b>', options: ['De som är mest originella.', 'De som har genererat mest forskning.', 'De som har bidragit med pedagogiska innovationer.', 'De som har fått en global utbredning.'], correct: 3 },
        ]
      }
    ];

    const allQuestions = textGroups.flatMap(g => g.questions.map(q => ({ ...q, images: g.images, textTitle: g.title })));
    const answers: (number | null)[] = new Array(allQuestions.length).fill(null);
    let current = 0;
    let submitted = false;
    const app = document.getElementById('prov-app')!;

    function render() {
      if (submitted) { renderResults(); return; }
      const q = allQuestions[current];
      const labels = ['A', 'B', 'C', 'D'];
      app.innerHTML = `
        <div class="pq-progress">Uppgift ${current + 1} av ${allQuestions.length}</div>
        <div class="las-text-section">
          <p class="las-text-label">${q.textTitle} — klicka för att läsa</p>
          ${q.images.map((img: string) => `<img src="${img}" alt="${q.textTitle}" class="las-text-img dtk-diagram-img" loading="lazy" data-fadein style="cursor:zoom-in;" />`).join('')}
        </div>
        <div class="pq-card">
          <div class="pq-question">
            <span class="pq-num">${q.num}.</span>
            <span class="pq-text">${q.text}</span>
          </div>
          <div class="pq-options">
            ${q.options.map((opt: string, i: number) => `
              <label class="pq-opt ${answers[current] === i ? 'pq-opt--sel' : ''}">
                <input type="radio" name="q${current}" value="${i}" ${answers[current] === i ? 'checked' : ''} />
                <span class="pq-letter">${labels[i]}</span>
                <span class="pq-opt-text">${opt}</span>
              </label>
            `).join('')}
          </div>
        </div>
        <div class="pq-nav">
          <div class="pq-nav-main">
            <button class="btn btn-outline btn-sm" id="btn-prev" ${current === 0 ? 'disabled' : ''}>Föregående</button>
            ${current === allQuestions.length - 1
              ? '<button class="btn btn-primary btn-sm" id="btn-submit">Rätta provet</button>'
              : '<button class="btn btn-primary btn-sm" id="btn-next">Nästa</button>'}
          </div>
          <button class="btn btn-sm btn-overview-link" id="btn-overview">Översikt</button>
        </div>
        <div class="pq-dots">
          ${allQuestions.map((_: any, i: number) => `<span class="pq-dot ${i === current ? 'pq-dot--cur' : ''} ${answers[i] !== null ? 'pq-dot--ans' : ''}" data-i="${i}">${i + 1}</span>`).join('')}
        </div>
      `;
      bindEvents();
    }

    function bindEvents() {
      app.querySelectorAll('input[type="radio"]').forEach(el => {
        el.addEventListener('change', (e) => { answers[current] = Number((e.target as HTMLInputElement).value); render(); });
      });
      document.getElementById('btn-prev')?.addEventListener('click', () => { current--; render(); });
      document.getElementById('btn-next')?.addEventListener('click', () => { current++; render(); });
      document.getElementById('btn-submit')?.addEventListener('click', () => { submitted = true; render(); });
      document.getElementById('btn-overview')?.addEventListener('click', renderOverview);
      app.querySelectorAll('.pq-dot').forEach(el => {
        el.addEventListener('click', () => { current = Number(el.getAttribute('data-i')); render(); });
      });
      // Zoom on text images
      app.querySelectorAll('.las-text-img').forEach(img => {
        img.addEventListener('click', () => {
          const src = (img as HTMLImageElement).src;
          const overlay = document.createElement('div');
          overlay.className = 'dtk-zoom-overlay';
          overlay.innerHTML = `<div class="dtk-zoom-inner"><img src="${src}" /></div>`;
          document.body.appendChild(overlay);
          let touchMoved = false;
          overlay.addEventListener('touchstart', () => { touchMoved = false; });
          overlay.addEventListener('touchmove', () => { touchMoved = true; });
          overlay.addEventListener('click', () => { if (!touchMoved) overlay.remove(); });
        });
      });
      // Fade-in
      app.querySelectorAll('img[data-fadein]').forEach(img => {
        const el = img as HTMLImageElement;
        if (el.complete && el.naturalHeight > 0) el.classList.add('loaded');
        else el.addEventListener('load', () => el.classList.add('loaded'));
      });
    }

    function renderOverview() {
      const labels = ['A', 'B', 'C', 'D'];
      const answered = answers.filter(a => a !== null).length;
      app.innerHTML = `
        <h2 style="text-align:center;margin-top:0;">Översikt</h2>
        <p style="text-align:center;color:var(--color-muted);">${answered} av ${allQuestions.length} besvarade</p>
        <div class="pq-overview" style="grid-template-columns:repeat(5,1fr);">${allQuestions.map((q: any, i: number) => `
          <button class="pq-ov-btn ${answers[i] !== null ? 'pq-ov-btn--ans' : ''}" data-i="${i}">
            <span class="pq-ov-num">${q.num}</span>
            <span class="pq-ov-val">${answers[i] !== null ? labels[answers[i]!] : '—'}</span>
          </button>
        `).join('')}</div>
        <div class="pq-nav" style="margin-top:1.5rem;justify-content:center;">
          <button class="btn btn-outline btn-sm" id="btn-back-first">Tillbaka</button>
          <button class="btn btn-primary btn-sm" id="btn-submit-overview">Rätta provet</button>
        </div>
      `;
      app.querySelectorAll('.pq-ov-btn').forEach(el => {
        el.addEventListener('click', () => { current = Number(el.getAttribute('data-i')); render(); });
      });
      document.getElementById('btn-back-first')?.addEventListener('click', () => { current = 0; render(); });
      document.getElementById('btn-submit-overview')?.addEventListener('click', () => { submitted = true; render(); });
    }

    function renderResults() {
      const labels = ['A', 'B', 'C', 'D'];
      let score = 0;
      allQuestions.forEach((q: any, i: number) => { if (answers[i] === q.correct) score++; });
      app.innerHTML = `
        <div class="pq-result-head"><h2>Resultat</h2><div class="pq-score">${score}/${allQuestions.length}</div><p style="color:var(--color-muted)">rätt svar</p></div>
        <div class="pq-results">${allQuestions.map((q: any, i: number) => {
          const ok = answers[i] === q.correct;
          return `<div class="pq-res ${ok ? 'pq-res--ok' : 'pq-res--no'}">
            <span class="pq-res-icon">${ok ? '✓' : '✗'}</span>
            <span class="pq-res-num">${q.num}.</span>
            <span>Ditt svar: <b>${answers[i] !== null ? labels[answers[i]!] : '—'}</b></span>
            ${!ok ? `<span class="pq-res-right">Rätt: <b>${labels[q.correct]}</b></span>` : ''}
          </div>`;
        }).join('')}</div>
        <div class="pq-nav" style="margin-top:2rem;justify-content:center;">
          <button class="btn btn-outline btn-sm" id="btn-retry">Gör om provet</button>
          <a href="/trana" class="btn btn-primary btn-sm">Tillbaka</a>
        </div>
      `;
      document.getElementById('btn-retry')?.addEventListener('click', () => { answers.fill(null); current = 0; submitted = false; render(); });
    }

    render();

    // Timer
    let timerSeconds = 22 * 60;
    let timerInterval: number;
    const timerBtn = document.getElementById('timer-btn')!;
    const timerDisp = document.getElementById('timer-display')!;
    const timerVal = document.getElementById('timer-value')!;
    function fmt(s: number) { return `${Math.floor(s/60)}:${(s%60).toString().padStart(2,'0')}`; }
    timerBtn.addEventListener('click', () => {
      timerBtn.style.display = 'none';
      timerDisp.style.display = 'inline';
      timerInterval = setInterval(() => {
        timerSeconds--;
        timerVal.textContent = fmt(timerSeconds);
        if (timerSeconds <= 0) { clearInterval(timerInterval); timerVal.textContent = 'Tiden är slut!'; }
      }, 1000) as unknown as number;
    });
  </script>
</Base>

<style is:global>
  .prov-header { text-align: center; margin-bottom: 2rem; }
  .prov-header h1 { font-size: 1.5rem; margin-bottom: 0.3rem; }
  .prov-meta { color: var(--color-muted); font-size: 0.9rem; margin-bottom: 1rem; }
  .prov-timer { margin-bottom: 0.5rem; }
  .timer-display { font-size: 1.3rem; font-weight: 700; color: var(--color-primary); display: none; }
  .btn-sm { padding: 0.5rem 1.2rem; font-size: 0.9rem; }
  .pq-progress { text-align: center; font-size: 0.8rem; color: var(--color-muted); margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.06em; }

  .las-text-section { margin-bottom: 1.5rem; }
  .las-text-label { font-size: 0.85rem; color: var(--color-muted); margin-bottom: 0.5rem; }
  .las-text-img { max-width: 100%; border: 1px solid var(--color-border); border-radius: var(--radius); background: #fff; margin-bottom: 0.5rem; cursor: zoom-in; }

  .pq-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 2rem 2rem 1.5rem; box-shadow: var(--shadow); margin-bottom: 2rem; }
  .pq-question { margin-bottom: 1.8rem; font-size: 1.05rem; line-height: 1.7; }
  .pq-num { font-weight: 700; margin-right: 0.5rem; }
  .pq-options { display: flex; flex-direction: column; gap: 0; margin-left: 1.2rem; }
  .pq-opt { display: flex; align-items: center; gap: 0.8rem; padding: 0.65rem 1rem; cursor: pointer; border-radius: var(--radius); transition: background 0.12s; border: 2px solid transparent; }
  .pq-opt:hover { background: #f5f7ff; }
  .pq-opt--sel { background: #eef2ff; border-color: var(--color-primary); }
  .pq-opt input { display: none; }
  .pq-letter { width: 30px; height: 30px; border-radius: 50%; background: #f1f5f9; border: 1.5px solid var(--color-border); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.85rem; flex-shrink: 0; }
  .pq-opt--sel .pq-letter { background: var(--color-primary); color: #fff; border-color: var(--color-primary); }
  .pq-opt-text { font-size: 1.05rem; line-height: 1.5; }
  .pq-nav { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.8rem; }
  .pq-nav-main { display: flex; gap: 0.8rem; }
  .btn-overview-link { background: none; border: none; color: var(--color-muted); text-decoration: underline; font-size: 0.85rem; cursor: pointer; padding: 0.4rem 0.6rem; }
  .btn-overview-link:hover { color: var(--color-primary); }
  .pq-dots { display: flex; justify-content: center; gap: 0.35rem; margin-top: 1.5rem; flex-wrap: wrap; }
  .pq-dot { width: 32px; height: 32px; border-radius: 50%; border: 1.5px solid var(--color-border); display: flex; align-items: center; justify-content: center; font-size: 0.78rem; font-weight: 600; cursor: pointer; background: var(--color-surface); }
  .pq-dot:hover { border-color: var(--color-primary); color: var(--color-primary); }
  .pq-dot--cur { border-color: var(--color-primary); color: var(--color-primary); box-shadow: 0 0 0 3px rgba(37,99,235,0.15); }
  .pq-dot--ans { background: var(--color-primary); color: #fff; border-color: var(--color-primary); }
  .pq-overview { display: grid; gap: 0.7rem; max-width: 350px; margin: 1.5rem auto; }
  .pq-ov-btn { display: flex; flex-direction: column; align-items: center; gap: 0.15rem; padding: 0.7rem; border: 1.5px solid var(--color-border); border-radius: var(--radius); background: var(--color-surface); cursor: pointer; font-family: var(--font-sans); }
  .pq-ov-btn:hover { border-color: var(--color-primary); }
  .pq-ov-btn--ans { border-color: var(--color-primary); background: #eef2ff; }
  .pq-ov-num { font-weight: 700; font-size: 0.9rem; }
  .pq-ov-val { color: var(--color-muted); font-size: 0.8rem; }
  .pq-result-head { text-align: center; margin-bottom: 2rem; }
  .pq-result-head h2 { margin-top: 0; }
  .pq-score { font-size: 3rem; font-weight: 800; color: var(--color-primary); line-height: 1; }
  .pq-results { display: flex; flex-direction: column; gap: 0.4rem; }
  .pq-res { display: flex; align-items: center; gap: 0.6rem; padding: 0.55rem 1rem; border-radius: var(--radius); font-size: 0.95rem; }
  .pq-res--ok { background: #ecfdf5; }
  .pq-res--no { background: #fef2f2; }
  .pq-res-icon { font-weight: 700; font-size: 1.1rem; }
  .pq-res--ok .pq-res-icon { color: var(--color-success); }
  .pq-res--no .pq-res-icon { color: #ef4444; }
  .pq-res-num { font-weight: 600; min-width: 2rem; }
  .pq-res-right { margin-left: auto; color: var(--color-success); }
  .dtk-zoom-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.9); z-index: 1000; cursor: pointer; }
  .dtk-zoom-inner { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; padding: 1rem; }
  .dtk-zoom-inner img { max-width: 95vw; max-height: 95vh; background: #fff; border-radius: var(--radius); box-shadow: 0 8px 32px rgba(0,0,0,0.4); }
  @media (max-width: 480px) { .pq-card { padding: 1.2rem; } .pq-options { margin-left: 0; } }
</style>
