---
import Base from '../../layouts/Base.astro';
---

<Base title="XYZ — Matematisk problemlösning (HT 2021) – HPAkuten" description="Öva på XYZ-delen från högskoleprovet HT 2021. 12 uppgifter med svarsalternativ, rätta direkt.">
  <div class="page-content">
    <div class="container" style="max-width: 700px;">

      <div class="prov-header">
        <h1>XYZ — Matematisk problemlösning</h1>
        <p class="prov-meta">Högskoleprov HT 2021 · Delprov 1 · 12 uppgifter · Rekommenderad tid: 12 minuter</p>
        <div class="prov-timer">
          <button class="btn btn-outline btn-sm" id="timer-btn">Starta timer (12:00)</button>
          <span class="timer-display" id="timer-display">⏱ <span id="timer-value">12:00</span></span>
        </div>
      </div>

      <div id="prov-app"></div>

    </div>
  </div>

  <script>
    // Helper: render fraction as stacked numerator/denominator
    const f = (top: string, bot: string) => `<span class="fr"><span class="fr-t">${top}</span><span class="fr-b">${bot}</span></span>`;
    const sr = (inner: string) => `<span class="sr"><span class="sr-sign">√</span><span class="sr-body">${inner}</span></span>`;

    const questions = [
      {
        num: 1,
        text: `<b>Vilket värde har <i>x</i></b> om ${f('1','2')} + ${f('1','3')} + <i>x</i> = 1?`,
        options: [f('1','6'), f('1','5'), f('1','4'), f('1','3')],
        correct: 0
      },
      {
        num: 2,
        text: 'En blombukett består av endast vita och röda rosor. Antalet röda rosor är tre gånger så stort som antalet vita rosor. <b>Vilket svarsalternativ kan motsvara antalet rosor i blombuketten?</b>',
        options: ['25', '26', '27', '28'],
        correct: 3
      },
      {
        num: 3,
        text: '<b>Vad är</b> 5 + 3 · 5 − 4 + 8 · 2?',
        options: ['0', '16', '32', '88'],
        correct: 2
      },
      {
        num: 4,
        text: '<b>Vilket svarsalternativ motsvarar ekvationen</b> <i>y</i> = 4<i>x</i> − 5?',
        options: [
          `<i>x</i> = <i>y</i> + ${f('5','4')}`,
          `<i>x</i> = ${f('<i>y</i>','4')} + 5`,
          `<i>x</i> = ${f('5 − <i>y</i>','4')}`,
          `<i>x</i> = ${f('<i>y</i> + 5','4')}`
        ],
        correct: 3
      },
      {
        num: 5,
        text: `Fyra linjer skär varandra i samma punkt. <b>Vad är <i>x</i>?</b>
          <div style="text-align:center;margin:1.2rem 0;">
            <img src="/prov-xyz1-5.png" alt="Fyra linjer med vinklar x, 2x, 3x, 2x" class="pq-fig" style="max-width:280px;aspect-ratio:371/396;" />
          </div>`,
        options: ['15°', '20°', '22,5°', '25°'],
        correct: 2
      },
      {
        num: 6,
        text: '<b>Vilket svarsalternativ är lika med</b> 3<i>x</i>(2 − 5<i>y</i>)?',
        options: [
          '6<i>x</i> − 5<i>y</i>',
          '(6<i>x</i> − 15)<i>y</i>',
          '−5<i>x</i>(2 + 3<i>y</i>)',
          '−(15<i>y</i> − 6)<i>x</i>'
        ],
        correct: 3
      },
      {
        num: 7,
        text: `<b>Vilket svarsalternativ är ett intervall där <i>g</i>(<i>x</i>) &gt; <i>f</i>(<i>x</i>) för alla <i>x</i> i intervallet?</b>
          <div style="text-align:center;margin:1.2rem 0;">
            <img src="/prov-xyz1-7.png" alt="Graf med f(x) och g(x)" class="pq-fig" style="max-width:300px;aspect-ratio:335/300;" />
          </div>`,
        options: [
          '<i>x</i> &gt; <i>a</i>',
          '<i>b</i> &lt; <i>x</i> &lt; <i>e</i>',
          '<i>c</i> &lt; <i>x</i> &lt; <i>e</i>',
          '<i>a</i> &lt; <i>x</i> &lt; <i>d</i>'
        ],
        correct: 3
      },
      {
        num: 8,
        text: `I en påse finns det 28 enfärgade kulor: 10 röda, 7 vita och 11 svarta. <b>Om man drar en kula slumpmässigt, hur stor är då sannolikheten att den inte är vit?</b>`,
        options: [f('1','3'), f('1','4'), f('2','3'), f('3','4')],
        correct: 3
      },
      {
        num: 9,
        text: `<b>Vilket svarsalternativ är lika med</b> ${f('0,36','3 · 0,024')} ?`,
        options: ['0,05', '0,5', '5', '50'],
        correct: 2
      },
      {
        num: 10,
        text: `Rektangeln ABCD är sammansatt av 12 lika stora kvadrater, enligt figuren. Rektangelns area är 300 cm². <b>Hur lång är sidan AB?</b>
          <div style="text-align:center;margin:1.2rem 0;">
            <img src="/prov-xyz1-10.png" alt="Rektangel ABCD med 12 kvadrater" class="pq-fig" style="max-width:200px;aspect-ratio:372/160;" />
          </div>`,
        options: [
          `${sr('300')} cm`,
          '20 cm',
          `${f('4','3')}${sr('300')} cm`,
          '25 cm'
        ],
        correct: 1
      },
      {
        num: 11,
        text: `5<i>x</i>² + 3<i>x</i> = 0<br><br><b>Vilket av svarsalternativen är ett möjligt värde på <i>x</i>?</b>`,
        options: [
          `−${f('3','5')}`,
          `${sr(f('3','5'))}`,
          `−${f('5','3')}`,
          `${sr(f('5','3'))}`
        ],
        correct: 0
      },
      {
        num: 12,
        text: `En rektangel är inritad i ett koordinatsystem som figuren visar. <b>Vilket svarsalternativ är en linje som delar rektangeln i två lika stora delar?</b>
          <div style="text-align:center;margin:1.2rem 0;">
            <img src="/prov-xyz1-12.png" alt="Rektangel i koordinatsystem med hörn vid (6,4)" class="pq-fig" style="max-width:240px;aspect-ratio:301/345;" />
          </div>`,
        options: [
          '<i>y</i> = −<i>x</i> + 6',
          '<i>y</i> = −<i>x</i> + 4',
          '<i>y</i> = <i>x</i> − 1',
          '<i>y</i> = <i>x</i> − 2'
        ],
        correct: 2
      }
    ];

    const answers: (number | null)[] = new Array(questions.length).fill(null);
    let current = 0;
    let submitted = false;

    const app = document.getElementById('prov-app')!;

    function render() {
      if (submitted) { renderResults(); return; }
      const q = questions[current];
      const labels = ['A', 'B', 'C', 'D'];
      app.innerHTML = `
        <div class="pq-progress">Uppgift ${q.num} av ${questions.length}</div>
        <div class="pq-card">
          <div class="pq-question">
            <span class="pq-num">${q.num}.</span>
            <span class="pq-text">${q.text}</span>
          </div>
          <div class="pq-options">
            ${q.options.map((opt, i) => `
              <label class="pq-opt ${answers[current] === i ? 'pq-opt--sel' : ''}">
                <input type="radio" name="q${current}" value="${i}" ${answers[current] === i ? 'checked' : ''} />
                <span class="pq-letter">${labels[i]}</span>
                <span class="pq-opt-text">${opt}</span>
              </label>
            `).join('')}
          </div>
        </div>
        <div class="pq-nav">
          <button class="btn btn-outline btn-sm" id="btn-prev" ${current === 0 ? 'disabled' : ''}>Föregående</button>
          <button class="btn btn-outline btn-sm" id="btn-overview">Översikt</button>
          ${current === questions.length - 1
            ? '<button class="btn btn-primary btn-sm" id="btn-submit">Rätta provet</button>'
            : '<button class="btn btn-primary btn-sm" id="btn-next">Nästa</button>'}
        </div>
        <div class="pq-dots">
          ${questions.map((_, i) => `<span class="pq-dot ${i === current ? 'pq-dot--cur' : ''} ${answers[i] !== null ? 'pq-dot--ans' : ''}" data-i="${i}">${i + 1}</span>`).join('')}
        </div>
      `;
      bindEvents();
    }

    function bindEvents() {
      app.querySelectorAll('input[type="radio"]').forEach(el => {
        el.addEventListener('change', (e) => { answers[current] = Number((e.target as HTMLInputElement).value); render(); });
      });
      document.getElementById('btn-prev')?.addEventListener('click', () => { current--; render(); });
      document.getElementById('btn-next')?.addEventListener('click', () => { current++; render(); });
      document.getElementById('btn-submit')?.addEventListener('click', () => { submitted = true; render(); });
      document.getElementById('btn-overview')?.addEventListener('click', renderOverview);
      app.querySelectorAll('.pq-dot').forEach(el => {
        el.addEventListener('click', () => { current = Number(el.getAttribute('data-i')); render(); });
      });
      // Fade in figures when loaded
      app.querySelectorAll('.pq-fig').forEach(img => {
        const el = img as HTMLImageElement;
        if (el.complete) { el.classList.add('loaded'); }
        else { el.addEventListener('load', () => el.classList.add('loaded')); }
      });
    }

    function renderOverview() {
      const labels = ['A', 'B', 'C', 'D'];
      const answered = answers.filter(a => a !== null).length;
      app.innerHTML = `
        <h2 style="text-align:center;margin-top:0;">Översikt</h2>
        <p style="text-align:center;color:var(--color-muted);">${answered} av ${questions.length} besvarade</p>
        <div class="pq-overview">${questions.map((q, i) => `
          <button class="pq-ov-btn ${answers[i] !== null ? 'pq-ov-btn--ans' : ''}" data-i="${i}">
            <span class="pq-ov-num">${q.num}</span>
            <span class="pq-ov-val">${answers[i] !== null ? labels[answers[i]!] : '—'}</span>
          </button>
        `).join('')}</div>
        <div class="pq-nav" style="margin-top:1.5rem;">
          <button class="btn btn-outline btn-sm" id="btn-back-first">Tillbaka till fråga 1</button>
          <button class="btn btn-primary btn-sm" id="btn-submit-overview">Rätta provet</button>
        </div>
      `;
      app.querySelectorAll('.pq-ov-btn').forEach(el => {
        el.addEventListener('click', () => { current = Number(el.getAttribute('data-i')); render(); });
      });
      document.getElementById('btn-back-first')?.addEventListener('click', () => { current = 0; render(); });
      document.getElementById('btn-submit-overview')?.addEventListener('click', () => { submitted = true; render(); });
    }

    function renderResults() {
      const labels = ['A', 'B', 'C', 'D'];
      let score = 0;
      questions.forEach((q, i) => { if (answers[i] === q.correct) score++; });
      app.innerHTML = `
        <div class="pq-result-head"><h2>Resultat</h2><div class="pq-score">${score}/${questions.length}</div><p style="color:var(--color-muted)">rätt svar</p></div>
        <div class="pq-results">${questions.map((q, i) => {
          const ok = answers[i] === q.correct;
          return `<div class="pq-res ${ok ? 'pq-res--ok' : 'pq-res--no'}">
            <span class="pq-res-icon">${ok ? '✓' : '✗'}</span>
            <span class="pq-res-num">${q.num}.</span>
            <span>Ditt svar: <b>${answers[i] !== null ? labels[answers[i]!] : '—'}</b></span>
            ${!ok ? `<span class="pq-res-right">Rätt: <b>${labels[q.correct]}</b></span>` : ''}
          </div>`;
        }).join('')}</div>
        <div class="pq-nav" style="margin-top:2rem;">
          <button class="btn btn-outline btn-sm" id="btn-retry">Gör om provet</button>
          <a href="/trana" class="btn btn-primary btn-sm">Tillbaka</a>
        </div>
      `;
      document.getElementById('btn-retry')?.addEventListener('click', () => { answers.fill(null); current = 0; submitted = false; render(); });
    }

    render();

    // Timer
    let timerRunning = false;
    let timerSeconds = 12 * 60;
    let timerInterval: number;
    const timerBtn = document.getElementById('timer-btn')!;
    const timerDisp = document.getElementById('timer-display')!;
    const timerVal = document.getElementById('timer-value')!;
    function fmt(s: number) { return `${Math.floor(s/60)}:${(s%60).toString().padStart(2,'0')}`; }
    timerBtn.addEventListener('click', () => {
      timerRunning = true;
      timerBtn.style.display = 'none';
      timerDisp.style.display = 'inline';
      timerInterval = setInterval(() => {
        timerSeconds--;
        timerVal.textContent = fmt(timerSeconds);
        if (timerSeconds <= 0) { clearInterval(timerInterval); timerVal.textContent = 'Tiden är slut!'; }
      }, 1000) as unknown as number;
    });
  </script>
</Base>

<style is:global>
  /* === Prov page === */
  .prov-header { text-align: center; margin-bottom: 2rem; }
  .prov-header h1 { font-size: 1.5rem; margin-bottom: 0.3rem; }
  .prov-meta { color: var(--color-muted); font-size: 0.9rem; margin-bottom: 1rem; }
  .prov-timer { margin-bottom: 0.5rem; }
  .timer-display { font-size: 1.3rem; font-weight: 700; color: var(--color-primary); display: none; }
  .btn-sm { padding: 0.5rem 1.2rem; font-size: 0.9rem; }

  /* Progress */
  .pq-progress { text-align: center; font-size: 0.8rem; color: var(--color-muted); margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.06em; }

  /* Question card */
  .pq-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 2rem 2rem 1.5rem;
    box-shadow: var(--shadow);
    margin-bottom: 2rem;
  }

  .pq-question {
    margin-bottom: 1.8rem;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .pq-num {
    font-weight: 700;
    margin-right: 0.5rem;
  }

  .pq-text { }

  /* Options — each on its own line like the real exam */
  .pq-options {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-left: 1.2rem;
  }

  .pq-opt {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.65rem 1rem;
    cursor: pointer;
    border-radius: var(--radius);
    transition: background 0.12s;
    border: 2px solid transparent;
  }

  .pq-opt:hover { background: #f5f7ff; }

  .pq-opt--sel {
    background: #eef2ff;
    border-color: var(--color-primary);
  }

  .pq-opt input { display: none; }

  .pq-letter {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: #f1f5f9;
    border: 1.5px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.85rem;
    flex-shrink: 0;
    transition: all 0.12s;
  }

  .pq-opt--sel .pq-letter {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
  }

  .pq-opt-text {
    font-size: 1.05rem;
    line-height: 1.5;
  }

  /* Navigation */
  .pq-nav {
    display: flex;
    justify-content: center;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  /* Dots */
  .pq-dots {
    display: flex;
    justify-content: center;
    gap: 0.35rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }

  .pq-dot {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1.5px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.12s;
    background: var(--color-surface);
    color: var(--color-text);
  }

  .pq-dot:hover { border-color: var(--color-primary); color: var(--color-primary); }
  .pq-dot--cur { border-color: var(--color-primary); color: var(--color-primary); box-shadow: 0 0 0 3px rgba(37,99,235,0.15); }
  .pq-dot--ans { background: var(--color-primary); color: #fff; border-color: var(--color-primary); }

  /* Overview */
  .pq-overview {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.7rem;
    max-width: 360px;
    margin: 1.5rem auto;
  }

  .pq-ov-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    padding: 0.7rem;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    cursor: pointer;
    transition: all 0.12s;
    font-family: var(--font-sans);
  }

  .pq-ov-btn:hover { border-color: var(--color-primary); }
  .pq-ov-btn--ans { border-color: var(--color-primary); background: #eef2ff; }
  .pq-ov-num { font-weight: 700; font-size: 0.9rem; }
  .pq-ov-val { color: var(--color-muted); font-size: 0.8rem; }

  /* Results */
  .pq-result-head { text-align: center; margin-bottom: 2rem; }
  .pq-result-head h2 { margin-top: 0; }
  .pq-score { font-size: 3rem; font-weight: 800; color: var(--color-primary); line-height: 1; }
  .pq-results { display: flex; flex-direction: column; gap: 0.4rem; }

  .pq-res {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.55rem 1rem;
    border-radius: var(--radius);
    font-size: 0.95rem;
  }

  .pq-res--ok { background: #ecfdf5; }
  .pq-res--no { background: #fef2f2; }
  .pq-res-icon { font-weight: 700; font-size: 1.1rem; }
  .pq-res--ok .pq-res-icon { color: var(--color-success); }
  .pq-res--no .pq-res-icon { color: #ef4444; }
  .pq-res-num { font-weight: 600; min-width: 1.5rem; }
  .pq-res-right { margin-left: auto; color: var(--color-success); }

  /* Fractions */
  .fr {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    vertical-align: middle;
    margin: 0 0.12em;
    line-height: 1.15;
  }

  .fr-t {
    border-bottom: 1.2px solid currentColor;
    padding: 0 0.18em 0.08em;
    text-align: center;
  }

  .fr-b {
    padding: 0.08em 0.18em 0;
    text-align: center;
  }

  /* Square root — use the actual unicode radical character properly */
  .sr {
    display: inline-flex;
    align-items: flex-end;
    vertical-align: middle;
    line-height: 1;
  }

  .sr-sign {
    font-size: 1.15em;
    line-height: 0.9;
  }

  .sr-body {
    border-top: 1.2px solid currentColor;
    padding: 0 0.12em;
    margin-left: -0.08em;
  }

  /* Figure images — reserve space and fade in */
  .pq-fig {
    width: 100%;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .pq-fig.loaded {
    opacity: 1;
  }

  @media (max-width: 480px) {
    .pq-card { padding: 1.2rem; }
    .pq-options { margin-left: 0; }
  }
</style>
