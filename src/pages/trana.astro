---
import Base from '../layouts/Base.astro';
---

<Base title="Träna på Högskoleprovet – HPAkuten" description="Öva på exempeluppgifter för alla åtta delprov på högskoleprovet. Välj delprov och träna med riktiga uppgifter.">
  <div class="page-content">
    <div class="container" style="max-width: 800px;">
      <h1>Träna på Högskoleprovet</h1>
      <p class="page-intro">Gör riktiga provuppgifter från HT 2021 — det prov där Jonas fick 160 av 160 poäng.</p>

      <a href="/prov/kvant-ht2021" class="prov-hero-link">
        <div class="prov-hero-card">
          <div class="prov-hero-badge">Rekommenderat</div>
          <h2>Kvantitativt prov — HT 2021</h2>
          <p>Alla 4 delprov ihop, precis som på riktigt.</p>
          <div class="prov-hero-stats">
            <span><strong>40</strong> uppgifter</span>
            <span><strong>55</strong> minuter</span>
            <span>XYZ + KVA + NOG + DTK</span>
          </div>
          <span class="btn btn-primary" style="margin-top:1rem;">Starta provet</span>
        </div>
      </a>

      <h2 style="margin-top: 2.5rem;">Eller gör ett delprov i taget</h2>
      <p style="color: var(--color-muted); margin-bottom: 1rem;">Kvantitativa delprov</p>

      <div class="prov-list">
        <a href="/prov/xyz-ht2021" class="prov-list-item">
          <div class="prov-list-icon">1</div>
          <div>
            <h3>XYZ — Matematisk problemlösning</h3>
            <p>12 uppgifter · 12 minuter</p>
          </div>
        </a>
        <a href="/prov/kva-ht2021" class="prov-list-item">
          <div class="prov-list-icon">2</div>
          <div>
            <h3>KVA — Kvantitativa jämförelser</h3>
            <p>10 uppgifter · 18 minuter</p>
          </div>
        </a>
        <a href="/prov/nog-ht2021" class="prov-list-item">
          <div class="prov-list-icon">3</div>
          <div>
            <h3>NOG — Kvantitativa resonemang</h3>
            <p>6 uppgifter · 12 minuter</p>
          </div>
        </a>
        <a href="/prov/dtk-ht2021" class="prov-list-item">
          <div class="prov-list-icon">4</div>
          <div>
            <h3>DTK — Diagram, tabeller och kartor</h3>
            <p>12 uppgifter · 18 minuter</p>
          </div>
        </a>
      </div>

      <h2 style="margin-top: 3rem;">Verbala delprov</h2>
      <p style="color: var(--color-muted); margin-bottom: 1rem;">Kommer snart!</p>

      <div class="prov-list">
        <a href="/prov/ord-ht2021" class="prov-list-item">
          <div class="prov-list-icon">5</div>
          <div>
            <h3>ORD — Ordförståelse</h3>
            <p>10 uppgifter · 3 minuter</p>
          </div>
        </a>
        <a href="/prov/las-ht2021" class="prov-list-item">
          <div class="prov-list-icon">6</div>
          <div>
            <h3>LÄS — Läsförståelse</h3>
            <p>10 uppgifter · 22 minuter</p>
          </div>
        </a>
        <a href="/prov/mek-ht2021" class="prov-list-item">
          <div class="prov-list-icon">7</div>
          <div>
            <h3>MEK — Meningskomplettering</h3>
            <p>10 uppgifter · 8 minuter</p>
          </div>
        </a>
        <div class="prov-list-item prov-list-item--disabled">
          <div class="prov-list-icon">8</div>
          <div>
            <h3>ELF — Engelsk läsförståelse</h3>
            <p>Ej tillgängligt (copyright)</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</Base>

<style>
  .prov-hero-link { text-decoration: none; color: inherit; display: block; }
  .prov-hero-link:hover { text-decoration: none; }

  .prov-hero-card {
    text-align: center;
    padding: 2rem;
    background: linear-gradient(135deg, #eff3ff 0%, #e0e7ff 100%);
    border: 2px solid var(--color-primary);
    border-radius: var(--radius);
    margin: 1.5rem 0;
    position: relative;
    transition: box-shadow 0.15s, transform 0.15s;
  }

  .prov-hero-link:hover .prov-hero-card {
    box-shadow: 0 8px 24px rgba(37,99,235,0.15);
    transform: translateY(-2px);
  }

  .prov-hero-badge {
    position: absolute;
    top: -0.7rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-primary);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.2rem 0.8rem;
    border-radius: 50px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .prov-hero-card h2 { margin: 0.5rem 0 0.3rem; font-size: 1.3rem; }
  .prov-hero-card > p { color: var(--color-muted); margin-bottom: 1rem; }

  .prov-hero-stats {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .prov-list {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .prov-list-item {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding: 1.2rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--color-text);
    transition: all 0.15s;
    box-shadow: var(--shadow);
  }

  a.prov-list-item:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
    text-decoration: none;
  }

  .prov-list-item--disabled {
    opacity: 0.5;
    cursor: default;
  }

  .prov-list-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .prov-list-item--disabled .prov-list-icon {
    background: var(--color-muted);
  }

  .prov-list-item h3 {
    margin: 0 0 0.2rem;
    font-size: 1.05rem;
  }

  .prov-list-item p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.9rem;
  }
</style>
