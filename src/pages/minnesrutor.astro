---
import Base from '../layouts/Base.astro';
---

<Base title="Minnesrutor – HPAkuten" description="Träna ditt visuella minne genom att memorera färgmönster i ett 6×6-rutnät. Perfekt minnesövning för högskoleprovet.">
  <div class="mg-app" id="app">
    <div class="mg-start" id="start-screen">
      <h1>Minnesrutor</h1>
      <p>Memorera färgmönstret på 60 sekunder och fyll sedan i rutorna ur minnet.</p>

      <div class="mg-mode-select">
        <button class="mg-mode-btn mg-mode-btn--active" data-colors="2">
          <span class="mg-mode-preview">
            <span class="mg-dot" style="background:#d4a017;"></span>
            <span class="mg-dot" style="background:#a832a8;"></span>
          </span>
          2 färger
        </button>
        <button class="mg-mode-btn" data-colors="3">
          <span class="mg-mode-preview">
            <span class="mg-dot" style="background:#d4a017;"></span>
            <span class="mg-dot" style="background:#a832a8;"></span>
            <span class="mg-dot" style="background:#2e7db5;"></span>
          </span>
          3 färger
        </button>
      </div>

      <button class="mg-btn mg-btn--start" id="btn-start">Starta</button>
    </div>

    <div class="mg-game" id="game-screen" style="display:none;">
      <div class="mg-topbar">
        <div class="mg-phase-label" id="phase-label">Memorera</div>
        <div class="mg-timer" id="timer">1:00</div>
      </div>

      <div class="mg-grid" id="grid"></div>

      <div class="mg-palette" id="palette" style="display:none;">
        <span class="mg-palette-label">Välj färg:</span>
        <div class="mg-palette-colors" id="palette-colors"></div>
        <button class="mg-btn mg-btn--erase" id="btn-erase" title="Sudda">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 20H7L3 16c-.8-.8-.8-2 0-2.8L14.2 2l6.4 6.4L11.4 17.6 7 20"/><path d="M18 12L12 6"/></svg>
        </button>
      </div>

      <div class="mg-counts" id="counts"></div>

      <div class="mg-actions" id="actions" style="display:none;">
        <button class="mg-btn mg-btn--submit" id="btn-submit">Klar!</button>
      </div>
    </div>

    <div class="mg-result" id="result-screen" style="display:none;">
      <h2 id="result-title"></h2>
      <p class="mg-score" id="result-score"></p>

      <div class="mg-result-grids">
        <div>
          <div class="mg-result-label">Ditt svar</div>
          <div class="mg-grid mg-grid--small" id="grid-answer"></div>
        </div>
        <div>
          <div class="mg-result-label">Facit</div>
          <div class="mg-grid mg-grid--small" id="grid-correct"></div>
        </div>
      </div>

      <button class="mg-btn mg-btn--start" id="btn-again">Kör igen</button>
    </div>
  </div>

  <link rel="manifest" href="/minnesrutor-manifest.json" />
  <meta name="theme-color" content="#0f4c5c" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

  <script>
    const COLORS_2 = ['#d4a017', '#a832a8'];
    const COLORS_3 = ['#d4a017', '#a832a8', '#2e7db5'];
    const BG = '#0f6068';
    const SIZE = 6;
    const TOTAL = SIZE * SIZE;
    const MEMO_TIME = 60;

    let colorMode = 2;
    let solution = [];
    let userGrid = [];
    let selectedColor = '';
    let timerInterval = null;

    const $ = (id) => document.getElementById(id);

    // Mode select
    document.querySelectorAll('.mg-mode-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.mg-mode-btn').forEach(b => b.classList.remove('mg-mode-btn--active'));
        btn.classList.add('mg-mode-btn--active');
        colorMode = parseInt(btn.dataset.colors);
      });
    });

    $('btn-start').addEventListener('click', startGame);
    $('btn-submit').addEventListener('click', showResult);
    $('btn-again').addEventListener('click', () => {
      $('result-screen').style.display = 'none';
      $('start-screen').style.display = '';
    });

    $('btn-erase').addEventListener('click', () => {
      selectedColor = BG;
      updatePaletteSelection();
    });

    function generateSolution() {
      const colors = colorMode === 2 ? COLORS_2 : COLORS_3;
      const perColor = colorMode === 2 ? 12 : 9;
      const arr = [];

      for (const c of colors) {
        for (let i = 0; i < perColor; i++) arr.push(c);
      }
      while (arr.length < TOTAL) arr.push(BG);

      // Fisher-Yates shuffle
      for (let i = arr.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [arr[i], arr[j]] = [arr[j], arr[i]];
      }
      return arr;
    }

    function renderGrid(container, cells, interactive) {
      container.innerHTML = '';
      cells.forEach((color, i) => {
        const cell = document.createElement('div');
        cell.className = 'mg-cell';
        cell.style.backgroundColor = color;
        cell.dataset.index = i;
        if (interactive) {
          cell.addEventListener('click', () => onCellClick(i));
          cell.addEventListener('touchstart', (e) => {
            e.preventDefault();
            onCellClick(i);
          }, { passive: false });
        }
        container.appendChild(cell);
      });
    }

    function onCellClick(i) {
      if (!selectedColor) return;
      userGrid[i] = selectedColor;
      const cell = $('grid').children[i];
      cell.style.backgroundColor = selectedColor;
      cell.classList.add('mg-cell--placed');
      setTimeout(() => cell.classList.remove('mg-cell--placed'), 150);
      updateCounts();
    }

    function updateCounts() {
      const colors = colorMode === 2 ? COLORS_2 : COLORS_3;
      const target = colorMode === 2 ? 12 : 9;
      const counts = {};
      colors.forEach(c => counts[c] = 0);
      userGrid.forEach(c => { if (counts[c] !== undefined) counts[c]++; });

      const labels = { '#d4a017': 'Gul', '#a832a8': 'Lila', '#2e7db5': 'Blå' };
      $('counts').innerHTML = colors.map(c => {
        const done = counts[c] === target;
        return `<span class="mg-count${done ? ' mg-count--done' : ''}">
          <span class="mg-count-dot" style="background:${c}"></span>
          ${counts[c]}/${target}
        </span>`;
      }).join('');
    }

    function buildPalette() {
      const container = $('palette-colors');
      container.innerHTML = '';
      const colors = colorMode === 2 ? COLORS_2 : COLORS_3;
      selectedColor = colors[0];

      colors.forEach(c => {
        const swatch = document.createElement('button');
        swatch.className = 'mg-swatch';
        swatch.style.backgroundColor = c;
        swatch.dataset.color = c;
        swatch.addEventListener('click', () => {
          selectedColor = c;
          updatePaletteSelection();
        });
        container.appendChild(swatch);
      });

      updatePaletteSelection();
    }

    function updatePaletteSelection() {
      document.querySelectorAll('.mg-swatch').forEach(s => {
        s.classList.toggle('mg-swatch--active', s.dataset.color === selectedColor);
      });
      $('btn-erase').classList.toggle('mg-btn--erase-active', selectedColor === BG);
    }

    function startGame() {
      solution = generateSolution();
      userGrid = new Array(TOTAL).fill(BG);

      $('start-screen').style.display = 'none';
      $('result-screen').style.display = 'none';
      $('game-screen').style.display = '';
      $('palette').style.display = 'none';
      $('actions').style.display = 'none';
      $('phase-label').textContent = 'Memorera';
      $('phase-label').className = 'mg-phase-label mg-phase-label--memo';

      renderGrid($('grid'), solution, false);
      $('grid').classList.remove('mg-grid--small');

      startTimer(MEMO_TIME, () => {
        startRecallPhase();
      });
    }

    function startRecallPhase() {
      $('phase-label').textContent = 'Fyll i';
      $('phase-label').className = 'mg-phase-label mg-phase-label--recall';
      $('palette').style.display = '';
      $('actions').style.display = '';

      buildPalette();
      renderGrid($('grid'), userGrid, true);
      updateCounts();
    }

    function startTimer(seconds, onDone) {
      let remaining = seconds;
      updateTimerDisplay(remaining);
      $('timer').classList.remove('mg-timer--warn');

      timerInterval = setInterval(() => {
        remaining--;
        updateTimerDisplay(remaining);
        if (remaining <= 10) $('timer').classList.add('mg-timer--warn');
        if (remaining <= 0) {
          clearInterval(timerInterval);
          onDone();
        }
      }, 1000);
    }

    function updateTimerDisplay(s) {
      const m = Math.floor(s / 60);
      const sec = s % 60;
      $('timer').textContent = `${m}:${sec.toString().padStart(2, '0')}`;
    }

    function showResult() {
      clearInterval(timerInterval);
      $('game-screen').style.display = 'none';
      $('result-screen').style.display = '';

      let correct = 0;
      for (let i = 0; i < TOTAL; i++) {
        if (userGrid[i] === solution[i]) correct++;
      }

      const pct = Math.round((correct / TOTAL) * 100);
      $('result-title').textContent =
        pct === 100 ? 'Perfekt!' :
        pct >= 80 ? 'Bra jobbat!' :
        pct >= 50 ? 'Helt okej!' : 'Fortsätt träna!';
      $('result-score').textContent = `${correct} av ${TOTAL} rätt (${pct}%)`;

      renderGrid($('grid-answer'), userGrid, false);
      renderGrid($('grid-correct'), solution, false);

      // Mark wrong cells on the answer grid
      for (let i = 0; i < TOTAL; i++) {
        if (userGrid[i] !== solution[i]) {
          $('grid-answer').children[i].classList.add('mg-cell--wrong');
        }
      }
    }

    // Register service worker for offline
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/minnesrutor-sw.js').catch(() => {});
    }
  </script>
</Base>

<style>
  .mg-app {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1.5rem 1rem;
  }

  /* Start screen */
  .mg-start {
    text-align: center;
    max-width: 420px;
  }
  .mg-start h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }
  .mg-start p {
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .mg-mode-select {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    margin-bottom: 1.5rem;
  }
  .mg-mode-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 1.5rem;
    border: 2px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 600;
    font-family: var(--font-sans);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .mg-mode-btn:hover {
    border-color: var(--color-primary);
  }
  .mg-mode-btn--active {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
  }
  .mg-mode-preview {
    display: flex;
    gap: 6px;
  }
  .mg-dot {
    width: 24px;
    height: 24px;
    border-radius: 4px;
  }

  /* Buttons */
  .mg-btn {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.1rem;
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
    transition: transform 0.1s, background 0.15s;
  }
  .mg-btn:active {
    transform: scale(0.97);
  }
  .mg-btn--start {
    background: var(--color-primary);
    color: #fff;
    padding: 0.85rem 2.5rem;
    font-size: 1.15rem;
  }
  .mg-btn--start:hover {
    background: var(--color-primary-dark);
  }
  .mg-btn--submit {
    background: var(--color-success);
    color: #fff;
    padding: 0.75rem 2rem;
  }
  .mg-btn--submit:hover {
    background: #059669;
  }

  /* Top bar */
  .mg-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 400px;
    margin-bottom: 0.75rem;
  }
  .mg-phase-label {
    font-weight: 700;
    font-size: 1.1rem;
    padding: 0.3rem 0.8rem;
    border-radius: 6px;
  }
  .mg-phase-label--memo {
    background: #fef3c7;
    color: #92400e;
  }
  .mg-phase-label--recall {
    background: #dbeafe;
    color: #1e40af;
  }
  .mg-timer {
    font-size: 1.5rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    color: var(--color-text);
  }
  .mg-timer--warn {
    color: #dc2626;
    animation: mg-pulse 1s infinite;
  }
  @keyframes mg-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  /* Grid */
  .mg-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 3px;
    width: 100%;
    max-width: 400px;
    aspect-ratio: 1;
    background: #0a3d44;
    padding: 3px;
    border-radius: 8px;
  }
  .mg-grid--small {
    max-width: 260px;
  }

  .mg-cell {
    border-radius: 3px;
    aspect-ratio: 1;
    transition: background-color 0.12s, transform 0.12s;
    cursor: default;
    touch-action: manipulation;
    position: relative;
  }
  .mg-cell--placed {
    transform: scale(0.9);
  }
  .mg-cell--wrong {
    box-shadow: inset 0 0 0 3px #ef4444;
    position: relative;
  }
  .mg-cell--wrong::after {
    content: '✕';
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ef4444;
    font-size: 1.2em;
    font-weight: 700;
  }

  /* Palette */
  .mg-palette {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .mg-palette-label {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-muted);
  }
  .mg-palette-colors {
    display: flex;
    gap: 0.5rem;
  }
  .mg-swatch {
    width: 44px;
    height: 44px;
    border-radius: 8px;
    border: 3px solid transparent;
    cursor: pointer;
    transition: border-color 0.12s, transform 0.12s;
  }
  .mg-swatch:hover {
    transform: scale(1.08);
  }
  .mg-swatch--active {
    border-color: var(--color-text);
    box-shadow: 0 0 0 2px #fff, 0 0 0 4px var(--color-text);
  }
  .mg-btn--erase {
    width: 44px;
    height: 44px;
    border-radius: 8px;
    background: var(--color-surface);
    border: 3px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    font-size: 1rem;
    color: var(--color-muted);
  }
  .mg-btn--erase:hover {
    border-color: var(--color-muted);
    color: var(--color-text);
  }
  .mg-btn--erase-active {
    border-color: var(--color-text);
    box-shadow: 0 0 0 2px #fff, 0 0 0 4px var(--color-text);
    color: var(--color-text);
  }

  /* Counts */
  .mg-counts {
    display: flex;
    gap: 1rem;
    margin-top: 0.75rem;
    justify-content: center;
  }
  .mg-count {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-weight: 600;
    font-size: 0.95rem;
    font-variant-numeric: tabular-nums;
    color: var(--color-muted);
  }
  .mg-count--done {
    color: var(--color-success);
  }
  .mg-count-dot {
    width: 14px;
    height: 14px;
    border-radius: 3px;
    flex-shrink: 0;
  }

  /* Actions */
  .mg-actions {
    margin-top: 1rem;
  }

  /* Result */
  .mg-result {
    text-align: center;
    max-width: 600px;
    width: 100%;
  }
  .mg-result h2 {
    font-size: 1.8rem;
    margin-bottom: 0.25rem;
  }
  .mg-score {
    font-size: 1.15rem;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }
  .mg-result-grids {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .mg-result-label {
    font-weight: 600;
    margin-bottom: 0.4rem;
    font-size: 0.95rem;
  }

  /* Game screen centering */
  .mg-game {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  /* Mobile tap targets */
  @media (pointer: coarse) {
    .mg-cell {
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
    }
  }

  @media (max-width: 480px) {
    .mg-grid {
      max-width: 92vw;
    }
    .mg-grid--small {
      max-width: 44vw;
    }
    .mg-start h1 {
      font-size: 1.5rem;
    }
    .mg-swatch {
      width: 40px;
      height: 40px;
    }
  }
</style>
