---
import Base from '../layouts/Base.astro';
---

<Base title="Träna provpass (55 min) – HPMästaren">
  <div class="page-content hp-practice-page">
    <div class="container container--wide">
      <h1>Träna provpass som på Högskoleprovet</h1>
      <p class="page-intro">
        Välj ett helt pass (<strong>Kvantitativ</strong> eller <strong>Verbal</strong>), sätt igång timern
        på 55 minuter och svara med radioknappar. När tiden är slut (eller när du lämnar in)
        får du facit och resultat direkt.
      </p>

      <div class="tip-box">
        <strong>Tips:</strong>
        För bästa träning — skriv under tidspress utan hjälpmedel och låt timern gå hela vägen.
      </div>

      <section id="setup-screen" class="card hp-setup">
        <h2>Välj del att träna</h2>
        <div class="mode-grid">
          <button id="start-quant" class="mode-card" type="button">
            <span class="mode-icon">📊</span>
            <span class="mode-title">Kvantitativa</span>
            <span class="mode-meta">XYZ, KVA, NOG, DTK • 55 min</span>
          </button>

          <button id="start-verbal" class="mode-card" type="button">
            <span class="mode-icon">📘</span>
            <span class="mode-title">Verbala</span>
            <span class="mode-meta">ORD, LÄS, MEK, ELF • 55 min</span>
          </button>
        </div>
      </section>

      <section id="exam-screen" class="card hp-exam" hidden>
        <header class="exam-header">
          <div>
            <p class="exam-label" id="exam-label"></p>
            <h2>Provpass</h2>
          </div>
          <div class="timer-wrap" aria-live="polite">
            <span class="timer-label">Tid kvar</span>
            <span class="timer" id="timer">55:00</span>
          </div>
        </header>

        <form id="exam-form">
          <div id="question-list" class="question-list"></div>

          <div class="exam-actions">
            <button type="submit" class="btn btn-primary">Lämna in och rätta</button>
            <button id="back-to-select" type="button" class="btn btn-outline">Avbryt</button>
          </div>
        </form>
      </section>

      <section id="result-screen" class="card hp-results" hidden>
        <h2>Resultat</h2>
        <p id="score-line" class="score-line"></p>
        <p id="time-line"></p>

        <div id="review" class="review"></div>

        <div class="results-actions">
          <button id="retry-btn" type="button" class="btn btn-primary">Gör om samma pass</button>
          <button id="new-pass-btn" type="button" class="btn btn-outline">Välj annan del</button>
        </div>
      </section>
    </div>
  </div>
</Base>

<style>
  .hp-practice-page .container {
    max-width: 980px;
  }

  .hp-setup,
  .hp-exam,
  .hp-results {
    margin-top: 1rem;
    border: 1px solid var(--color-border);
  }

  .mode-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    margin-top: 1rem;
  }

  .mode-card {
    border: 2px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1rem;
    text-align: left;
    background: #fff;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.15s ease;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .mode-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-1px);
  }

  .mode-icon {
    font-size: 1.35rem;
  }

  .mode-title {
    font-weight: 700;
    font-size: 1.1rem;
  }

  .mode-meta {
    color: var(--color-muted);
    font-size: 0.92rem;
  }

  .exam-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1rem;
    margin-bottom: 1rem;
    align-items: center;
  }

  .exam-label {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .timer-wrap {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .timer-label {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .timer {
    font-size: 2rem;
    line-height: 1;
    font-weight: 800;
    color: var(--color-primary);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  .timer.low {
    color: #dc2626;
  }

  .question-list {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .question-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1rem;
  }

  .question-card h3 {
    margin-top: 0;
    font-size: 1rem;
  }

  .subtest-tag {
    display: inline-block;
    font-size: 0.74rem;
    font-weight: 700;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.15rem 0.55rem;
    margin-bottom: 0.5rem;
    color: #334155;
    background: #f8fafc;
  }

  .question-reading {
    margin: 0.7rem 0;
    padding: 0.7rem;
    border-radius: 0.45rem;
    border: 1px solid #dbe5ef;
    background: #f8fbff;
    font-size: 0.95rem;
  }

  .options {
    margin-top: 0.7rem;
    display: grid;
    gap: 0.45rem;
  }

  .option-label {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    border: 1px solid var(--color-border);
    border-radius: 0.45rem;
    padding: 0.55rem 0.7rem;
  }

  .option-label input {
    margin-top: 0.2rem;
  }

  .exam-actions,
  .results-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.2rem;
    flex-wrap: wrap;
  }

  .score-line {
    font-size: 1.25rem;
    font-weight: 700;
  }

  .review {
    margin-top: 1rem;
    display: grid;
    gap: 0.7rem;
  }

  .review-item {
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 0.7rem;
  }

  .review-item.correct {
    border-color: #16a34a;
    background: #f0fdf4;
  }

  .review-item.incorrect {
    border-color: #ef4444;
    background: #fef2f2;
  }
</style>

<script>
  type Mode = 'quant' | 'verbal';

  interface Question {
    subtest: string;
    text: string;
    reading?: string;
    options: string[];
    correct: number;
  }

  const DATA: Record<Mode, { label: string; questions: Question[] }> = {
    quant: {
      label: 'Kvantitativa delar (inspirerat av Vår 2021)',
      questions: [
        { subtest: 'XYZ', text: 'Vad är 18% av 250?', options: ['35', '40', '45', '50'], correct: 2 },
        { subtest: 'KVA', text: 'A: 3/4 av 120. B: 70. Vilket är störst?', options: ['A är större', 'B är större', 'A och B är lika stora', 'Kan inte avgöras'], correct: 0 },
        { subtest: 'NOG', text: 'x är ett heltal. Räcker följande för att bestämma x? (1) x är jämnt. (2) x > 10', options: ['(1) ensamt räcker', '(2) ensamt räcker', 'Båda tillsammans räcker', 'Inte ens tillsammans'], correct: 3 },
        { subtest: 'DTK', text: 'I ett diagram visas att försäljningen var 120 enheter i januari och 150 i februari. Hur många procent ökade försäljningen?', options: ['20%', '25%', '30%', '35%'], correct: 1 },
        { subtest: 'XYZ', text: 'Lös ekvationen: 2x + 7 = 19', options: ['4', '5', '6', '7'], correct: 2 },
        { subtest: 'KVA', text: 'A: √81. B: 3². Vilket gäller?', options: ['A är större', 'B är större', 'A och B är lika stora', 'Kan inte avgöras'], correct: 2 },
        { subtest: 'NOG', text: 'Är n > 0? (1) n² = 9 (2) n är positivt', options: ['(1) ensamt räcker', '(2) ensamt räcker', 'Båda tillsammans räcker', 'Inte ens tillsammans'], correct: 1 },
        { subtest: 'DTK', text: 'Ett cirkeldiagram visar 30% för kategori A av totalt 240 svar. Hur många svar tillhör kategori A?', options: ['60', '72', '84', '96'], correct: 1 }
      ]
    },
    verbal: {
      label: 'Verbala delar (inspirerat av Vår 2021)',
      questions: [
        { subtest: 'ORD', text: 'Vad betyder ordet "koncis"?', options: ['Utförlig', 'Kortfattad', 'Svårbegriplig', 'Poetisk'], correct: 1 },
        {
          subtest: 'LÄS',
          reading: 'Många elever tror att längre studietid automatiskt ger bättre resultat. Forskning pekar dock på att kvaliteten i repetitionen är viktigare än den totala tiden.',
          text: 'Vilken slutsats stöds bäst av texten?',
          options: ['Studietid saknar betydelse', 'Kvaliteten i repetition är central', 'Alla elever bör studera lika länge', 'Korta pass är alltid bäst'],
          correct: 1
        },
        { subtest: 'MEK', text: 'Hon var så ______ i sin argumentation att motståndarna snabbt gav med sig.', options: ['trevande', 'stringent', 'osäker', 'vag'], correct: 1 },
        {
          subtest: 'ELF',
          reading: 'Remote work can improve flexibility, but some employees report that boundaries between work and leisure become blurred.',
          text: 'What challenge of remote work is mentioned?',
          options: ['Higher commute costs', 'Blurred boundaries between work and free time', 'Lack of internet access', 'Lower salaries'],
          correct: 1
        },
        { subtest: 'ORD', text: 'Vad betyder "implicit"?', options: ['Tydligt uttryckt', 'Underförstådd', 'Motsägelsefull', 'Tillfällig'], correct: 1 },
        {
          subtest: 'LÄS',
          reading: 'Artikeln menar att lokal kollektivtrafik är avgörande för att minska utsläpp i städer, men att investeringar måste kombineras med rimliga biljettpriser.',
          text: 'Vad krävs enligt texten för att nå effekt?',
          options: ['Endast fler bussar', 'Bara nya spår', 'Investeringar + rimliga priser', 'Gratis bilparkering'],
          correct: 2
        },
        { subtest: 'MEK', text: 'Rapporten var så ______ att den blev svår att följa.', options: ['pedagogisk', 'överskådlig', 'fragmentarisk', 'stringent'], correct: 2 },
        {
          subtest: 'ELF',
          reading: 'The article argues that critical thinking is not a fixed talent but a skill developed through practice and feedback.',
          text: 'What is the article’s main point?',
          options: ['Critical thinking is innate', 'Feedback is irrelevant', 'Critical thinking can be trained', 'Only experts can think critically'],
          correct: 2
        }
      ]
    }
  };

  const DURATION_SECONDS = 55 * 60;

  const setupScreen = document.getElementById('setup-screen') as HTMLElement;
  const examScreen = document.getElementById('exam-screen') as HTMLElement;
  const resultScreen = document.getElementById('result-screen') as HTMLElement;

  const examForm = document.getElementById('exam-form') as HTMLFormElement;
  const questionList = document.getElementById('question-list') as HTMLElement;
  const examLabel = document.getElementById('exam-label') as HTMLElement;

  const timerEl = document.getElementById('timer') as HTMLElement;
  const scoreLine = document.getElementById('score-line') as HTMLElement;
  const timeLine = document.getElementById('time-line') as HTMLElement;
  const reviewEl = document.getElementById('review') as HTMLElement;

  const startQuantBtn = document.getElementById('start-quant') as HTMLButtonElement;
  const startVerbalBtn = document.getElementById('start-verbal') as HTMLButtonElement;
  const backToSelectBtn = document.getElementById('back-to-select') as HTMLButtonElement;
  const retryBtn = document.getElementById('retry-btn') as HTMLButtonElement;
  const newPassBtn = document.getElementById('new-pass-btn') as HTMLButtonElement;

  let currentMode: Mode | null = null;
  let timeLeft = DURATION_SECONDS;
  let intervalId: number | null = null;

  function formatTime(seconds: number): string {
    const mm = Math.floor(seconds / 60).toString().padStart(2, '0');
    const ss = (seconds % 60).toString().padStart(2, '0');
    return `${mm}:${ss}`;
  }

  function updateTimerUI() {
    timerEl.textContent = formatTime(timeLeft);
    timerEl.classList.toggle('low', timeLeft <= 5 * 60);
  }

  function stopTimer() {
    if (intervalId !== null) {
      window.clearInterval(intervalId);
      intervalId = null;
    }
  }

  function startTimer() {
    stopTimer();
    timeLeft = DURATION_SECONDS;
    updateTimerUI();

    intervalId = window.setInterval(() => {
      timeLeft -= 1;
      updateTimerUI();

      if (timeLeft <= 0) {
        stopTimer();
        submitExam(true);
      }
    }, 1000);
  }

  function renderQuestions(mode: Mode) {
    const { questions } = DATA[mode];
    questionList.innerHTML = '';

    questions.forEach((q, i) => {
      const wrapper = document.createElement('article');
      wrapper.className = 'question-card';

      const readingHtml = q.reading ? `<p class="question-reading">${q.reading}</p>` : '';
      const optionsHtml = q.options
        .map(
          (option, optionIdx) => `
            <label class="option-label">
              <input type="radio" name="q-${i}" value="${optionIdx}" />
              <span>${String.fromCharCode(65 + optionIdx)}. ${option}</span>
            </label>
          `
        )
        .join('');

      wrapper.innerHTML = `
        <span class="subtest-tag">${q.subtest}</span>
        <h3>${i + 1}. ${q.text}</h3>
        ${readingHtml}
        <div class="options">${optionsHtml}</div>
      `;

      questionList.appendChild(wrapper);
    });
  }

  function showScreen(screen: 'setup' | 'exam' | 'result') {
    setupScreen.hidden = screen !== 'setup';
    examScreen.hidden = screen !== 'exam';
    resultScreen.hidden = screen !== 'result';
  }

  function startExam(mode: Mode) {
    currentMode = mode;
    examLabel.textContent = DATA[mode].label;
    renderQuestions(mode);
    showScreen('exam');
    startTimer();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function submitExam(autoSubmitted = false) {
    if (!currentMode) return;

    stopTimer();

    const { questions } = DATA[currentMode];
    let correctCount = 0;
    let answeredCount = 0;
    const usedSeconds = DURATION_SECONDS - timeLeft;

    reviewEl.innerHTML = '';

    questions.forEach((q, i) => {
      const checked = examForm.querySelector(`input[name="q-${i}"]:checked`) as HTMLInputElement | null;
      const answer = checked ? Number(checked.value) : null;

      if (answer !== null) answeredCount += 1;
      const isCorrect = answer === q.correct;
      if (isCorrect) correctCount += 1;

      const row = document.createElement('div');
      row.className = `review-item ${isCorrect ? 'correct' : 'incorrect'}`;
      row.innerHTML = `
        <strong>Fråga ${i + 1} (${q.subtest})</strong><br/>
        Ditt svar: ${answer === null ? 'Inget svar' : String.fromCharCode(65 + answer)}
        &nbsp;•&nbsp; Rätt svar: ${String.fromCharCode(65 + q.correct)}
      `;
      reviewEl.appendChild(row);
    });

    scoreLine.textContent = `Du fick ${correctCount} av ${questions.length} rätt (${Math.round((correctCount / questions.length) * 100)}%)`;
    const minuteInfo = `${Math.floor(usedSeconds / 60)} min ${usedSeconds % 60} sek`;
    timeLine.textContent = autoSubmitted
      ? `Tiden tog slut efter ${minuteInfo}. Du besvarade ${answeredCount}/${questions.length} frågor.`
      : `Inlämnat efter ${minuteInfo}. Du besvarade ${answeredCount}/${questions.length} frågor.`;

    showScreen('result');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  examForm.addEventListener('submit', (event) => {
    event.preventDefault();
    submitExam(false);
  });

  startQuantBtn.addEventListener('click', () => startExam('quant'));
  startVerbalBtn.addEventListener('click', () => startExam('verbal'));

  backToSelectBtn.addEventListener('click', () => {
    stopTimer();
    currentMode = null;
    showScreen('setup');
  });

  retryBtn.addEventListener('click', () => {
    if (currentMode) startExam(currentMode);
  });

  newPassBtn.addEventListener('click', () => {
    currentMode = null;
    showScreen('setup');
  });
</script>
