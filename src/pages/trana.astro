---
import Base from '../layouts/Base.astro';
---

<Base title="Träna på Högskoleprovet – HPMästaren">
  <div class="page-content">
    <div class="container">
      <h1>Träna på Högskoleprovet</h1>
      <p class="page-intro">Öva på exempeluppgifter för varje delprov. Välj ett delprov och kör!</p>

      <div class="tip-box">
        <strong>Kom ihåg</strong>
        Det viktigaste är att öva på <em>riktiga</em> gamla prov under tidspress. De här övningsuppgifterna
        hjälper dig bekanta dig med formatet och testa dina kunskaper, men ersätter inte fullängdsprov.
        Ladda ner gamla prov gratis på <strong>studera.nu</strong>.
      </div>

      <!-- Subtest selector -->
      <div class="trana-selector" id="trana-selector">
        <h2>Välj delprov</h2>
        <div class="card-grid">
          <button class="card trana-card" data-section="ord">
            <span class="card-icon">📖</span>
            <h3>ORD</h3>
            <p>Ordförståelse</p>
          </button>
          <button class="card trana-card" data-section="las">
            <span class="card-icon">📄</span>
            <h3>LÄS</h3>
            <p>Läsförståelse</p>
          </button>
          <button class="card trana-card" data-section="mek">
            <span class="card-icon">✏️</span>
            <h3>MEK</h3>
            <p>Meningskomplettering</p>
          </button>
          <button class="card trana-card" data-section="elf">
            <span class="card-icon">🇬🇧</span>
            <h3>ELF</h3>
            <p>Engelsk läsförståelse</p>
          </button>
          <button class="card trana-card" data-section="xyz">
            <span class="card-icon">🔢</span>
            <h3>XYZ</h3>
            <p>Matematik</p>
          </button>
          <button class="card trana-card" data-section="kva">
            <span class="card-icon">⚖️</span>
            <h3>KVA</h3>
            <p>Kvantitativa jämförelser</p>
          </button>
          <button class="card trana-card" data-section="nog">
            <span class="card-icon">🧩</span>
            <h3>NOG</h3>
            <p>Kvantitativa resonemang</p>
          </button>
          <button class="card trana-card" data-section="dtk">
            <span class="card-icon">📊</span>
            <h3>DTK</h3>
            <p>Diagram &amp; tabeller</p>
          </button>
        </div>
      </div>

      <!-- Quiz area -->
      <div id="quiz-area" style="display: none;">
        <div class="quiz-header">
          <button class="btn btn-outline btn-sm" id="back-btn">← Tillbaka</button>
          <h2 id="quiz-title"></h2>
          <div class="quiz-progress">
            <span id="quiz-progress-text"></span>
            <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
          </div>
        </div>

        <div id="quiz-question" class="quiz-question"></div>

        <div id="quiz-options" class="quiz-options"></div>

        <div id="quiz-feedback" class="quiz-feedback" style="display: none;"></div>

        <div class="quiz-actions">
          <button class="btn btn-primary" id="next-btn" style="display: none;">Nästa fråga →</button>
        </div>
      </div>

      <!-- Results area -->
      <div id="results-area" style="display: none;">
        <div class="results-card">
          <h2>Resultat</h2>
          <div class="results-score" id="results-score"></div>
          <div id="results-breakdown"></div>
          <div class="results-actions">
            <button class="btn btn-primary" id="retry-btn">Försök igen</button>
            <button class="btn btn-outline" id="other-btn">Välj annat delprov</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</Base>

<style>
  .trana-card {
    cursor: pointer;
    border: none;
    text-align: left;
    font-family: var(--font-sans);
    background: var(--color-surface);
  }

  .trana-card h3 {
    margin-top: 0.3rem;
    font-size: 1.3rem;
  }

  .trana-card p {
    font-size: 0.9rem;
  }

  /* Quiz styles */
  .quiz-header {
    margin-bottom: 1.5rem;
  }

  .quiz-header h2 {
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }

  .btn-sm {
    padding: 0.4rem 1rem;
    font-size: 0.9rem;
  }

  .quiz-progress {
    color: var(--color-muted);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .progress-bar {
    height: 6px;
    background: var(--color-border);
    border-radius: 3px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--color-primary);
    border-radius: 3px;
    transition: width 0.3s;
  }

  .quiz-question {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .quiz-question .reading-text {
    background: #f8fafc;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.2rem;
    margin-bottom: 1.2rem;
    font-size: 1rem;
    line-height: 1.7;
  }

  .quiz-options {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 1.5rem;
  }

  .quiz-option {
    display: block;
    width: 100%;
    text-align: left;
    padding: 0.9rem 1.2rem;
    border: 2px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    font-family: var(--font-sans);
    font-size: 1rem;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }

  .quiz-option:hover:not(.disabled) {
    border-color: var(--color-primary);
    background: #eff6ff;
  }

  .quiz-option.selected {
    border-color: var(--color-primary);
    background: #eff6ff;
  }

  .quiz-option.correct {
    border-color: var(--color-success);
    background: #ecfdf5;
  }

  .quiz-option.incorrect {
    border-color: #ef4444;
    background: #fef2f2;
  }

  .quiz-option.disabled {
    cursor: default;
  }

  .quiz-option.disabled:not(.correct):not(.incorrect):not(.selected) {
    opacity: 0.6;
  }

  .quiz-feedback {
    margin-bottom: 1.5rem;
  }

  .quiz-actions {
    text-align: center;
  }

  /* Results */
  .results-card {
    text-align: center;
    padding: 2rem 0;
  }

  .results-score {
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-primary);
    margin: 1rem 0;
  }

  .results-actions {
    margin-top: 2rem;
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  #results-breakdown {
    max-width: 500px;
    margin: 1.5rem auto;
    text-align: left;
  }

  #results-breakdown .result-item {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  #results-breakdown .result-item.correct {
    color: var(--color-success);
  }

  #results-breakdown .result-item.incorrect {
    color: #ef4444;
  }
</style>

