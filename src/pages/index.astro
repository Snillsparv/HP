---
import Base from '../layouts/Base.astro';
import { getSessionFromCookies } from '../lib/auth.js';

const user = await getSessionFromCookies(Astro.request.headers.get('cookie'));
const isBB = user?.email?.includes('jessica.ahrling');
---

{isBB ? (
<Base title="BBAkuten – Nedräkning till Smultron">
  <style is:global>
    .bb-page .hero-stat .number,
    .bb-page .countdown-inline,
    .bb-page .site-logo span,
    .bb-page .hero-tag,
    .bb-page h1,
    .bb-page .btn-primary { color: #dc2626 !important; }
    .bb-page .btn-primary { background: #dc2626 !important; border-color: #dc2626 !important; color: #fff !important; }
    .bb-page .site-logo span { color: #dc2626 !important; }
  </style>

  <div class="hero hero--minimal">
    <div class="hero-content">
      <div class="hero-peek-wrapper">
        <img src="/jonas_bb.webp" alt="Jonas" class="hero-peek-img" data-fadein />
      </div>
      <span class="hero-tag">Från Sveriges mest nervösa blivande pappa</span>
      <h1>Välkommen till BBAkuten</h1>
      <p class="subtitle">
        Strategier och andningstekniker från Jonas von Essen, som nu ska ta sig an sitt livs största utmaning.
      </p>

      <div class="hero-stats">
        <div class="hero-stat">
          <span class="number">1</span>
          <span class="label">Första barnet</span>
        </div>
        <div class="hero-stat">
          <span class="number">3/3</span>
          <span class="label">Lyckade befruktningar</span>
        </div>
        <div class="hero-stat">
          <span class="number">∞</span>
          <span class="label">Kärlek</span>
        </div>
      </div>
    </div>
  </div>

  <section class="section" id="guide">
    <div class="container">
      <h2 class="section-title">Bara <span id="bb-cd-inline" class="countdown-inline" style="cursor:default;">--</span> kvar tills Smultron är här! 🍓</h2>
      <p class="section-subtitle" style="max-width: 700px; margin-left: auto; margin-right: auto;">
        Vi kan knappt bärga oss!
      </p>
    </div>
  </section>

  <script is:inline>
    document.body.classList.add('bb-page');

    // Replace logo
    document.querySelectorAll('.site-logo').forEach(el => {
      el.innerHTML = 'BB<span>Akuten</span>';
    });
    document.title = 'BBAkuten – Nedräkning till Smultron';

    // Countdown to Smultron (28 april 2026)
    (function() {
      const now = new Date();
      const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
      const target = new Date(2026, 3, 28);
      const days = Math.round((target.getTime() - today.getTime()) / 86400000);
      const el = document.getElementById('bb-cd-inline');
      if (!el) return;
      if (days > 0) el.textContent = `${days} ${days === 1 ? 'dag' : 'dagar'}`;
      else if (days === 0) el.textContent = 'IDAG 🍓';
      else el.textContent = `${Math.abs(days)} ${Math.abs(days) === 1 ? 'dag' : 'dagar'} sedan`;
    })();
  </script>
</Base>
) : (
<Base title="HPAkuten – Förbered dig snabbt och gratis inför Högskoleprovet" description="Träna gratis på högskoleprovet med Jonas von Essen, 2.0 tolv gånger i rad. Strategier, övningsprov och videogenomgångar som höjer ditt HP-resultat snabbt.">
  <div class="hero hero--minimal">
    <div class="hero-content">
      <div class="hero-peek-wrapper">
        <img src="/jonas_hp.webp" alt="Jonas von Essen" class="hero-peek-img" id="hero-img" data-fadein />
      </div>
      <span class="hero-tag">Från Sveriges mest framgångsrika HP-skrivare</span>
      <h1 id="hero-title">Nå ditt drömresultat på&nbsp;HP</h1>
      <p class="subtitle">
        Strategier och minnestekniker från Jonas von Essen, tvåfaldig världsmästare i minne med 2.0 på HP tolv gånger i rad.
      </p>

      <div class="hero-stats">
        <div class="hero-stat">
          <span class="number">15</span>
          <span class="label">Gånger skrivit HP</span>
        </div>
        <div class="hero-stat">
          <span class="number">2.0</span>
          <span class="label">12 gånger i rad</span>
        </div>
        <div class="hero-stat">
          <span class="number">160/160</span>
          <span class="label">Alla rätt (ensam i landet 2021)</span>
        </div>
      </div>

      <a href="#guide" class="btn btn-primary">Visa planen</a>
    </div>
  </div>

  <!-- Intro -->
  <section class="section" id="guide">
    <div class="container">
      <h2 id="countdown-title" class="section-title">Bara <span id="cd-inline" class="countdown-inline" style="cursor:default;">--</span> kvar och du är helt oförberedd?</h2>
      <p id="countdown-subtitle" class="section-subtitle" style="max-width: 700px; margin-left: auto; margin-right: auto;">
        Lugn, följ stegen nedan och du kommer att vara betydligt mer redo än du är just nu!
      </p>

      <div style="max-width: 800px; margin: 2rem auto;">
        <div class="video-embed"><iframe src="https://player.vimeo.com/video/1181837285?dnt=1&title=0&byline=0&portrait=0" title="Introduktion till HPAkuten" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe></div>
      </div>

      <div class="guide-text">
        <p>
          Det som snabbast kan göra en bättre på högskoleprovet är ironiskt nog just att <strong>skriva högskoleprovet!</strong> I snitt höjer man sitt resultat med 0,3 procentenheter mellan första och andra gången man skriver det. Det här beror förstås på att man andra gången vet hur provet går till och vad man kan förvänta sig. Om du dessutom tränar på ett strategiskt sätt så kan du ganska lätt höja dig ännu mer!
        </p>
        <p>
          Innebär det här att du måste vänta ett halvår till nästa prov för att få ett bra resultat? <strong>Absolut inte!</strong> På den här sidan kan du <strong>simulera</strong> ett gammalt högskoleprov för att direkt ge dig själv fördelarna med att ha gjort provet tidigare!
        </p>
        <div class="tip-box success">
          <strong>Allt är helt gratis</strong>
          Jag har försökt knåpa ihop en perfekt guide för vad jag skulle göra med bara några dagar kvar till provet. Till skillnad från nästan alla andra HP-kurser finns det ingen del som kostar något. Jag vill bara hjälpa så många som möjligt att förbättra sig så snabbt som möjligt.
        </div>
      </div>
    </div>
  </section>

  <!-- Steps -->
  <section class="section" style="background: #f1f5f9;">
    <div class="container">
      <h2 class="section-title">Följ de här 5 stegen och du kommer att höja ditt resultat</h2>

      <div class="steps">
        <a href="/trana" class="step">
          <span class="step-number">1</span>
          <div class="step-content">
            <h3>Titta på överblicken</h3>
            <p>
              Titta igenom överblicksvideon om hur provet är upplagt.
            </p>
            <span class="btn btn-primary" style="margin-top:0.5rem;">Sätt igång!</span>
          </div>
        </a>

        <a href="/prov/kvant-ht2021" class="step">
          <span class="step-number">2</span>
          <div class="step-content">
            <h3>Gör ett kvantitativt delprov på tid</h3>
            <p>
              Det är väldigt viktigt att du får en känsla av typen av uppgifter och hur lång tid de olika delarna tar. Efter rättningen tittar du på mina videor med lösningsförslag på de uppgifter du var osäker på.
            </p>
          </div>
        </a>

        <a href="/prov/verbal-ht2021" class="step">
          <span class="step-number">3</span>
          <div class="step-content">
            <h3>Gör samma sak med den verbala delen</h3>
            <p>
              Gör den verbala delen på tid och titta sedan på lösningsförslagen.
            </p>
          </div>
        </a>

        <a href="/delprov/xyz" class="step">
          <span class="step-number">4</span>
          <div class="step-content">
            <h3>Fyll igen kunskapsluckorna</h3>
            <p>
              Nu när du vet var dina svaga punkter finns kan du titta igenom min 20-minutersvideo som går igenom all matte du behöver kunna på högskoleprovet och min kortare video med ytterligare tips till den verbala delen. Om du behöver fräscha upp något specifikt område kan du göra det också!
            </p>
          </div>
        </a>

        <a href="/trana" class="step">
          <span class="step-number step-number--final">5</span>
          <div class="step-content">
            <h3>Gör de andra delarna och jämför</h3>
            <p>
              Gör det andra kvantitativa och det andra verbala delprovet och jämför med dina första resultat.
            </p>
          </div>
        </a>
      </div>

      <div class="tip-box success" style="max-width:700px; margin: 1.5rem auto 0; text-align:center;">
        <strong>Du är nu i ett mycket bättre läge än du var i tidigare! :) Lycka till!!</strong>
      </div>
    </div>
    </div>
  </section>

  <!-- Videos -->
  <section class="section">
    <div class="container container--wide">
      <h2 class="section-title">Sett i media</h2>
      <p class="section-subtitle">Jag har delat mina HP-tips och minnestekniker i Sveriges största medier.</p>
      <div class="video-grid">
        <div class="video-card">
          <p class="video-label">Expressen</p>
          <div class="video-embed"><iframe src="https://www.youtube.com/embed/YMfvx2pxXkU" title="Expressen" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>
        </div>
        <div class="video-card">
          <p class="video-label">TV4</p>
          <div class="video-embed"><iframe src="https://www.youtube.com/embed/yG5YIMd71wk" title="TV4" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>
        </div>
        <div class="video-card">
          <p class="video-label">Talang</p>
          <div class="video-embed"><iframe src="https://www.youtube.com/embed/WZwQ-zKBBaA" title="Talang" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const examDates = [
      new Date(2026, 3, 18, 9, 0, 0),  // 18 april 2026
      new Date(2026, 9, 18, 9, 0, 0),  // 18 oktober 2026
      new Date(2027, 3, 10, 9, 0, 0),  // 10 april 2027
      new Date(2027, 9, 24, 9, 0, 0),  // 24 oktober 2027
    ];

    function getNextExamDate() {
      const now = new Date();
      for (let i = 0; i < examDates.length; i++) {
        const d = examDates[i];
        // Switch to next exam at 17:00 on exam day
        const cutoff = new Date(d);
        cutoff.setHours(17, 0, 0, 0);
        if (cutoff.getTime() > now.getTime()) return d;
      }
      return examDates[examDates.length - 1];
    }

    const target = getNextExamDate();

    // Exam day: swap hero image, title, and launch confetti
    function isExamDay() {
      const now = new Date();
      return examDates.some(d =>
        d.getFullYear() === now.getFullYear() &&
        d.getMonth() === now.getMonth() &&
        d.getDate() === now.getDate()
      );
    }

    if (isExamDay()) {
      const heroImg = document.getElementById('hero-img') as HTMLImageElement;
      const heroTitle = document.getElementById('hero-title');
      if (heroImg) heroImg.src = '/jonas_redo.webp';
      if (heroTitle) heroTitle.textContent = 'LYCKA TILL IDAG!';

      const cdSub = document.getElementById('countdown-subtitle');
      if (cdSub) cdSub.textContent = 'Följ stegen nedan och du kommer att vara betydligt mer redo än du är just nu!';

      // Replace countdown title with well-wishing message
      const cdTitle = document.getElementById('countdown-title');
      if (cdTitle) {
        const now2 = new Date();
        const today = new Date(now2.getFullYear(), now2.getMonth(), now2.getDate());
        const nextExam = examDates.find(d => {
          const dDay = new Date(d.getFullYear(), d.getMonth(), d.getDate());
          return dDay.getTime() > today.getTime();
        });
        if (nextExam) {
          const nextDay = new Date(nextExam.getFullYear(), nextExam.getMonth(), nextExam.getDate());
          const daysToNext = Math.round((nextDay.getTime() - today.getTime()) / 86400000);
          cdTitle.innerHTML = `Hoppas att det går utmärkt idag! Men ta det lugnt och kom ihåg att du har <span class="countdown-inline">${daysToNext} dagar</span> på dig att förbereda dig för nästa prov om du inte blev nöjd!`;
        }
      }

      // Confetti
      const canvas = document.createElement('canvas');
      canvas.style.cssText = 'position:fixed;inset:0;width:100%;height:100%;pointer-events:none;z-index:9999;';
      document.body.appendChild(canvas);
      const ctx2 = canvas.getContext('2d')!;
      const dpr = window.devicePixelRatio || 1;
      canvas.width = window.innerWidth * dpr;
      canvas.height = window.innerHeight * dpr;
      ctx2.scale(dpr, dpr);
      const W2 = window.innerWidth, H2 = window.innerHeight;
      const colors = ['#3b82f6', '#22c55e', '#f59e0b', '#ef4444', '#a855f7', '#ec4899'];
      const pieces: { x: number; y: number; w: number; h: number; color: string; rot: number; vx: number; vy: number; vr: number; }[] = [];
      for (let i = 0; i < 150; i++) {
        pieces.push({
          x: Math.random() * W2, y: -Math.random() * H2 * 0.5,
          w: 6 + Math.random() * 6, h: 10 + Math.random() * 10,
          color: colors[Math.floor(Math.random() * colors.length)],
          rot: Math.random() * Math.PI * 2,
          vx: (Math.random() - 0.5) * 3, vy: 2 + Math.random() * 4, vr: (Math.random() - 0.5) * 0.2,
        });
      }
      let frame = 0;
      function animateConfetti() {
        ctx2.clearRect(0, 0, W2, H2);
        let alive = false;
        for (const p of pieces) {
          p.x += p.vx; p.y += p.vy; p.rot += p.vr; p.vy += 0.05;
          if (p.y < H2 + 50) alive = true;
          ctx2.save();
          ctx2.translate(p.x, p.y);
          ctx2.rotate(p.rot);
          ctx2.fillStyle = p.color;
          ctx2.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);
          ctx2.restore();
        }
        frame++;
        if (alive && frame < 300) requestAnimationFrame(animateConfetti);
        else canvas.remove();
      }
      requestAnimationFrame(animateConfetti);
    }

    function updateCountdown() {
      const now = new Date();
      const diff = target.getTime() - now.getTime();
      const el = document.getElementById('cd-inline');
      if (!el) return;

      if (diff <= 0) {
        const hours = Math.floor((diff + 8 * 3600000) / 3600000);
        if (hours > 0) {
          el.textContent = `${hours} timmar`;
        } else {
          el.textContent = 'några timmar';
        }
        return;
      }

      const hours = Math.floor(diff / 3600000);

      // Exact tooltip
      const tDays = Math.floor(diff / 86400000);
      const tHours = Math.floor((diff % 86400000) / 3600000);
      const tMins = Math.floor((diff % 3600000) / 60000);
      const parts = [];
      if (tDays > 0) parts.push(`${tDays} ${tDays === 1 ? 'dag' : 'dagar'}`);
      if (tHours > 0) parts.push(`${tHours} timmar`);
      parts.push(`${tMins} minuter`);
      el.title = parts.join(', ');

      if (hours >= 24) {
        const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
        const examDay = new Date(target.getFullYear(), target.getMonth(), target.getDate());
        const daysUntil = Math.round((examDay.getTime() - today.getTime()) / 86400000);
        el.textContent = daysUntil === 1 ? '1 dag' : `${daysUntil} dagar`;
      } else if (hours > 0) {
        el.textContent = `${hours} timmar`;
      } else {
        const mins = Math.floor((diff % 3600000) / 60000);
        el.textContent = `${mins} minuter`;
      }
    }

    updateCountdown();
    setInterval(updateCountdown, 30000);
  </script>
</Base>
)}
