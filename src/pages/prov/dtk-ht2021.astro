---
import Base from '../../layouts/Base.astro';
---

<Base title="DTK — Diagram, tabeller och kartor (HT 2021) – HPAkuten" description="Öva på DTK-delen från högskoleprovet HT 2021. 12 uppgifter baserade på diagram och tabeller, rätta direkt.">
  <div class="page-content">
    <div class="container" style="max-width: 700px;">

      <div class="prov-header">
        <h1>DTK — Diagram, tabeller och kartor</h1>
        <p class="prov-meta">Högskoleprov HT 2021 · Delprov 4 · 12 uppgifter · Rekommenderad tid: 18 minuter</p>
        <div class="prov-timer">
          <button class="btn btn-outline btn-sm" id="timer-btn">Starta timer (18:00)</button>
          <span class="timer-display" id="timer-display">⏱ <span id="timer-value">18:00</span></span>
        </div>
      </div>

      <div id="prov-app"></div>

    </div>
  </div>

  <script>
    // DTK questions are grouped by diagram
    // Each group shows its diagram above the questions
    const diagramGroups = [
      {
        diagram: '/prov-dtk1-diagram1.png',
        diagramAlt: 'Diagram: Betalningsförelägganden',
        rotate: true,
        questions: [
          {
            num: 29,
            text: 'För vilket år gällde att antalet betalningsförelägganden var större än 40 000 och att andelen män bland gäldenärerna var större än 55 procent?',
            options: ['2007', '2009', '2012', '2014'],
            correct: 2
          },
          {
            num: 30,
            text: 'Hur stor var den procentuella ökningen av antalet betalningsförelägganden 2014 jämfört med 2007?',
            options: ['45 procent', '125 procent', '155 procent', '215 procent'],
            correct: 2
          },
          {
            num: 31,
            text: 'Hur många av betalningsföreläggandena 2013 avsåg kvinnor?',
            options: ['19 676', '22 136', '24 596', '27 056'],
            correct: 1
          }
        ]
      },
      {
        diagram: '/prov-dtk1-diagram2.png',
        diagramAlt: 'Diagram: Flöden av hushållsavfall',
        rotate: false,
        questions: [
          {
            num: 32,
            text: 'Identifiera den behandlingstyp som den största respektive näst största mängden avfall gick till. <b>Hur stor var skillnaden mellan dessa två behandlingstyper?</b>',
            options: ['1 130 000 ton', '1 222 000 ton', '1 352 000 ton', '1 444 000 ton'],
            correct: 1
          },
          {
            num: 33,
            text: `Vilken av cirklarna visar hur hushållssektorns avfallstyp <i>Övrigt från återvinningscentral</i> fördelades på behandlingstyp?
              <div style="text-align:center;margin:1rem 0;">
                <img src="/prov-dtk1-33.png" alt="Fyra cirkeldiagram A-D" class="pq-fig" style="max-width:450px;aspect-ratio:730/116;" />
              </div>`,
            options: ['A', 'B', 'C', 'D'],
            correct: 1
          },
          {
            num: 34,
            text: 'Hur stor del av den totala mängden avfall gick till behandlingstypen <i>Energiåtervinning</i>?',
            options: ['1/2', '3/5', '3/4', '4/5'],
            correct: 1
          }
        ]
      },
      {
        diagram: '/prov-dtk1-diagram3.png',
        diagramAlt: 'Tabell: Elever i ungdomsvårdsskolor 1965-1968',
        rotate: true,
        questions: [
          {
            num: 35,
            text: 'Hur stor andel av de omhändertagna eleverna 1967 var 15–16 år?',
            options: ['1/6', '1/5', '1/4', '1/3'],
            correct: 2
          },
          {
            num: 36,
            text: 'Studera orsaker till omhändertaganden av flickor. För vilken orsak hade andelen förändrats mest från 1965 till 1968, i procentenheter räknat?',
            options: ['Biltillgrepp', 'Andra egendomsbrott', 'Sexuell vanart', 'Alkoholmissbruk'],
            correct: 2
          },
          {
            num: 37,
            text: 'Hur länge hade en flicka som skrevs ut från yrkesskola 1966 varit omhändertagen i genomsnitt?',
            options: ['1 år och 10 månader', '2 år och 5 månader', '2 år och 7 månader', '2 år och 9 månader'],
            correct: 1
          },
          {
            num: 38,
            text: 'Andelen pojkar som omhändertogs på grund av misshandel minskade med 8,8 procentenheter från 1966 till 1968. <b>Hur många pojkar motsvarade denna minskning?</b>',
            options: ['30', '100', '180', '250'],
            correct: 1
          }
        ]
      },
      {
        diagram: '/prov-dtk1-diagram4.png',
        diagramAlt: 'Diagram: Bibliotekens bestånd av medier',
        rotate: true,
        questions: [
          {
            num: 39,
            text: 'Hur stor andel av det totala beståndet av medier fanns i storstadslänen Stockholm, Skåne och Västra Götaland?',
            options: ['50 procent', '55 procent', '60 procent', '65 procent'],
            correct: 1
          },
          {
            num: 40,
            text: 'Jämför antalet medier på folkbibliotek i Jämtland och i Västerbotten. <b>Hur stor var skillnaden?</b>',
            options: ['545 000', '763 000', '925 000', '1 202 000'],
            correct: 2
          }
        ]
      }
    ];

    // Flatten for navigation
    const allQuestions = diagramGroups.flatMap(g => g.questions.map(q => ({ ...q, diagram: g.diagram, diagramAlt: g.diagramAlt, rotate: g.rotate })));

    const answers: (number | null)[] = new Array(allQuestions.length).fill(null);
    let current = 0;
    let submitted = false;

    const app = document.getElementById('prov-app')!;

    // Load KaTeX
    const katexCSS = document.createElement('link');
    katexCSS.rel = 'stylesheet';
    katexCSS.href = 'https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css';
    document.head.appendChild(katexCSS);

    function render() {
      if (submitted) { renderResults(); return; }
      const q = allQuestions[current];
      const labels = ['A', 'B', 'C', 'D'];
      app.innerHTML = `
        <div class="pq-progress">Uppgift ${current + 1} av ${allQuestions.length}</div>
        <div class="dtk-diagram">
          <p class="dtk-diagram-label">Studera diagrammet/tabellen och besvara frågan.</p>
          <img src="${q.diagram}" alt="${q.diagramAlt}" class="pq-fig dtk-diagram-img ${q.rotate ? 'dtk-rotated' : ''}" />
        </div>
        <div class="pq-card">
          <div class="pq-question">
            <span class="pq-num">${q.num}.</span>
            <span class="pq-text">${q.text}</span>
          </div>
          <div class="pq-options">
            ${q.options.map((opt, i) => `
              <label class="pq-opt ${answers[current] === i ? 'pq-opt--sel' : ''}">
                <input type="radio" name="q${current}" value="${i}" ${answers[current] === i ? 'checked' : ''} />
                <span class="pq-letter">${labels[i]}</span>
                <span class="pq-opt-text">${opt}</span>
              </label>
            `).join('')}
          </div>
        </div>
        <div class="pq-nav">
          <button class="btn btn-outline btn-sm" id="btn-prev" ${current === 0 ? 'disabled' : ''}>Föregående</button>
          <button class="btn btn-outline btn-sm" id="btn-overview">Översikt</button>
          ${current === allQuestions.length - 1
            ? '<button class="btn btn-primary btn-sm" id="btn-submit">Rätta provet</button>'
            : '<button class="btn btn-primary btn-sm" id="btn-next">Nästa</button>'}
        </div>
        <div class="pq-dots">
          ${allQuestions.map((_, i) => `<span class="pq-dot ${i === current ? 'pq-dot--cur' : ''} ${answers[i] !== null ? 'pq-dot--ans' : ''}" data-i="${i}">${i + 1}</span>`).join('')}
        </div>
      `;
      bindEvents();
    }

    function bindEvents() {
      app.querySelectorAll('input[type="radio"]').forEach(el => {
        el.addEventListener('change', (e) => { answers[current] = Number((e.target as HTMLInputElement).value); render(); });
      });
      document.getElementById('btn-prev')?.addEventListener('click', () => { current--; render(); });
      document.getElementById('btn-next')?.addEventListener('click', () => { current++; render(); });
      document.getElementById('btn-submit')?.addEventListener('click', () => { submitted = true; render(); });
      document.getElementById('btn-overview')?.addEventListener('click', renderOverview);
      app.querySelectorAll('.pq-dot').forEach(el => {
        el.addEventListener('click', () => { current = Number(el.getAttribute('data-i')); render(); });
      });
      app.querySelectorAll('.pq-fig').forEach(img => {
        const el = img as HTMLImageElement;
        if (el.complete) { el.classList.add('loaded'); }
        else { el.addEventListener('load', () => el.classList.add('loaded')); }
      });
      // Zoom on diagram click
      app.querySelectorAll('.dtk-diagram-img').forEach(img => {
        img.addEventListener('click', () => {
          const src = (img as HTMLImageElement).src;
          const overlay = document.createElement('div');
          overlay.className = 'dtk-zoom-overlay';
          overlay.innerHTML = `<img src="${src}" />`;
          overlay.addEventListener('click', () => overlay.remove());
          document.body.appendChild(overlay);
        });
      });
    }

    function renderOverview() {
      const labels = ['A', 'B', 'C', 'D'];
      const answered = answers.filter(a => a !== null).length;
      app.innerHTML = `
        <h2 style="text-align:center;margin-top:0;">Översikt</h2>
        <p style="text-align:center;color:var(--color-muted);">${answered} av ${allQuestions.length} besvarade</p>
        <div class="pq-overview">${allQuestions.map((q, i) => `
          <button class="pq-ov-btn ${answers[i] !== null ? 'pq-ov-btn--ans' : ''}" data-i="${i}">
            <span class="pq-ov-num">${q.num}</span>
            <span class="pq-ov-val">${answers[i] !== null ? labels[answers[i]!] : '—'}</span>
          </button>
        `).join('')}</div>
        <div class="pq-nav" style="margin-top:1.5rem;">
          <button class="btn btn-outline btn-sm" id="btn-back-first">Tillbaka till fråga 29</button>
          <button class="btn btn-primary btn-sm" id="btn-submit-overview">Rätta provet</button>
        </div>
      `;
      app.querySelectorAll('.pq-ov-btn').forEach(el => {
        el.addEventListener('click', () => { current = Number(el.getAttribute('data-i')); render(); });
      });
      document.getElementById('btn-back-first')?.addEventListener('click', () => { current = 0; render(); });
      document.getElementById('btn-submit-overview')?.addEventListener('click', () => { submitted = true; render(); });
    }

    function renderResults() {
      const labels = ['A', 'B', 'C', 'D'];
      let score = 0;
      allQuestions.forEach((q, i) => { if (answers[i] === q.correct) score++; });
      app.innerHTML = `
        <div class="pq-result-head"><h2>Resultat</h2><div class="pq-score">${score}/${allQuestions.length}</div><p style="color:var(--color-muted)">rätt svar</p></div>
        <div class="pq-results">${allQuestions.map((q, i) => {
          const ok = answers[i] === q.correct;
          return `<div class="pq-res ${ok ? 'pq-res--ok' : 'pq-res--no'}">
            <span class="pq-res-icon">${ok ? '✓' : '✗'}</span>
            <span class="pq-res-num">${q.num}.</span>
            <span>Ditt svar: <b>${answers[i] !== null ? labels[answers[i]!] : '—'}</b></span>
            ${!ok ? `<span class="pq-res-right">Rätt: <b>${labels[q.correct]}</b></span>` : ''}
          </div>`;
        }).join('')}</div>
        <div class="pq-nav" style="margin-top:2rem;">
          <button class="btn btn-outline btn-sm" id="btn-retry">Gör om provet</button>
          <a href="/trana" class="btn btn-primary btn-sm">Tillbaka</a>
        </div>
      `;
      document.getElementById('btn-retry')?.addEventListener('click', () => { answers.fill(null); current = 0; submitted = false; render(); });
    }

    render();

    // Timer
    let timerRunning = false;
    let timerSeconds = 18 * 60;
    let timerInterval: number;
    const timerBtn = document.getElementById('timer-btn')!;
    const timerDisp = document.getElementById('timer-display')!;
    const timerVal = document.getElementById('timer-value')!;
    function fmt(s: number) { return `${Math.floor(s/60)}:${(s%60).toString().padStart(2,'0')}`; }
    timerBtn.addEventListener('click', () => {
      timerRunning = true;
      timerBtn.style.display = 'none';
      timerDisp.style.display = 'inline';
      timerInterval = setInterval(() => {
        timerSeconds--;
        timerVal.textContent = fmt(timerSeconds);
        if (timerSeconds <= 0) { clearInterval(timerInterval); timerVal.textContent = 'Tiden är slut!'; }
      }, 1000) as unknown as number;
    });
  </script>
</Base>

<style is:global>
  .prov-header { text-align: center; margin-bottom: 2rem; }
  .prov-header h1 { font-size: 1.5rem; margin-bottom: 0.3rem; }
  .prov-meta { color: var(--color-muted); font-size: 0.9rem; margin-bottom: 1rem; }
  .prov-timer { margin-bottom: 0.5rem; }
  .timer-display { font-size: 1.3rem; font-weight: 700; color: var(--color-primary); display: none; }
  .btn-sm { padding: 0.5rem 1.2rem; font-size: 0.9rem; }

  .pq-progress { text-align: center; font-size: 0.8rem; color: var(--color-muted); margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.06em; }

  /* DTK diagram display */
  .dtk-diagram {
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .dtk-diagram-label {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-bottom: 0.8rem;
  }

  .dtk-diagram-img {
    max-width: 100%;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: #fff;
    cursor: zoom-in;
    transition: opacity 0.4s ease;
  }

  .dtk-rotated {
    transform: rotate(90deg);
    transform-origin: center center;
    margin: 5% 0;
  }

  /* Zoom overlay */
  .dtk-zoom-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.8);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: zoom-out;
    padding: 1rem;
  }

  .dtk-zoom-overlay img {
    max-width: 95vw;
    max-height: 95vh;
    border-radius: var(--radius);
    background: #fff;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }

  .pq-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 2rem 2rem 1.5rem;
    box-shadow: var(--shadow);
    margin-bottom: 2rem;
  }

  .pq-question { margin-bottom: 1.8rem; font-size: 1.05rem; line-height: 1.7; }
  .pq-num { font-weight: 700; margin-right: 0.5rem; }

  .pq-options { display: flex; flex-direction: column; gap: 0; margin-left: 1.2rem; }
  .pq-opt { display: flex; align-items: center; gap: 0.8rem; padding: 0.65rem 1rem; cursor: pointer; border-radius: var(--radius); transition: background 0.12s; border: 2px solid transparent; }
  .pq-opt:hover { background: #f5f7ff; }
  .pq-opt--sel { background: #eef2ff; border-color: var(--color-primary); }
  .pq-opt input { display: none; }
  .pq-letter { width: 30px; height: 30px; border-radius: 50%; background: #f1f5f9; border: 1.5px solid var(--color-border); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.85rem; flex-shrink: 0; transition: all 0.12s; }
  .pq-opt--sel .pq-letter { background: var(--color-primary); color: #fff; border-color: var(--color-primary); }
  .pq-opt-text { font-size: 1.05rem; line-height: 1.5; }

  .pq-nav { display: flex; justify-content: center; gap: 0.8rem; flex-wrap: wrap; }
  .pq-dots { display: flex; justify-content: center; gap: 0.35rem; margin-top: 1.5rem; flex-wrap: wrap; }
  .pq-dot { width: 32px; height: 32px; border-radius: 50%; border: 1.5px solid var(--color-border); display: flex; align-items: center; justify-content: center; font-size: 0.78rem; font-weight: 600; cursor: pointer; transition: all 0.12s; background: var(--color-surface); color: var(--color-text); }
  .pq-dot:hover { border-color: var(--color-primary); color: var(--color-primary); }
  .pq-dot--cur { border-color: var(--color-primary); color: var(--color-primary); box-shadow: 0 0 0 3px rgba(37,99,235,0.15); }
  .pq-dot--ans { background: var(--color-primary); color: #fff; border-color: var(--color-primary); }

  .pq-overview { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.7rem; max-width: 360px; margin: 1.5rem auto; }
  .pq-ov-btn { display: flex; flex-direction: column; align-items: center; gap: 0.15rem; padding: 0.7rem; border: 1.5px solid var(--color-border); border-radius: var(--radius); background: var(--color-surface); cursor: pointer; transition: all 0.12s; font-family: var(--font-sans); }
  .pq-ov-btn:hover { border-color: var(--color-primary); }
  .pq-ov-btn--ans { border-color: var(--color-primary); background: #eef2ff; }
  .pq-ov-num { font-weight: 700; font-size: 0.9rem; }
  .pq-ov-val { color: var(--color-muted); font-size: 0.8rem; }

  .pq-result-head { text-align: center; margin-bottom: 2rem; }
  .pq-result-head h2 { margin-top: 0; }
  .pq-score { font-size: 3rem; font-weight: 800; color: var(--color-primary); line-height: 1; }
  .pq-results { display: flex; flex-direction: column; gap: 0.4rem; }
  .pq-res { display: flex; align-items: center; gap: 0.6rem; padding: 0.55rem 1rem; border-radius: var(--radius); font-size: 0.95rem; }
  .pq-res--ok { background: #ecfdf5; }
  .pq-res--no { background: #fef2f2; }
  .pq-res-icon { font-weight: 700; font-size: 1.1rem; }
  .pq-res--ok .pq-res-icon { color: var(--color-success); }
  .pq-res--no .pq-res-icon { color: #ef4444; }
  .pq-res-num { font-weight: 600; min-width: 2rem; }
  .pq-res-right { margin-left: auto; color: var(--color-success); }

  .pq-fig { width: 100%; opacity: 0; transition: opacity 0.4s ease; }
  .pq-fig.loaded { opacity: 1; }

  @media (max-width: 480px) {
    .pq-card { padding: 1.2rem; }
    .pq-options { margin-left: 0; }
  }
</style>
