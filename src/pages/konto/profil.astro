---
import Base from '../../layouts/Base.astro';
import { getSessionFromCookies } from '../../lib/auth.js';

const user = await getSessionFromCookies(Astro.request.headers.get('cookie'));

if (!user) {
  return Astro.redirect('/konto/login');
}
---

<Base title="Min profil – HPAkuten">
  <div class="page-content">
    <div class="container" style="max-width: 480px;">
      <h1>Min profil</h1>

      <div class="profile-card">
        <div class="profile-avatar">{user.name.charAt(0).toUpperCase()}</div>
        <div>
          <p><strong>{user.name}</strong></p>
          <p style="color: var(--color-muted); font-size: 0.9rem;">{user.email}</p>
          <p style="color: var(--color-muted); font-size: 0.85rem;">Medlem sedan {new Date(user.created_at).toLocaleDateString('sv-SE')}</p>
        </div>
      </div>

      <form method="POST" action="/api/auth/logout" style="margin-top: 2rem;">
        <button type="submit" class="btn btn-outline" style="width: 100%;">Logga ut</button>
      </form>
    </div>
  </div>
</Base>

<style>
  .profile-card {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    margin-top: 1rem;
  }

  .profile-card p {
    margin-bottom: 0.2rem;
  }

  .profile-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 700;
    flex-shrink: 0;
  }
</style>
