---
import Base from '../layouts/Base.astro';
import { getSessionFromCookies } from '../lib/auth.js';
const user = await getSessionFromCookies(Astro.request.headers.get('cookie'));
const serverStep = user?.train_step || 1;
---

<Base title="Träna på Högskoleprovet – HPAkuten" description="Öva på riktiga provuppgifter från HT 2021. Steg-för-steg-plan med videogenomgångar.">
  <div class="page-content">
    <div class="container" style="max-width: 800px;">
      <h1>Träna på Högskoleprovet</h1>
      <p class="page-intro">Följ planen steg för steg och du kommer att vara betydligt mer redo på provdagen.</p>

      <div class="train-steps" id="train-steps">

        <div class="train-step" id="step-1" data-step="1">
          <div class="train-step-header">
            <span class="train-step-num">1</span>
            <h2>Se överblicken</h2>
          </div>
          <p>Börja med att titta på den här videon så att du förstår hur provet är upplagt.</p>
          <div class="video-embed"><iframe src="https://player.vimeo.com/video/1181680968?dnt=1" title="Överblick över högskoleprovet" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen loading="lazy"></iframe></div>
          <button class="btn btn-primary train-done-btn" data-next="2">Jag har kollat!</button>
        </div>

        <div class="train-step train-step--locked" id="step-2" data-step="2">
          <button class="train-back-btn" data-back="1">&uarr;</button>
          <div class="train-step-header">
            <span class="train-step-num">2</span>
            <h2>Gör kvantitativt prov 1</h2>
          </div>
          <p>Gör det första kvantitativa provet på tid. Rätta sedan och kolla på mina videor med lösningsförslag för de uppgifter du var osäker på.</p>
          <div class="delprov-videos">
            <p class="delprov-videos-label">Se genomgång av delproven först:</p>
            <div class="delprov-videos-links">
              <a href="/delprov/xyz">XYZ</a>
              <a href="/delprov/kva">KVA</a>
              <a href="/delprov/nog">NOG</a>
              <a href="/delprov/dtk">DTK</a>
            </div>
          </div>
          <a href="/prov/kvant-ht2021" class="prov-hero-link">
            <div class="prov-hero-card prov-hero-card--kvant">
              <h3>Kvantitativt prov 1</h3>
              <div class="prov-hero-stats">
                <span><strong>40</strong> uppgifter</span>
                <span><strong>55</strong> minuter</span>
                <span>XYZ + KVA + NOG + DTK</span>
              </div>
              <span class="btn btn-primary prov-btn--kvant" style="margin-top:1rem;">Starta provet</span>
            </div>
          </a>
          <button class="btn btn-primary train-done-btn" data-next="3">Klar</button>
        </div>

        <div class="train-step train-step--locked" id="step-3" data-step="3">
          <button class="train-back-btn" data-back="2">&uarr;</button>
          <div class="train-step-header">
            <span class="train-step-num">3</span>
            <h2>Gör verbalt prov 1</h2>
          </div>
          <p>Gör den verbala delen på tid och titta sedan på lösningsförslagen.</p>
          <div class="delprov-videos">
            <p class="delprov-videos-label">Se genomgång av delproven först:</p>
            <div class="delprov-videos-links">
              <a href="/delprov/ord">ORD</a>
              <a href="/delprov/las">LÄS</a>
              <a href="/delprov/mek">MEK</a>
              <a href="/delprov/elf">ELF</a>
            </div>
          </div>
          <a href="/prov/verbal-ht2021" class="prov-hero-link">
            <div class="prov-hero-card prov-hero-card--verbal">
              <h3>Verbalt prov 1</h3>
              <div class="prov-hero-stats">
                <span><strong>30</strong> uppgifter</span>
                <span><strong>33</strong> minuter</span>
                <span>ORD + LÄS + MEK</span>
              </div>
              <span class="btn btn-primary prov-btn--verbal" style="margin-top:1rem;">Starta provet</span>
            </div>
          </a>
          <button class="btn btn-primary train-done-btn" data-next="4">Klar</button>
        </div>

        <div class="train-step train-step--locked" id="step-4" data-step="4">
          <button class="train-back-btn" data-back="3">&uarr;</button>
          <div class="train-step-header">
            <span class="train-step-num">4</span>
            <h2>Titta på mattegenomgången</h2>
          </div>
          <p>Nu vet du var dina svaga punkter finns. Titta igenom min video som går igenom all matte du behöver kunna på högskoleprovet.</p>
          <a href="/delprov/xyz" class="prov-hero-link">
            <div class="prov-hero-card prov-hero-card--matte">
              <h3>Mattegenomgången</h3>
              <p style="margin-bottom:0;">All matte du behöver kunna, i en video.</p>
              <span class="btn btn-primary prov-btn--matte" style="margin-top:1rem;">Till videon</span>
            </div>
          </a>
          <button class="btn btn-primary train-done-btn" data-next="5">Klar</button>
        </div>

        <div class="train-step train-step--locked" id="step-5" data-step="5">
          <button class="train-back-btn" data-back="4">&uarr;</button>
          <div class="train-step-header">
            <span class="train-step-num">5a</span>
            <h2>Gör kvantitativt prov 2</h2>
          </div>
          <p>Dags för det andra kvantitativa provet. Jämför med ditt resultat från prov 1!</p>
          <a href="/prov/kvant2-ht2021" class="prov-hero-link">
            <div class="prov-hero-card prov-hero-card--kvant">
              <h3>Kvantitativt prov 2</h3>
              <div class="prov-hero-stats">
                <span><strong>40</strong> uppgifter</span>
                <span><strong>55</strong> minuter</span>
                <span>XYZ + KVA + NOG + DTK</span>
              </div>
              <span class="btn btn-primary prov-btn--kvant" style="margin-top:1rem;">Starta provet</span>
            </div>
          </a>
          <button class="btn btn-primary train-done-btn" data-next="6">Klar</button>
        </div>

        <div class="train-step train-step--locked" id="step-6" data-step="6">
          <button class="train-back-btn" data-back="5">&uarr;</button>
          <div class="train-step-header">
            <span class="train-step-num">5b</span>
            <h2>Gör verbalt prov 2</h2>
          </div>
          <p>Sista steget! Gör det andra verbala provet och jämför med ditt resultat från prov 1.</p>
          <a href="/prov/verbal2-ht2021" class="prov-hero-link">
            <div class="prov-hero-card prov-hero-card--verbal">
              <h3>Verbalt prov 2</h3>
              <div class="prov-hero-stats">
                <span><strong>30</strong> uppgifter</span>
                <span><strong>33</strong> minuter</span>
                <span>ORD + LÄS + MEK</span>
              </div>
              <span class="btn btn-primary prov-btn--verbal" style="margin-top:1rem;">Starta provet</span>
            </div>
          </a>
          <button class="btn btn-primary train-done-btn" data-next="7">Klar</button>
        </div>

        <div class="train-step train-step--locked" id="step-7" data-step="7">
          <div class="tip-box success" style="text-align: center; margin: 0;">
            <strong style="font-size: 1.2rem;">Du är nu i ett mycket bättre läge än du var i tidigare! Lycka till!!</strong>
          </div>
        </div>

      </div>
    </div>
  </div>

  <script define:vars={{ serverStep }}>
    window.__serverStep = serverStep;
  </script>

  <script>
    const STORAGE_KEY = 'hp-train-step';
    const localStep = parseInt(localStorage.getItem(STORAGE_KEY) || '1', 10);
    const sStep = (window as any).__serverStep || 1;
    const saved = Math.max(localStep, sStep);

    function saveStep(n: number) {
      localStorage.setItem(STORAGE_KEY, String(n));
      fetch('/api/auth/train-step', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ step: n }),
      }).catch(() => {});
    }

    function activateStep(n: number) {
      document.querySelectorAll('.train-step').forEach(el => {
        const step = parseInt(el.getAttribute('data-step') || '0', 10);
        el.classList.remove('train-step--locked', 'train-step--active', 'train-step--done');
        if (step < n) {
          el.classList.add('train-step--done');
        } else if (step === n) {
          el.classList.add('train-step--active');
        } else {
          el.classList.add('train-step--locked');
        }
      });
    }

    activateStep(saved);

    // Auto-scroll to current step on page load (if not step 1)
    if (saved > 1) {
      requestAnimationFrame(() => {
        const target = document.getElementById(`step-${saved}`);
        if (target) {
          const y = target.getBoundingClientRect().top + window.scrollY - 80;
          window.scrollTo({ top: y, behavior: 'smooth' });
        }
      });
    }

    document.querySelectorAll('.train-done-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const next = parseInt(btn.getAttribute('data-next') || '1', 10);
        saveStep(next);
        activateStep(next);
        const target = document.getElementById(`step-${next}`);
        if (target) {
          const y = target.getBoundingClientRect().top + window.scrollY - 80;
          window.scrollTo({ top: y, behavior: 'smooth' });
        }
      });
    });

    document.querySelectorAll('.train-back-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const back = parseInt(btn.getAttribute('data-back') || '1', 10);
        saveStep(back);
        activateStep(back);
        const target = document.getElementById(`step-${back}`);
        if (target) {
          const y = target.getBoundingClientRect().top + window.scrollY - 80;
          window.scrollTo({ top: y, behavior: 'smooth' });
        }
      });
    });
  </script>
</Base>

<style>
  .prov-hero-link { text-decoration: none; color: inherit; display: block; }
  .prov-hero-link:hover { text-decoration: none; }

  .prov-hero-card {
    text-align: center;
    padding: 1.5rem 2rem;
    border: 2px solid var(--color-border);
    border-radius: var(--radius);
    margin: 1rem 0;
    transition: box-shadow 0.15s, transform 0.15s;
  }

  .prov-hero-link:hover .prov-hero-card {
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    transform: translateY(-2px);
  }

  .prov-hero-card--kvant {
    background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
    border-color: #ea580c;
  }

  .prov-hero-card--verbal {
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
    border-color: #2563eb;
  }

  .prov-hero-card--matte {
    background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
    border-color: #16a34a;
  }

  .prov-btn--kvant { background: #ea580c; }
  .prov-btn--verbal { background: #2563eb; }
  .prov-btn--matte { background: #16a34a; }

  .prov-hero-card h3 { margin: 0 0 0.5rem; font-size: 1.15rem; }
  .prov-hero-card > p { color: var(--color-muted); }

  .prov-hero-stats {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .train-steps {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-top: 2rem;
  }

  .train-step {
    padding: 2rem;
    border-radius: var(--radius);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow);
    transition: opacity 0.3s, filter 0.3s;
    position: relative;
  }

  .train-step--active {
    border-color: var(--color-primary);
    box-shadow: 0 4px 20px rgba(37,99,235,0.12);
  }

  .train-step--locked {
    opacity: 0.35;
    pointer-events: none;
    filter: grayscale(0.3);
  }

  .train-step--done {
    opacity: 0.35;
    filter: grayscale(0.3);
  }

  .train-back-btn {
    position: absolute;
    top: 0.8rem;
    left: 0.8rem;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 1rem;
    color: var(--color-muted);
    transition: color 0.15s, border-color 0.15s;
  }

  .train-back-btn:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .train-step-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.8rem;
    text-align: center;
  }

  .train-step-header h2 {
    margin: 0;
    font-size: 1.3rem;
  }

  .train-step-num {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #2563eb;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    font-weight: 800;
    flex-shrink: 0;
  }

  .train-step > p {
    margin: 0 0 1rem;
    color: var(--color-muted);
    text-align: center;
  }

  .train-done-btn {
    display: block;
    width: 100%;
    margin-top: 1.5rem;
    font-size: 1rem;
    padding: 0.8rem;
  }

  .delprov-videos {
    text-align: center;
    margin-bottom: 1rem;
    padding: 1rem;
    background: #f8fafc;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
  }

  .delprov-videos-label {
    margin: 0 0 0.5rem;
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .delprov-videos-links {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }

  .delprov-videos-links a {
    font-weight: 700;
    font-size: 0.95rem;
  }
</style>
