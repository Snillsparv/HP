---
import Base from '../../layouts/Base.astro';
import { getSessionFromCookies } from '../../lib/auth.js';
import pool from '../../lib/db.js';
const user = await getSessionFromCookies(Astro.request.headers.get('cookie'));
let prevResult = null;
if (user) {
  const { rows } = await pool.query(
    'SELECT score, total FROM test_results WHERE user_id = $1 AND test_id = $2 ORDER BY score DESC LIMIT 1',
    [user.id, 'verbal-ht2021']
  );
  if (rows.length) prevResult = rows[0];
}
---

<Base title="Verbalt prov 2 HT 2021 – HPAkuten" description="Gör den andra verbala delen av högskoleprovet HT 2021 (utan ELF). 30 uppgifter, 33 minuter.">
  <div class="page-content">
    <div class="container" style="max-width: 700px;">
      <div id="prov-root"></div>
    </div>
  </div>

  <script define:vars={{ isLoggedIn: !!user, prevScore: prevResult?.score ?? null, prevTotal: prevResult?.total ?? null }}>
    window.__isLoggedIn = isLoggedIn;
    window.__prevScore = prevScore;
    window.__prevTotal = prevTotal;
  </script>

  <script>
    import { verbalSubTests2 } from '../../lib/questions-verbal2-ht2021.js';
    import type { VSubTest } from '../../lib/questions-verbal2-ht2021.js';
    import { getNormering } from '../../lib/normering.js';
    import { analyzeResults } from '../../lib/analysis.js';
    import { generateResultImage } from '../../lib/share-image.js';

    const subTests = verbalSubTests2;
    const root = document.getElementById('prov-root')!;
    const allQuestions = subTests.flatMap(st => st.questions.map(q => ({ ...q, subTest: st })));
    const totalTime = 33 * 60;
    const answers: (number | null)[] = new Array(allQuestions.length).fill(null);
    let current = 0;
    let submitted = false;
    let timerSeconds = totalTime;
    let timerInterval: number | null = null;
    let timerPaused = false;
    let started = false;

    const PROGRESS_KEY = 'hp-progress-verbal2-ht2021';

    const urlParams = new URLSearchParams(window.location.search);
    const isReview = urlParams.get('review') === '1';
    async function loadReview() {
      if (!isReview) return;
      clearProgress();
      const stored = JSON.parse(localStorage.getItem('hp-results') || '{}');
      const saved = stored['verbal2-ht2021'];
      if (saved?.answers) {
        saved.answers.forEach((a: number | null, i: number) => { if (i < answers.length) answers[i] = a; });
        submitted = true;
        started = true;
        timerSeconds = totalTime - (saved.timeSeconds || 0);
        return;
      }
      try {
        const res = await fetch('/api/test/results?testId=verbal2-ht2021');
        const data = await res.json();
        if (data.results?.length > 0) {
          const best = data.results[0];
          const serverAnswers = typeof best.answers === 'string' ? JSON.parse(best.answers) : best.answers;
          if (serverAnswers?.length) {
            serverAnswers.forEach((a: number | null, i: number) => { if (i < answers.length) answers[i] = a; });
            submitted = true;
            started = true;
            timerSeconds = totalTime - (best.time_seconds || 0);
          }
        }
      } catch {}
    }

    // Check for saved in-progress test
    function getSavedProgress() {
      try {
        const raw = localStorage.getItem(PROGRESS_KEY);
        if (!raw) return null;
        const data = JSON.parse(raw);
        if (data?.answers?.length === allQuestions.length && data.started && !data.submitted) return data;
      } catch {}
      return null;
    }

    function saveProgress() {
      if (started && !submitted) {
        const elapsed = totalTime - timerSeconds;
        localStorage.setItem(PROGRESS_KEY, JSON.stringify({ answers: [...answers], current, timerSeconds, started, submitted, elapsed }));
      }
    }

    function clearProgress() {
      localStorage.removeItem(PROGRESS_KEY);
    }

    // Auto-save on leaving page
    window.addEventListener('beforeunload', (e) => {
      if (started && !submitted) {
        saveProgress();
        e.preventDefault();
        e.returnValue = '';
      }
    });

    // Load KaTeX
    const css = document.createElement('link');
    css.rel = 'stylesheet';
    css.href = 'https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css';
    document.head.appendChild(css);
    const js = document.createElement('script');
    js.src = 'https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.js';
    document.head.appendChild(js);

    function renderTex() {
      if (typeof (window as any).katex === 'undefined') { setTimeout(renderTex, 50); return; }
      document.querySelectorAll('.tex').forEach(el => {
        (window as any).katex.render(el.textContent || '', el, { throwOnError: false });
      });
    }

    function fmt(s: number) { return `${Math.floor(s/60)}:${(s%60).toString().padStart(2,'0')}`; }

    function startTimer() {
      timerInterval = setInterval(() => {
        if (!timerPaused) {
          timerSeconds--;
          const el = document.getElementById('timer-val');
          if (el) el.textContent = fmt(timerSeconds);
          if (timerSeconds <= 0) {
            clearInterval(timerInterval!);
            submitted = true;
            clearProgress();
            render();
          }
        }
      }, 1000) as unknown as number;
    }

    function renderStart() {
      root.innerHTML = `
        <div style="text-align:center; padding: 3rem 0;">
          <h1 style="font-size:1.8rem; margin-bottom: 1.5rem;">Verbalt prov 2</h1>
          <img src="/verb.webp" alt="Verbalt prov" width="280" height="280" loading="lazy" style="width:280px; height:280px; margin-bottom:1.5rem; border-radius:var(--radius);" data-fadein />
          <div style="display:flex; justify-content:center; gap:3rem; margin-bottom: 2.5rem;">
            <div>
              <div style="font-size:2.8rem; font-weight:800; color:var(--color-primary);">30</div>
              <div style="color:var(--color-muted); font-size:0.85rem;">uppgifter</div>
            </div>
            <div>
              <div style="font-size:2.8rem; font-weight:800; color:var(--color-primary);">33:00</div>
              <div style="color:var(--color-muted); font-size:0.85rem;">minuter</div>
            </div>
          </div>
          <div style="text-align:left; max-width:440px; margin:0 auto 2rem; color:var(--color-muted); font-size:0.88rem; line-height:1.7;">
            <p style="margin-bottom:0;">Se till att du inte kommer att bli störd de närmaste 33 minuterna. Sätt din telefon på stör ej, precis som på provet. Jag rekommenderar att du gör provet på datorn för att se texterna bättre, men att göra det på mobilen fungerar också.</p>
          </div>
          <div class="tip-box" style="max-width:440px; margin:0 auto 2rem; font-size:0.88rem; text-align:left;">När du skrivit klart kommer provet att rättas automatiskt och du kan titta på mina lösningar.</div>
          <div class="tip-box warning" style="max-width:440px; margin:0 auto 2rem; font-size:0.88rem; text-align:left;">ELF-delen (engelsk läsförståelse) ingår tyvärr inte eftersom de engelska texterna ofta är copyrightade och inte publiceras. Men ELF fungerar precis som LÄS, så har du gjort den vet du hur det går till.</div>
          ${!(window as any).__isLoggedIn ? '<div style="max-width:440px; margin:0 auto 1.5rem; padding:1rem; background:#eff6ff; border:1px solid #bfdbfe; border-radius:var(--radius); font-size:0.85rem; text-align:left; color:#1e40af;"><strong>Tips:</strong> <a href="#" onclick="event.preventDefault(); window.openSignupModal();" style="color:#1e40af; text-decoration:underline;">Skapa ett konto</a> för att spara dina resultat och se din utveckling. OBS! Det är helt frivilligt och kostar inget. Du kan också fortsätta utan konto!</div>' : ''}
          ${getSavedProgress() ? `
            <div style="display:flex; flex-direction:column; gap:0.8rem; align-items:center;">
              <button class="btn btn-primary" id="btn-resume" style="font-size:1.2rem; padding:1rem 4rem;">Fortsätt där du var</button>
              <button class="btn btn-outline" id="btn-restart" style="font-size:0.95rem; padding:0.7rem 2rem;">Börja om från början</button>
            </div>
          ` : `
            <button class="btn btn-primary" id="btn-start" style="font-size:1.2rem; padding:1rem 4rem;">Starta provet</button>
          `}
        </div>
      `;
      document.getElementById('btn-start')?.addEventListener('click', () => {
        clearProgress();
        started = true;
        startTimer();
        render();
      });
      document.getElementById('btn-resume')?.addEventListener('click', () => {
        const prog = getSavedProgress();
        if (prog) {
          prog.answers.forEach((a: number | null, i: number) => { if (i < answers.length) answers[i] = a; });
          current = prog.current || 0;
          timerSeconds = prog.timerSeconds || totalTime;
        }
        started = true;
        startTimer();
        render();
      });
      document.getElementById('btn-restart')?.addEventListener('click', () => {
        clearProgress();
        started = true;
        startTimer();
        render();
      });
    }

    function currentSubTest(): SubTest {
      return allQuestions[current].subTest;
    }

    function render() {
      if (!started) { renderStart(); return; }
      if (submitted) { renderResults(); return; }
      const q = allQuestions[current];
      const st = q.subTest;
      const labels = ['A', 'B', 'C', 'D', 'E'];

      const questionHTML = `<div class="pq-question"><span class="pq-num">${q.num}.</span><span class="pq-text">${q.text}</span></div>`;

      let textHTML = '';
      if (st.type === 'las' && q.images) {
        textHTML = `<div class="las-text-section">
          <p class="las-text-label">${q.textTitle} — klicka för att läsa</p>
          ${q.images.map((img: string) => `<img src="${img}" alt="${q.textTitle}" class="las-text-img dtk-diagram-img" loading="lazy" data-fadein style="cursor:zoom-in;" />`).join('')}
        </div>`;
      }

      root.innerHTML = `
        <div class="prov-top-bar">
          <span class="prov-section-tag">${st.shortName}</span>
          <span class="prov-timer-bar">
            <span id="timer-val">${fmt(timerSeconds)}</span>
            <button class="btn-timer-toggle" id="btn-pause">${timerPaused ? '▶' : '⏸'}</button>
          </span>
        </div>
        <div class="pq-progress">Uppgift ${current + 1} av ${allQuestions.length}</div>
        ${textHTML}
        <div class="pq-card">
          ${questionHTML}
          <div class="pq-options">
            ${q.options.map((opt, i) => `
              <label class="pq-opt ${answers[current] === i ? 'pq-opt--sel' : ''}">
                <input type="radio" name="q${current}" value="${i}" ${answers[current] === i ? 'checked' : ''} />
                <span class="pq-letter">${labels[i]}</span>
                <span class="pq-opt-text">${opt}</span>
              </label>
            `).join('')}
          </div>
        </div>
        <div class="pq-nav">
          <div class="pq-nav-main">
            <button class="btn btn-outline btn-sm" id="btn-prev" ${current === 0 ? 'disabled' : ''}>Föregående</button>
            ${current === allQuestions.length - 1
              ? '<button class="btn btn-primary btn-sm" id="btn-next">Nästa</button>'
              : '<button class="btn btn-primary btn-sm" id="btn-next">Nästa</button>'}
          </div>
          <div style="display:flex; gap:0.6rem; align-items:center;">
            <button class="btn btn-sm btn-overview-link" id="btn-overview">Översikt</button>
            ${answers.filter(a => a === null).length === 0
              ? '<button class="btn btn-sm btn-outline" id="btn-submit" style="color:var(--color-success); border-color:var(--color-success);">Rätta provet</button>'
              : `<button class="btn btn-sm btn-outline" id="btn-submit" style="opacity:0.5;">Rätta (${answers.filter(a => a !== null).length}/${allQuestions.length})</button>`}
          </div>
        </div>
        <div class="pq-dots">${allQuestions.map((_, i) => `<span class="pq-dot ${i === current ? 'pq-dot--cur' : ''} ${answers[i] !== null ? 'pq-dot--ans' : ''}" data-i="${i}">${i+1}</span>`).join('')}</div>
      `;
      bindEvents();
    }

    function bindEvents() {
      root.querySelectorAll('input[type="radio"]').forEach(el => {
        el.addEventListener('change', (e) => { answers[current] = Number((e.target as HTMLInputElement).value); render(); });
      });
      document.getElementById('btn-prev')?.addEventListener('click', () => { current--; render(); });
      document.getElementById('btn-next')?.addEventListener('click', () => { current = (current + 1) % allQuestions.length; render(); });
      document.getElementById('btn-submit')?.addEventListener('click', () => {
        const unanswered = answers.filter(a => a === null).length;
        let msg = 'Vill du rätta provet?';
        if (unanswered > 0) msg = `Du har ${unanswered} obesvarade frågor. Vill du rätta ändå?`;
        if (confirm(msg)) { submitted = true; clearProgress(); if (timerInterval) clearInterval(timerInterval); render(); }
      });
      document.getElementById('btn-overview')?.addEventListener('click', renderOverview);
      document.getElementById('btn-pause')?.addEventListener('click', () => { timerPaused = !timerPaused; render(); });
      root.querySelectorAll('.pq-dot').forEach(el => {
        el.addEventListener('click', () => { current = Number(el.getAttribute('data-i')); render(); });
      });
      // DTK zoom
      root.querySelectorAll('.dtk-diagram-img').forEach(img => {
        img.addEventListener('click', () => {
          const src = (img as HTMLImageElement).src;
          const isRotated = img.classList.contains('dtk-rotated');
          const overlay = document.createElement('div');
          overlay.className = 'dtk-zoom-overlay';
          overlay.innerHTML = `<div class="dtk-zoom-inner"><img src="${src}" class="${isRotated ? 'dtk-zoom-rotated' : ''}" /></div>`;
          document.body.appendChild(overlay);
          let touchMoved = false;
          overlay.addEventListener('touchstart', () => { touchMoved = false; });
          overlay.addEventListener('touchmove', () => { touchMoved = true; });
          overlay.addEventListener('click', () => { if (!touchMoved) overlay.remove(); });
        });
      });
      // Fade-in images
      root.querySelectorAll('img[data-fadein]').forEach(img => {
        const el = img as HTMLImageElement;
        if (el.complete && el.naturalHeight > 0) el.classList.add('loaded');
        else el.addEventListener('load', () => el.classList.add('loaded'));
      });
      renderTex();
    }

    function renderOverview() {
      const labels = ['A', 'B', 'C', 'D', 'E'];
      const answered = answers.filter(a => a !== null).length;
      let html = `
        <div class="prov-top-bar">
          <span>Översikt</span>
          <span class="prov-timer-bar"><span id="timer-val">${fmt(timerSeconds)}</span><button class="btn-timer-toggle" id="btn-pause">${timerPaused ? '▶' : '⏸'}</button></span>
        </div>
        <p style="text-align:center;color:var(--color-muted);">${answered} av ${allQuestions.length} besvarade</p>
      `;
      for (const st of subTests) {
        const qs = allQuestions.filter(q => q.subTest.id === st.id);
        const startIdx = allQuestions.indexOf(qs[0]);
        html += `<h3 style="margin:1.5rem 0 0.5rem; font-size:0.95rem;">${st.shortName}</h3><div class="pq-overview">`;
        qs.forEach((q, i) => {
          const gi = startIdx + i;
          html += `<button class="pq-ov-btn ${answers[gi] !== null ? 'pq-ov-btn--ans' : ''}" data-i="${gi}"><span class="pq-ov-num">${q.num}</span><span class="pq-ov-val">${answers[gi] !== null ? labels[answers[gi]!] : '—'}</span></button>`;
        });
        html += `</div>`;
      }
      html += `<div class="pq-nav" style="margin-top:1.5rem;">
        <button class="btn btn-outline btn-sm" id="btn-back">Tillbaka</button>
        <button class="btn btn-primary btn-sm" id="btn-submit">Rätta provet</button>
      </div>`;
      root.innerHTML = html;
      root.querySelectorAll('.pq-ov-btn').forEach(el => {
        el.addEventListener('click', () => { current = Number(el.getAttribute('data-i')); render(); });
      });
      document.getElementById('btn-back')?.addEventListener('click', () => render());
      document.getElementById('btn-submit')?.addEventListener('click', () => {
        const unanswered = answers.filter(a => a === null).length;
        let msg = 'Vill du rätta provet?';
        if (unanswered > 0) msg = `Du har ${unanswered} obesvarade frågor. Vill du rätta ändå?`;
        if (confirm(msg)) { submitted = true; clearProgress(); if (timerInterval) clearInterval(timerInterval); render(); }
      });
      document.getElementById('btn-pause')?.addEventListener('click', () => { timerPaused = !timerPaused; renderOverview(); });
    }

    async function renderResults() {
      const labels = ['A', 'B', 'C', 'D', 'E'];
      const elapsed = totalTime - timerSeconds;

      // Per-subtest scores
      let resultsHTML = '';
      let totalScore = 0;
      for (const st of subTests) {
        const qs = allQuestions.filter(q => q.subTest.id === st.id);
        const startIdx = allQuestions.indexOf(qs[0]);
        let score = 0;
        qs.forEach((q, i) => { if (answers[startIdx + i] === q.correct) score++; });
        totalScore += score;
        resultsHTML += `
          <h3 style="margin:1.5rem 0 0.5rem;">${st.shortName} — ${score}/${qs.length}</h3>
          <div class="pq-results">${qs.map((q, i) => {
            const gi = startIdx + i;
            const ok = answers[gi] === q.correct;
            return `<div class="pq-res-wrap">
      <div class="pq-res ${ok ? 'pq-res--ok' : 'pq-res--no'}" data-toggle="res-${q.num}" style="cursor:pointer;">
        <span class="pq-res-icon">${ok ? '✓' : '✗'}</span>
        <span class="pq-res-num">${q.num}.</span>
        <span>Ditt svar: <b>${answers[gi] !== null ? labels[answers[gi]!] : '—'}</b></span>
        ${!ok ? `<span class="pq-res-right">Rätt: <b>${labels[q.correct]}</b></span>` : ''}
        <span class="pq-res-chevron">▾</span>
      </div>
      <div class="pq-res-detail" id="res-${q.num}" style="display:none;">
        <div class="pq-res-question">${q.text || ''}</div>
        <div class="pq-res-options">${q.options.map((opt, oi) => `<div class="pq-res-opt ${oi === q.correct ? 'pq-res-opt--correct' : ''} ${oi === answers[gi] && oi !== q.correct ? 'pq-res-opt--wrong' : ''}">${labels[oi]}. ${opt}</div>`).join('')}</div>
      </div>
    </div>`;
          }).join('')}</div>`;
      }

      const normered = getNormering(totalScore, allQuestions.length, 'verbal');
      const { summaryHTML: analysisHTML } = analyzeResults(allQuestions, answers, normered);
      const ps = (window as any).__prevScore;
      const pt = (window as any).__prevTotal;
      let comparisonHTML = '';
      if (ps !== null && pt !== null) {
        const prevNorm = getNormering(ps, pt, 'verbal');
        const diff = normered - prevNorm;
        if (diff > 0) {
          comparisonHTML = `<div class="tip-box success" style="margin-top:1.5rem; text-align:center;"><strong>Grattis! Du höjde dig med ${diff.toFixed(1)} poäng!</strong><br>Prov 1: ${prevNorm.toFixed(1)} (${ps}/${pt}) → Prov 2: ${normered.toFixed(1)} (${totalScore}/${allQuestions.length})</div>`;
        } else if (diff === 0) {
          comparisonHTML = `<div class="tip-box" style="margin-top:1.5rem; text-align:center;"><strong>Samma resultat som prov 1!</strong><br>Prov 1: ${prevNorm.toFixed(1)} (${ps}/${pt}) · Prov 2: ${normered.toFixed(1)} (${totalScore}/${allQuestions.length})<br>Bra jobbat med träningen! Du har fortfarande goda chanser att höja dig på det riktiga provet.</div>`;
        } else {
          comparisonHTML = `<div class="tip-box" style="margin-top:1.5rem; text-align:center;"><strong>Jämförelse med prov 1</strong><br>Prov 1: ${prevNorm.toFixed(1)} (${ps}/${pt}) · Prov 2: ${normered.toFixed(1)} (${totalScore}/${allQuestions.length})<br>Bra jobbat med träningen! Du har fortfarande goda chanser att höja dig på det riktiga provet.</div>`;
        }
      }

      root.innerHTML = `
        <div class="pq-result-head">
          <h2>Resultat</h2>
          <div class="pq-normered">${normered.toFixed(1)}</div>
          <p style="color:var(--color-muted); font-size:0.9rem;">normerad poäng</p>
          <div class="pq-score" style="font-size:1.5rem; margin-top:0.5rem;">${totalScore}/${allQuestions.length}</div>
          <p style="color:var(--color-muted)">rätt svar · tid: ${fmt(elapsed)}</p>
        </div>
        ${comparisonHTML}
        ${analysisHTML}
        ${resultsHTML}
        <div id="save-area" style="margin-top:2rem; text-align:center;"></div>
        <div class="pq-share" style="text-align:center; margin:1.5rem 0;">
          <div id="share-preview" style="margin-bottom:1rem;"></div>
          <div style="display:flex; justify-content:center; gap:0.6rem; flex-wrap:wrap;">
            <button class="btn btn-primary btn-sm" id="btn-share-img" style="display:inline-flex; align-items:center; gap:0.4rem;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
              Dela
            </button>
            <button class="btn btn-outline btn-sm" id="btn-download" style="display:inline-flex; align-items:center; gap:0.4rem;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Ladda ner
            </button>
          </div>
        </div>
        <div class="pq-nav" style="margin-top:1rem;">
          <button class="btn btn-outline btn-sm" id="btn-retry">Gör om provet</button>
          <a href="/trana" class="btn btn-primary btn-sm" id="btn-continue">Fortsätt</a>
        </div>
      `;

      // Always save to localStorage
      const resultData = { testId: 'verbal2-ht2021', score: totalScore, total: allQuestions.length, answers: [...answers], timeSeconds: elapsed, date: new Date().toISOString() };
      const stored = JSON.parse(localStorage.getItem('hp-results') || '{}');
      stored['verbal2-ht2021'] = resultData;
      localStorage.setItem('hp-results', JSON.stringify(stored));

      // Also save to server if logged in
      const saveArea = document.getElementById('save-area')!;
      if ((window as any).__isLoggedIn) {
        try {
          await fetch('/api/test/results', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ testId: 'verbal2-ht2021', score: totalScore, total: allQuestions.length, answers, timeSeconds: elapsed }),
          });
          saveArea.innerHTML = '<div class="tip-box success"><strong>Resultat sparat i ditt konto!</strong></div>';
        } catch {
          saveArea.innerHTML = '<div class="tip-box warning"><strong>Kunde inte spara till kontot, men resultatet finns sparat lokalt.</strong></div>';
        }
      } else {
        saveArea.innerHTML = '<div class="tip-box success"><strong>Resultat sparat!</strong> <a href="/konto/registrera">Skapa ett gratis konto</a> för att spara dina resultat permanent.</div>';
      }

      // Accordion toggle for question details
      root.querySelectorAll('[data-toggle]').forEach(el => {
        el.addEventListener('click', () => {
          const targetId = el.getAttribute('data-toggle')!;
          const detail = document.getElementById(targetId);
          if (detail) {
            const open = detail.style.display !== 'none';
            detail.style.display = open ? 'none' : 'block';
            el.querySelector('.pq-res-chevron')!.textContent = open ? '▾' : '▴';
          }
        });
      });
      renderTex();

      document.getElementById('btn-retry')?.addEventListener('click', () => {
        answers.fill(null); current = 0; submitted = false; timerSeconds = totalTime; timerPaused = false; started = false;
        render();
      });

      // Auto-generate share image
      const stScores: { name: string; correct: number; total: number }[] = [];
      for (const st of subTests) {
        const qs = allQuestions.filter(q => q.subTest.id === st.id);
        const startIdx = allQuestions.indexOf(qs[0]);
        let sc = 0;
        qs.forEach((q, i) => { if (answers[startIdx + i] === q.correct) sc++; });
        stScores.push({ name: st.shortName, correct: sc, total: qs.length });
      }
      generateResultImage('Verbalt prov 2', normered, totalScore, allQuestions.length, stScores).then(dataUrl => {
        const preview = document.getElementById('share-preview')!;
        preview.innerHTML = `<img src="${dataUrl}" style="max-width:300px; width:100%; border-radius:var(--radius); box-shadow:var(--shadow);" />`;

        document.getElementById('btn-share-img')?.addEventListener('click', async () => {
          try {
            const res2 = await fetch(dataUrl);
            const blob = await res2.blob();
            const file = new File([blob], 'hp-resultat.png', { type: 'image/png' });
            if (navigator.canShare?.({ files: [file] })) {
              await navigator.share({ files: [file], title: 'Mitt HP-resultat' });
            } else {
              await navigator.share({ text: 'Jag tränade på HPAkuten! www.hpakuten.se' });
            }
          } catch {}
        });

        document.getElementById('btn-download')?.addEventListener('click', () => {
          const a = document.createElement('a');
          a.href = dataUrl;
          a.download = 'hp-resultat.png';
          a.click();
        });
      });

      document.getElementById('btn-continue')?.addEventListener('click', () => {
        localStorage.setItem('hp-train-step', '7');
        fetch('/api/auth/train-step', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ step: 7 }) }).catch(() => {});
      });
    }

    loadReview().then(() => render());
  </script>
</Base>

