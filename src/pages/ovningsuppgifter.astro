---
import Base from '../layouts/Base.astro';
---

<Base title="Övningsuppgifter – HPAkuten" description="Öva på matteuppgifter för högskoleprovet. Bråk, procent, ekvationer, geometri och mer.">
  <div class="page-content">
    <div class="container" style="max-width: 800px;">
      <h1>Övningsuppgifter</h1>
      <p class="page-intro">Öva på de viktigaste matteområdena för högskoleprovet. Klicka på ett svar för att se om det stämmer!</p>

      <div id="exercise-app"></div>
    </div>
  </div>

  <script>
    import { categories as cats1 } from '../lib/exercises.js';
    import { part2 } from '../lib/exercises-part2.js';
    import { part3 } from '../lib/exercises-part3.js';
    import { part4 } from '../lib/exercises-part4.js';
    import type { Exercise, Category } from '../lib/exercises.js';

    const categories: Category[] = [...cats1, ...part2, ...part3, ...part4];
    const root = document.getElementById('exercise-app')!;
    let currentCat: Category | null = null;
    let currentIdx = 0;
    const answered: Map<string, Map<number, number>> = new Map();

    // Load KaTeX
    const css = document.createElement('link');
    css.rel = 'stylesheet';
    css.href = 'https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css';
    document.head.appendChild(css);
    const js = document.createElement('script');
    js.src = 'https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.js';
    document.head.appendChild(js);

    function renderTex() {
      if (typeof (window as any).katex === 'undefined') { setTimeout(renderTex, 50); return; }
      document.querySelectorAll('.tex').forEach(el => {
        (window as any).katex.render(el.textContent || '', el, { throwOnError: false });
      });
    }

    function renderCategoryList() {
      root.innerHTML = `
        <div class="ex-cats">
          ${categories.map(cat => {
            const done = answered.get(cat.id)?.size || 0;
            const isDone = done === cat.exercises.length;
            return `<button class="ex-cat-btn ${isDone ? 'ex-cat-btn--done' : ''}" data-cat="${cat.id}">
              <span class="ex-cat-name">${isDone ? '✓ ' : ''}${cat.name}</span>
              <span class="ex-cat-count">${done}/${cat.exercises.length}</span>
            </button>`;
          }).join('')}
        </div>
      `;
      root.querySelectorAll('.ex-cat-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          currentCat = categories.find(c => c.id === btn.getAttribute('data-cat')!)!;
          currentIdx = 0;
          renderExercise();
        });
      });
    }

    function renderExercise() {
      if (!currentCat) return;
      const ex = currentCat.exercises[currentIdx];
      const catAnswers = answered.get(currentCat.id) || new Map();
      const chosen = catAnswers.get(currentIdx);
      const isAnswered = chosen !== undefined;
      const labels = ['A', 'B', 'C', 'D', 'E'];

      root.innerHTML = `
        <div class="prov-top-bar">
          <span class="prov-section-tag">${currentCat.name}</span>
          <button class="btn-timer-toggle" id="btn-back-cats" title="Alla kategorier">✕</button>
        </div>
        <div class="pq-progress">Uppgift ${currentIdx + 1} av ${currentCat.exercises.length}</div>
        <div class="pq-card">
          <div class="pq-question"><span class="pq-num">${currentIdx + 1}.</span><span class="pq-text">${ex.q}</span></div>
          <div class="pq-options">
            ${ex.options.map((opt, i) => {
              let cls = 'pq-opt';
              if (isAnswered && i === ex.correct) cls += ' ex-opt--correct';
              if (isAnswered && i === chosen && i !== ex.correct) cls += ' ex-opt--wrong';
              if (isAnswered && i === chosen) cls += ' pq-opt--sel';
              return `<label class="${cls}" ${isAnswered ? '' : `data-oi="${i}"`}>
                <span class="pq-letter" ${isAnswered && i === ex.correct ? 'style="background:#22c55e; color:#fff; border-color:#22c55e;"' : isAnswered && i === chosen && i !== ex.correct ? 'style="background:#ef4444; color:#fff; border-color:#ef4444;"' : ''}>${labels[i]}</span>
                <span class="pq-opt-text">${opt}</span>
              </label>`;
            }).join('')}
          </div>
          ${isAnswered ? `<div class="ex-fb ${chosen === ex.correct ? 'ex-fb--ok' : 'ex-fb--no'}" style="margin-top:1rem;"><strong>Förklaring:</strong><br>${ex.explanation}</div>` : ''}
        </div>
        <div class="pq-nav">
          <div class="pq-nav-main">
            <button class="btn btn-outline btn-sm" id="btn-prev" ${currentIdx === 0 ? 'disabled' : ''}>Föregående</button>
            <button class="btn btn-primary btn-sm" id="btn-next">${currentIdx === currentCat.exercises.length - 1 ? 'Tillbaka till kategorier' : 'Nästa'}</button>
          </div>
          <button class="btn btn-sm btn-overview-link" id="btn-back-cats">Alla kategorier</button>
        </div>
        <div class="pq-dots">${currentCat.exercises.map((_, i) => {
          const a = catAnswers.get(i);
          let dotCls = 'pq-dot';
          if (i === currentIdx) dotCls += ' pq-dot--cur';
          if (a !== undefined) dotCls += ' pq-dot--ans';
          return `<span class="${dotCls}" data-i="${i}">${i+1}</span>`;
        }).join('')}</div>
      `;

      renderTex();

      // Bind events
      if (!isAnswered) {
        root.querySelectorAll('[data-oi]').forEach(el => {
          el.addEventListener('click', () => {
            const oi = Number(el.getAttribute('data-oi'));
            if (!catAnswers.has(currentIdx)) {
              if (!answered.has(currentCat!.id)) answered.set(currentCat!.id, new Map());
              answered.get(currentCat!.id)!.set(currentIdx, oi);
              renderExercise();
            }
          });
        });
      }

      document.getElementById('btn-prev')?.addEventListener('click', () => { currentIdx--; renderExercise(); });
      document.getElementById('btn-next')?.addEventListener('click', () => {
        if (currentIdx === currentCat!.exercises.length - 1) {
          currentCat = null;
          renderCategoryList();
        } else {
          currentIdx++;
          renderExercise();
        }
      });
      document.getElementById('btn-back-cats')?.addEventListener('click', () => { currentCat = null; renderCategoryList(); });
      root.querySelectorAll('.pq-dot').forEach(el => {
        el.addEventListener('click', () => { currentIdx = Number(el.getAttribute('data-i')); renderExercise(); });
      });
    }

    renderCategoryList();
  </script>

  <style is:global>
    /* Prov-layout styles for exercises */
    .prov-top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; padding: 0.6rem 1rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); }
    .prov-section-tag { font-weight: 700; font-size: 0.85rem; color: var(--color-primary); text-transform: uppercase; letter-spacing: 0.06em; }
    .btn-timer-toggle { background: none; border: none; font-size: 1rem; cursor: pointer; padding: 0.2rem; color: var(--color-muted); }
    .btn-timer-toggle:hover { color: var(--color-text); }
    .pq-progress { text-align: center; font-size: 0.8rem; color: var(--color-muted); margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.06em; }
    .pq-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 2rem 2rem 1.5rem; box-shadow: var(--shadow); margin-bottom: 2rem; }
    .pq-question { margin-bottom: 1.8rem; font-size: 1.05rem; line-height: 1.7; }
    .pq-num { font-weight: 700; margin-right: 0.5rem; }
    .pq-options { display: flex; flex-direction: column; gap: 0; margin-left: 1.2rem; }
    .pq-opt { display: flex; align-items: center; gap: 0.8rem; padding: 0.65rem 1rem; cursor: pointer; border-radius: var(--radius); transition: background 0.12s; border: 2px solid transparent; }
    .pq-opt:hover { background: #f5f7ff; }
    .pq-opt--sel { background: #eef2ff; border-color: var(--color-primary); }
    .pq-letter { width: 30px; height: 30px; border-radius: 50%; background: #f1f5f9; border: 1.5px solid var(--color-border); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.85rem; flex-shrink: 0; }
    .pq-opt-text { font-size: 1.05rem; line-height: 1.5; }
    .pq-nav { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.8rem; }
    .pq-nav-main { display: flex; gap: 0.8rem; }
    .pq-dots { display: flex; justify-content: center; gap: 0.25rem; margin-top: 1.5rem; flex-wrap: wrap; }
    .pq-dot { width: 28px; height: 28px; border-radius: 50%; border: 1.5px solid var(--color-border); display: flex; align-items: center; justify-content: center; font-size: 0.65rem; font-weight: 600; cursor: pointer; background: var(--color-surface); }
    .pq-dot:hover { border-color: var(--color-primary); color: var(--color-primary); }
    .pq-dot--cur { border-color: var(--color-primary); color: var(--color-primary); box-shadow: 0 0 0 2px rgba(37,99,235,0.15); }
    .pq-dot--ans { background: var(--color-primary); color: #fff; border-color: var(--color-primary); }
    @media (max-width: 480px) { .pq-card { padding: 1.2rem; } .pq-options { margin-left: 0; } }

    /* Exercise-specific */
    .ex-cats { display: flex; flex-direction: column; gap: 0.6rem; }
    .ex-cat-btn { display: flex; justify-content: space-between; align-items: center; padding: 1rem 1.2rem; background: var(--color-surface); border: 1.5px solid var(--color-border); border-radius: var(--radius); cursor: pointer; font-family: var(--font-sans); transition: all 0.15s; }
    .ex-cat-btn:hover { border-color: var(--color-primary); transform: translateY(-1px); box-shadow: var(--shadow-md); }
    .ex-cat-btn--done { border-color: #22c55e; background: #f0fdf4; }
    .ex-cat-btn--done .ex-cat-name { color: #16a34a; }
    .ex-cat-btn--done .ex-cat-count { color: #16a34a; }
    .ex-cat-name { font-weight: 700; font-size: 1.05rem; }
    .ex-cat-count { color: var(--color-muted); font-size: 0.85rem; font-weight: 600; }
    .ex-opt--correct { background: #ecfdf5 !important; border-color: #22c55e !important; }
    .ex-opt--wrong { background: #fef2f2 !important; border-color: #ef4444 !important; }
    .ex-fb { padding: 0.8rem 1rem; border-radius: var(--radius); font-size: 0.9rem; line-height: 1.6; }
    .ex-fb--ok { background: #ecfdf5; color: #065f46; }
    .ex-fb--no { background: #fef2f2; color: #991b1b; }
  </style>
</Base>
