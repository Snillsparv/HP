---
import { getSessionFromCookies } from '../lib/auth.js';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Jonas von Essen hjälper dig nå ditt drömresultat på högskoleprovet. Strategier, minnestekniker och studieplanering från Sveriges mest framgångsrika HP-skrivare.', ogImage = '/jonas_hp.webp' } = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalUrl = new URL(currentPath, 'https://www.hpakuten.se').href;
const user = await getSessionFromCookies(Astro.request.headers.get('cookie'));
---

<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={`https://www.hpakuten.se${ogImage}`} />
  <meta property="og:locale" content="sv_SE" />
  <meta property="og:site_name" content="HPAkuten" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`https://www.hpakuten.se${ogImage}`} />

  <!-- Organization structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "HPAkuten",
    "url": "https://www.hpakuten.se",
    "description": "Gratis förberedelser inför högskoleprovet med strategier, övningsprov och videogenomgångar från Jonas von Essen, tvåfaldig världsmästare i minne med 2.0 på HP tolv gånger i rad.",
    "logo": "https://www.hpakuten.se/favicon.svg"
  })} />
</head>
<body>
  <header class="site-header">
    <div class="container container--wide">
      <a href="/" class="site-logo">HP<span>Akuten</span></a>
      <button class="nav-toggle" aria-label="Meny" id="nav-toggle">☰</button>
      <nav class="site-nav" id="site-nav">
        <a href="/trana" class:list={['nav-cta', { active: currentPath.startsWith('/trana') || currentPath.startsWith('/prov') || currentPath.startsWith('/delprov') }]}>Träna</a>
        <a href="/forum" class:list={[{ active: currentPath.startsWith('/forum') }]}>Forum</a>
        <a href="/om-hp" class:list={[{ active: currentPath.startsWith('/om-hp') }]}>Om HP</a>
        <a href="/om" class:list={[{ active: currentPath === '/om' }]}>Om Jonas</a>
        {user ? (
          <a href="/konto/profil" class="nav-login">{user.name}</a>
        ) : (
          <a href="/konto/login" class="nav-login">Logga in</a>
        )}
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-contact">
        <h3>Hör av dig!</h3>
        <p>Allt på den här sidan är helt gratis, men jag skulle bli jätteglad om du som ett litet tack skrev och berättade om du gillar innehållet och hur det gick på provet! :)</p>
        <form class="contact-form" action="https://formsubmit.co/info@jonasvonessen.se" method="POST">
          <input type="hidden" name="_subject" value="Meddelande från HPAkuten" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value="https://www.hpakuten.se/?tack=1" />
          <div class="contact-row">
            <input type="text" name="name" placeholder="Ditt namn" required />
            <input type="email" name="email" placeholder="Din e-post" required />
          </div>
          <textarea name="message" rows="3" placeholder="Skriv ditt meddelande..." required></textarea>
          <button type="submit" class="btn btn-primary">Skicka</button>
        </form>
      </div>
      <p>&copy; {new Date().getFullYear()} Jonas von Essen · HPAkuten</p>
    </div>
  </footer>

  <script>
    document.getElementById('nav-toggle')?.addEventListener('click', () => {
      document.getElementById('site-nav')?.classList.toggle('open');
    });



    // Lazy-load Vimeo: click placeholder to load iframe
    document.querySelectorAll('.video-placeholder').forEach(el => {
      el.addEventListener('click', () => {
        const id = el.getAttribute('data-vimeo');
        el.outerHTML = `<div class="video-embed"><iframe src="https://player.vimeo.com/video/${id}?dnt=1&autoplay=1" title="Video" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe></div>`;
      });
    });

    // Global: fade in images with data-fadein attribute
    function initFadeImages() {
      document.querySelectorAll('img[data-fadein]').forEach(img => {
        const el = img as HTMLImageElement;
        if (el.complete && el.naturalHeight > 0) {
          el.classList.add('loaded');
        } else {
          el.addEventListener('load', () => el.classList.add('loaded'));
        }
      });
    }
    initFadeImages();

    // Also observe dynamically added images (for SPA-like pages)
    new MutationObserver(() => initFadeImages()).observe(document.body, { childList: true, subtree: true });
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
