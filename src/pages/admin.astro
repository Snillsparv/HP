---
import Base from '../layouts/Base.astro';
import { getSessionFromCookies } from '../lib/auth.js';
import pool from '../lib/db.js';

const ADMIN_EMAIL = 'snillsparv@gmail.com';

const user = await getSessionFromCookies(Astro.request.headers.get('cookie'));

if (!user || user.email !== ADMIN_EMAIL) {
  return Astro.redirect('/');
}

// Alerts
import '../lib/alerts.js';
const { rows: unseenAlerts } = await pool.query(
  "SELECT * FROM admin_alerts WHERE seen = false ORDER BY created_at DESC"
);

// Stats
const { rows: [userCount] } = await pool.query('SELECT COUNT(*) as count FROM users');
const { rows: [resultCount] } = await pool.query('SELECT COUNT(*) as count FROM test_results');
const { rows: [threadCount] } = await pool.query('SELECT COUNT(*) as count FROM threads');
const { rows: [replyCount] } = await pool.query('SELECT COUNT(*) as count FROM replies');
const { rows: [msgCount] } = await pool.query('SELECT COUNT(*) as count FROM contact_messages');

// Contact messages
const { rows: recentMessages } = await pool.query('SELECT * FROM contact_messages ORDER BY created_at DESC');

// Recent users
const { rows: recentUsers } = await pool.query(`
  SELECT id, name, email, avatar_color, train_step, created_at
  FROM users ORDER BY created_at DESC LIMIT 20
`);

// Test results per test
const { rows: resultsByTest } = await pool.query(`
  SELECT test_id, COUNT(*) as count, ROUND(AVG(score)::numeric, 1) as avg_score
  FROM test_results GROUP BY test_id ORDER BY test_id
`);

// Recent results
const { rows: recentResults } = await pool.query(`
  SELECT tr.test_id, tr.score, tr.total, tr.created_at, u.name, u.email
  FROM test_results tr JOIN users u ON tr.user_id = u.id
  ORDER BY tr.created_at DESC LIMIT 20
`);

// Question difficulty stats
import { subTests as kvant1Tests } from '../lib/questions-ht2021.js';
import { subTests as kvant2Tests } from '../lib/questions-kvant2-ht2021.js';
import { verbalSubTests as verbal1Tests } from '../lib/questions-verbal-ht2021.js';
import { verbalSubTests2 as verbal2Tests } from '../lib/questions-verbal2-ht2021.js';

const { rows: allResults } = await pool.query('SELECT test_id, answers, created_at FROM test_results');

const testQSets: Record<string, { num: number; correct: number; subTest: string }[]> = {};
for (const [tid, sts] of Object.entries({ 'kvant-ht2021': kvant1Tests, 'kvant2-ht2021': kvant2Tests, 'verbal-ht2021': verbal1Tests, 'verbal2-ht2021': verbal2Tests })) {
  const qs: { num: number; correct: number; subTest: string }[] = [];
  for (const st of sts as any[]) {
    for (const q of st.questions) qs.push({ num: q.num, correct: q.correct, subTest: st.shortName });
  }
  testQSets[tid] = qs;
}

// Facit fix dates: ignore results before these dates for affected questions
const facitFixDates: Record<string, string> = {
  'verbal2-ht2021': '2026-04-16T21:53:00Z',
};
const facitFixQuestions: Record<string, number[]> = {
  'verbal2-ht2021': [14, 15],
};

interface QStat { testId: string; num: number; subTest: string; answered: number; correctCount: number; rate: number; }
const qStats: QStat[] = [];

for (const [tid, qs] of Object.entries(testQSets)) {
  const counters = qs.map(() => ({ answered: 0, correct: 0 }));
  const testResults = allResults.filter((r: any) => r.test_id === tid);
  for (const r of testResults) {
    const ans = typeof r.answers === 'string' ? JSON.parse(r.answers) : r.answers;
    if (!Array.isArray(ans)) continue;
    const fixDate = facitFixDates[tid];
    const fixQs = facitFixQuestions[tid] || [];
    ans.forEach((a: any, i: number) => {
      if (i < qs.length && a !== null && a !== undefined) {
        // Skip old results for questions with corrected answer keys
        if (fixDate && fixQs.includes(qs[i].num) && new Date(r.created_at) < new Date(fixDate)) return;
        counters[i].answered++;
        if (Number(a) === qs[i].correct) counters[i].correct++;
      }
    });
  }
  qs.forEach((q, i) => {
    if (counters[i].answered > 0) {
      qStats.push({ testId: tid, num: q.num, subTest: q.subTest, answered: counters[i].answered, correctCount: counters[i].correct, rate: Math.round((counters[i].correct / counters[i].answered) * 100) });
    }
  });
}

const hardestQuestions = [...qStats].filter(q => q.answered >= 3).sort((a, b) => a.rate - b.rate).slice(0, 20);
const easiestQuestions = [...qStats].filter(q => q.answered >= 3).sort((a, b) => b.rate - a.rate).slice(0, 10);

// User results with normering
import { getNormering } from '../lib/normering.js';

const { rows: userResults } = await pool.query(`
  SELECT DISTINCT ON (tr.user_id, tr.test_id)
    tr.user_id, tr.test_id, tr.score, tr.total, tr.created_at,
    u.name, u.email
  FROM test_results tr JOIN users u ON tr.user_id = u.id
  ORDER BY tr.user_id, tr.test_id, tr.score DESC
`);

interface UserComparison { name: string; email: string; kvant1?: number; kvant1n?: number; verbal1?: number; verbal1n?: number; kvant2?: number; kvant2n?: number; verbal2?: number; verbal2n?: number; }
const userMap = new Map<number, UserComparison>();
for (const r of userResults) {
  if (!userMap.has(r.user_id)) userMap.set(r.user_id, { name: r.name, email: r.email });
  const u = userMap.get(r.user_id)!;
  const type = r.test_id.includes('verbal') ? 'verbal' as const : 'kvant' as const;
  const isTest2 = r.test_id.includes('2-ht');
  const norm = getNormering(r.score, r.total, type, isTest2);
  if (r.test_id === 'kvant-ht2021') { u.kvant1 = r.score; u.kvant1n = norm; }
  if (r.test_id === 'kvant2-ht2021') { u.kvant2 = r.score; u.kvant2n = norm; }
  if (r.test_id === 'verbal-ht2021') { u.verbal1 = r.score; u.verbal1n = norm; }
  if (r.test_id === 'verbal2-ht2021') { u.verbal2 = r.score; u.verbal2n = norm; }
}
const usersWithResults = [...userMap.values()].filter(u => u.kvant1n || u.verbal1n).sort((a, b) => {
  const aMax = Math.max(a.kvant1n || 0, a.kvant2n || 0, a.verbal1n || 0, a.verbal2n || 0);
  const bMax = Math.max(b.kvant1n || 0, b.kvant2n || 0, b.verbal1n || 0, b.verbal2n || 0);
  return bMax - aMax;
});

// Daily stats for charts
const { rows: dailyUsers } = await pool.query(`
  SELECT DATE(created_at) as day, COUNT(*) as count
  FROM users GROUP BY DATE(created_at) ORDER BY day
`);
const { rows: dailyResults } = await pool.query(`
  SELECT DATE(created_at) as day, COUNT(*) as count
  FROM test_results GROUP BY DATE(created_at) ORDER BY day
`);

function timeAgo(d: string) {
  const diff = Date.now() - new Date(d).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 60) return `${mins}m sedan`;
  const hours = Math.floor(mins / 60);
  if (hours < 24) return `${hours}h sedan`;
  const days = Math.floor(hours / 24);
  return `${days}d sedan`;
}
---

<Base title="Admin – HPAkuten">
  <div class="page-content">
    <div class="container">
      <h1>Admin</h1>

      {unseenAlerts.length > 0 && (
        <div class="admin-alerts">
          <h3>🔔 {unseenAlerts.length} ny{unseenAlerts.length === 1 ? 'tt' : 'a'} meddelande{unseenAlerts.length === 1 ? '' : 'n'}</h3>
          {unseenAlerts.map(a => (
            <div class="admin-alert-item">
              <span>{a.message}</span>
              <span style="font-size:0.8rem; color:var(--color-muted); white-space:nowrap;">{timeAgo(a.created_at)}</span>
            </div>
          ))}
          <button class="btn btn-sm btn-outline" id="dismiss-alerts" style="margin-top:0.5rem;">Markera som lästa</button>
        </div>
      )}

      <div class="admin-stats">
        <div class="admin-stat">
          <div class="admin-stat-num">{userCount.count}</div>
          <div class="admin-stat-label">Användare</div>
        </div>
        <div class="admin-stat">
          <div class="admin-stat-num">{resultCount.count}</div>
          <div class="admin-stat-label">Provresultat</div>
        </div>
        <div class="admin-stat">
          <div class="admin-stat-num">{msgCount.count}</div>
          <div class="admin-stat-label">Meddelanden</div>
        </div>
        <div class="admin-stat">
          <div class="admin-stat-num">{threadCount.count}</div>
          <div class="admin-stat-label">Forumtrådar</div>
        </div>
      </div>

      <div class="admin-search">
        <h3>Sök användare</h3>
        <div style="display:flex; gap:0.5rem;">
          <input type="text" id="user-search" placeholder="Namn eller e-post..." style="flex:1; padding:0.6rem 0.8rem; border:1.5px solid var(--color-border); border-radius:var(--radius); font-size:0.95rem; font-family:var(--font-sans);" />
          <button id="user-search-btn" class="btn btn-primary btn-sm">Sök</button>
        </div>
        <div id="user-search-results" style="margin-top:0.75rem;"></div>
      </div>

      <div class="admin-search">
        <h3>Exportera e-postlista</h3>
        <p style="font-size:0.85rem; color:var(--color-muted); margin:0 0 0.6rem;">Kopiera alla registrerade e-postadresser (kommaseparerade), t.ex. för nyhetsbrev via Brevo.</p>
        <div style="display:flex; gap:0.5rem;">
          <button id="export-emails-btn" class="btn btn-primary btn-sm">Hämta e-postlista</button>
          <button id="copy-emails-btn" class="btn btn-outline btn-sm" style="display:none;">Kopiera till urklipp</button>
        </div>
        <div id="export-emails-result" style="margin-top:0.75rem;"></div>
      </div>

      <details class="admin-section" open>
        <summary>Tillväxt över tid</summary>
        <div style="padding:1rem;">
          <canvas id="growth-chart" width="800" height="300" style="width:100%; height:300px;"></canvas>
          <div style="display:flex; gap:1.5rem; justify-content:center; margin-top:0.5rem; font-size:0.85rem;">
            <span><span style="color:#3b82f6;">●</span> Nya användare</span>
            <span><span style="color:#22c55e;">●</span> Nya provresultat</span>
          </div>
        </div>
      </details>

      <script define:vars={{ dailyUsers, dailyResults }}>
        const canvas = document.getElementById('growth-chart');
        if (canvas) {
          const ctx = canvas.getContext('2d');
          const dpr = window.devicePixelRatio || 1;
          canvas.width = canvas.offsetWidth * dpr;
          canvas.height = 300 * dpr;
          ctx.scale(dpr, dpr);
          const W = canvas.offsetWidth;
          const H = 300;
          const pad = { top: 20, right: 20, bottom: 40, left: 50 };

          // Merge dates
          const allDays = new Set();
          dailyUsers.forEach(d => allDays.add(d.day.split('T')[0]));
          dailyResults.forEach(d => allDays.add(d.day.split('T')[0]));
          const days = [...allDays].sort();

          const uMap = {};
          dailyUsers.forEach(d => uMap[d.day.split('T')[0]] = Number(d.count));
          const rMap = {};
          dailyResults.forEach(d => rMap[d.day.split('T')[0]] = Number(d.count));

          const uData = days.map(d => uMap[d] || 0);
          const rData = days.map(d => rMap[d] || 0);
          const maxVal = Math.max(...uData, ...rData, 1);

          function drawLine(data, color) {
            if (data.length < 2) return;
            ctx.beginPath();
            ctx.strokeStyle = color;
            ctx.lineWidth = 2;
            data.forEach((v, i) => {
              const x = pad.left + (i / (data.length - 1)) * (W - pad.left - pad.right);
              const y = pad.top + (1 - v / maxVal) * (H - pad.top - pad.bottom);
              if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
            });
            ctx.stroke();
          }

          // Background
          ctx.fillStyle = '#fafbfc';
          ctx.fillRect(0, 0, W, H);

          // Grid lines
          ctx.strokeStyle = '#e2e8f0';
          ctx.lineWidth = 1;
          for (let i = 0; i <= 4; i++) {
            const y = pad.top + (i / 4) * (H - pad.top - pad.bottom);
            ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(W - pad.right, y); ctx.stroke();
            ctx.fillStyle = '#94a3b8';
            ctx.font = '11px sans-serif';
            ctx.textAlign = 'right';
            ctx.fillText(Math.round(maxVal * (1 - i / 4)).toString(), pad.left - 8, y + 4);
          }

          // Date labels
          ctx.fillStyle = '#94a3b8';
          ctx.font = '11px sans-serif';
          ctx.textAlign = 'center';
          const step = Math.max(1, Math.floor(days.length / 6));
          days.forEach((d, i) => {
            if (i % step === 0 || i === days.length - 1) {
              const x = pad.left + (i / (days.length - 1)) * (W - pad.left - pad.right);
              ctx.fillText(d.slice(5), x, H - 10);
            }
          });

          drawLine(uData, '#3b82f6');
          drawLine(rData, '#22c55e');
        }
      </script>

      <details class="admin-section" open>
        <summary>Resultat per prov</summary>
        <table>
          <thead><tr><th>Prov</th><th>Antal</th><th>Snittpoäng</th></tr></thead>
          <tbody>{resultsByTest.map(r => <tr><td>{r.test_id}</td><td>{r.count}</td><td>{r.avg_score}</td></tr>)}</tbody>
        </table>
      </details>

      <details class="admin-section" open>
        <summary>Användarresultat med normering ({usersWithResults.length} st)</summary>
        <table>
          <thead><tr><th>Namn</th><th>Kvant 1</th><th>Kvant 2</th><th>K diff</th><th>Verb 1</th><th>Verb 2</th><th>V diff</th></tr></thead>
          <tbody>{usersWithResults.map(u => {
            const kDiff = (u.kvant1n != null && u.kvant2n != null) ? u.kvant2n - u.kvant1n : null;
            const vDiff = (u.verbal1n != null && u.verbal2n != null) ? u.verbal2n - u.verbal1n : null;
            return <tr>
              <td title={u.email}>{u.name}</td>
              <td>{u.kvant1n != null ? u.kvant1n.toFixed(1) : '—'}</td>
              <td>{u.kvant2n != null ? u.kvant2n.toFixed(1) : '—'}</td>
              <td style={`font-weight:700; color:${kDiff != null ? (kDiff > 0 ? '#22c55e' : kDiff < 0 ? '#ef4444' : 'var(--color-muted)') : 'var(--color-muted)'};`}>{kDiff != null ? (kDiff > 0 ? '+' : '') + kDiff.toFixed(1) : '—'}</td>
              <td>{u.verbal1n != null ? u.verbal1n.toFixed(1) : '—'}</td>
              <td>{u.verbal2n != null ? u.verbal2n.toFixed(1) : '—'}</td>
              <td style={`font-weight:700; color:${vDiff != null ? (vDiff > 0 ? '#22c55e' : vDiff < 0 ? '#ef4444' : 'var(--color-muted)') : 'var(--color-muted)'};`}>{vDiff != null ? (vDiff > 0 ? '+' : '') + vDiff.toFixed(1) : '—'}</td>
            </tr>;
          })}</tbody>
        </table>
      </details>

      <details class="admin-section">
        <summary>Meddelanden ({msgCount.count})</summary>
        <table>
          <thead><tr><th>Namn</th><th>E-post</th><th>Meddelande</th><th>När</th></tr></thead>
          <tbody>{recentMessages.map(m => <tr><td>{m.name}</td><td style="font-size:0.85rem;">{m.email}</td><td style="font-size:0.85rem; max-width:300px;">{m.message}</td><td style="font-size:0.85rem;">{timeAgo(m.created_at)}</td></tr>)}</tbody>
        </table>
      </details>

      <details class="admin-section">
        <summary>Senaste användare (20)</summary>
        <table>
          <thead><tr><th>Namn</th><th>E-post</th><th>Steg</th><th>Registrerad</th></tr></thead>
          <tbody>{recentUsers.map(u => <tr><td>{u.name}</td><td style="font-size:0.85rem; color:var(--color-muted);">{u.email}</td><td>{u.train_step || 1}</td><td style="font-size:0.85rem;">{timeAgo(u.created_at)}</td></tr>)}</tbody>
        </table>
      </details>

      <details class="admin-section">
        <summary>Senaste provresultat (20)</summary>
        <table>
          <thead><tr><th>Användare</th><th>Prov</th><th>Poäng</th><th>När</th></tr></thead>
          <tbody>{recentResults.map(r => <tr><td>{r.name}</td><td style="font-size:0.85rem;">{r.test_id}</td><td>{r.score}/{r.total}</td><td style="font-size:0.85rem;">{timeAgo(r.created_at)}</td></tr>)}</tbody>
        </table>
      </details>

      <details class="admin-section">
        <summary>Svåraste frågorna (topp 20)</summary>
      <table>
        <thead>
          <tr><th>Prov</th><th>Del</th><th>Fråga</th><th>Rätt</th><th>Svar</th><th>%</th></tr>
        </thead>
        <tbody>
          {hardestQuestions.map(q => (
            <tr>
              <td style="font-size:0.8rem;">{q.testId}</td>
              <td>{q.subTest}</td>
              <td><strong>{q.num}</strong></td>
              <td>{q.correctCount}/{q.answered}</td>
              <td>{q.answered}</td>
              <td style={`font-weight:700; color:${q.rate < 30 ? '#ef4444' : q.rate < 50 ? '#f59e0b' : '#3b82f6'};`}>{q.rate}%</td>
            </tr>
          ))}
        </tbody>
      </table>
      </details>

      <details class="admin-section">
        <summary>Lättaste frågorna (topp 10)</summary>
        <table>
          <thead><tr><th>Prov</th><th>Del</th><th>Fråga</th><th>Rätt</th><th>Svar</th><th>%</th></tr></thead>
          <tbody>{easiestQuestions.map(q => <tr><td style="font-size:0.8rem;">{q.testId}</td><td>{q.subTest}</td><td><strong>{q.num}</strong></td><td>{q.correctCount}/{q.answered}</td><td>{q.answered}</td><td style="font-weight:700; color:#22c55e;">{q.rate}%</td></tr>)}</tbody>
        </table>
      </details>

      <details class="admin-section">
        <summary>Alla frågor ({qStats.length} st, svårast först)</summary>
        <table>
          <thead><tr><th>Prov</th><th>Del</th><th>Fråga</th><th>Rätt</th><th>Svar</th><th>%</th></tr></thead>
          <tbody>{[...qStats].sort((a, b) => a.rate - b.rate).map(q => <tr><td style="font-size:0.8rem;">{q.testId}</td><td>{q.subTest}</td><td><strong>{q.num}</strong></td><td>{q.correctCount}/{q.answered}</td><td>{q.answered}</td><td style={`font-weight:700; color:${q.rate < 30 ? '#ef4444' : q.rate < 50 ? '#f59e0b' : q.rate < 70 ? '#3b82f6' : '#22c55e'};`}>{q.rate}%</td></tr>)}</tbody>
        </table>
      </details>
    </div>
  </div>

  <script>
    const input = document.getElementById('user-search') as HTMLInputElement;
    const btn = document.getElementById('user-search-btn')!;
    const results = document.getElementById('user-search-results')!;

    async function search() {
      const q = input.value.trim();
      if (!q) return;
      results.innerHTML = '<p style="color:var(--color-muted);">Söker...</p>';
      try {
        const res = await fetch(`/api/admin/users?q=${encodeURIComponent(q)}`);
        if (!res.ok) { results.innerHTML = '<p style="color:#ef4444;">Fel vid sökning</p>'; return; }
        const data = await res.json();
        if (data.count === 0) {
          results.innerHTML = '<p style="color:var(--color-muted);">Inga träffar.</p>';
          return;
        }
        const rows = data.users.map((u: any) => {
          const date = new Date(u.created_at).toLocaleDateString('sv-SE');
          return `<tr><td>${u.id}</td><td><strong>${u.name}</strong></td><td style="color:var(--color-muted);">${u.email}</td><td>${u.train_step || 1}</td><td>${date}</td></tr>`;
        }).join('');
        results.innerHTML = `<p style="font-size:0.85rem; color:var(--color-muted); margin-bottom:0.5rem;">${data.count} träff${data.count === 1 ? '' : 'ar'}</p>
          <table class="search-result-table"><thead><tr><th>ID</th><th>Namn</th><th>E-post</th><th>Steg</th><th>Registrerad</th></tr></thead><tbody>${rows}</tbody></table>`;
      } catch { results.innerHTML = '<p style="color:#ef4444;">Kunde inte nå servern</p>'; }
    }

    btn.addEventListener('click', search);
    input.addEventListener('keydown', (e) => { if (e.key === 'Enter') search(); });

    // Email export
    let exportedEmails = '';
    document.getElementById('export-emails-btn')?.addEventListener('click', async () => {
      const res = await fetch('/api/admin/users?q=@');
      const data = await res.json();
      exportedEmails = data.users.map((u: any) => u.email).join(', ');
      const result = document.getElementById('export-emails-result')!;
      result.innerHTML = `<p style="font-size:0.85rem; color:var(--color-muted); margin-bottom:0.5rem;">${data.count} adresser</p><textarea readonly style="width:100%; height:100px; padding:0.5rem; font-size:0.8rem; border:1px solid var(--color-border); border-radius:var(--radius); font-family:var(--font-sans); resize:vertical;">${exportedEmails}</textarea>`;
      document.getElementById('copy-emails-btn')!.style.display = '';
    });
    document.getElementById('copy-emails-btn')?.addEventListener('click', async () => {
      await navigator.clipboard.writeText(exportedEmails);
      const btn = document.getElementById('copy-emails-btn')!;
      btn.textContent = 'Kopierat!';
      setTimeout(() => btn.textContent = 'Kopiera till urklipp', 2000);
    });

    document.getElementById('dismiss-alerts')?.addEventListener('click', async () => {
      await fetch('/api/admin/alerts', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'dismiss-all' }) });
      document.querySelector('.admin-alerts')?.remove();
    });
  </script>
</Base>

<style>
  .admin-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin: 1.5rem 0;
  }

  .admin-stat {
    text-align: center;
    padding: 1.2rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .admin-stat-num {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-primary);
  }

  .admin-stat-label {
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  table {
    width: 100%;
    margin-bottom: 1rem;
  }

  .admin-section {
    margin-bottom: 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .admin-section summary {
    padding: 0.8rem 1rem;
    font-weight: 700;
    font-size: 1.05rem;
    cursor: pointer;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }

  .admin-section summary:hover {
    background: #f8fafc;
  }

  .admin-section[open] summary {
    border-bottom: 1px solid var(--color-border);
  }

  .admin-section > table,
