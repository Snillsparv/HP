---
import { getSessionFromCookies } from '../lib/auth.js';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Jonas von Essen hjälper dig nå ditt drömresultat på högskoleprovet. Strategier, minnestekniker och studieplanering från Sveriges mest framgångsrika HP-skrivare.' } = Astro.props;
const currentPath = Astro.url.pathname;
const user = getSessionFromCookies(Astro.request.headers.get('cookie'));
---

<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <header class="site-header">
    <div class="container container--wide">
      <a href="/" class="site-logo">HP<span>Akuten</span></a>
      <button class="nav-toggle" aria-label="Meny" id="nav-toggle">☰</button>
      <nav class="site-nav" id="site-nav">
        <a href="/snabbguiden" class:list={[{ active: currentPath.startsWith('/snabbguiden') }]}>Snabbguiden</a>
        <a href="/delprov" class:list={[{ active: currentPath.startsWith('/delprov') }]}>Delprov</a>
        <a href="/minnestekniker" class:list={[{ active: currentPath.startsWith('/minnestekniker') }]}>Minnestekniker</a>
        <a href="/trana" class:list={[{ active: currentPath.startsWith('/trana') }]}>Träna</a>
        <a href="/ovning" class:list={[{ active: currentPath.startsWith('/ovning') }]}>Övning</a>
        <a href="/forum" class:list={[{ active: currentPath.startsWith('/forum') }]}>Forum</a>
        <a href="/om" class:list={[{ active: currentPath.startsWith('/om') }]}>Om Jonas</a>
        {user ? (
          <a href="/konto/profil" class="nav-login">{user.name}</a>
        ) : (
          <a href="/konto/login" class="nav-login">Logga in</a>
        )}
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-swish">
        <p>
          Allt på den här sidan är gratis — inga premiumplaner, inga dolda kostnader.
          <br />Om du vill tacka kan du <strong>swisha en kaffe</strong> eller ännu hellre:
          <strong>skriv och berätta hur det gick!</strong>
        </p>
      </div>
      <p>&copy; {new Date().getFullYear()} Jonas von Essen · HPAkuten</p>
    </div>
  </footer>

  <script>
    document.getElementById('nav-toggle')?.addEventListener('click', () => {
      document.getElementById('site-nav')?.classList.toggle('open');
    });
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
