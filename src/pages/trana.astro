---
import Base from '../layouts/Base.astro';
---

<Base title="Träna originalpass – HPMästaren">
  <div class="page-content">
    <div class="container container--wide">
      <h1>Träna på originalpass (Vår 2021)</h1>
      <p class="page-intro">
        Här kör du på <strong>exakt originaluppgifter i exakt originalordning</strong> direkt från uppgiftshäftet.
        Välj pass, skriv 55 minuter och fyll i svarsraden med radioknappar.
      </p>

      <section id="setup-screen" class="card">
        <h2>Välj pass</h2>
        <div class="card-grid pass-grid">
          <button class="card pass-card" data-pass="quant" type="button">
            <span class="card-icon">📊</span>
            <h3>Kvantitativt (40 frågor)</h3>
            <p>Original: provpass 3 - KVA (Vår 2021)</p>
          </button>
          <button class="card pass-card" data-pass="verbal" type="button">
            <span class="card-icon">📘</span>
            <h3>Verbalt (40 frågor)</h3>
            <p>Original: provpass 1 - VERB (Vår 2021)</p>
          </button>
        </div>
      </section>

      <section id="exam-screen" class="card" hidden>
        <div class="exam-top">
          <div>
            <button class="btn btn-outline btn-sm" id="back-btn" type="button">← Tillbaka</button>
            <h2 id="exam-title"></h2>
            <p class="material-links" id="material-links"></p>
          </div>
          <div class="timer-box" aria-live="polite">
            <span>Tid kvar</span>
            <strong id="timer">55:00</strong>
          </div>
        </div>

        <div class="exam-layout">
          <div class="booklet-pane">
            <iframe id="booklet-frame" title="Original uppgiftshäfte" class="booklet-frame"></iframe>
          </div>

          <form id="answer-form" class="answer-pane">
            <h3>Svarsrad (1–40)</h3>
            <p class="muted">Markera ett svar per fråga (A–E).</p>
            <div id="answer-grid" class="answer-grid"></div>
            <div class="actions">
              <button class="btn btn-primary" type="submit">Lämna in</button>
            </div>
          </form>
        </div>
      </section>

      <section id="result-screen" class="card" hidden>
        <h2>Klart!</h2>
        <p id="result-meta"></p>
        <p>
          Öppna <a id="facit-link" href="#" target="_blank" rel="noopener">facit</a> och rätta i samma ordning (1–40)
          som i uppgiftshäftet.
        </p>
        <div class="results-actions">
          <button class="btn btn-primary" id="retry-btn" type="button">Kör igen</button>
          <button class="btn btn-outline" id="other-btn" type="button">Välj annat pass</button>
        </div>
      </section>
    </div>
  </div>
</Base>

<style>
  .pass-grid { margin-top: 1rem; }
  .pass-card { cursor: pointer; text-align: left; border: none; }

  .exam-top { display:flex; justify-content:space-between; align-items:flex-start; gap:1rem; margin-bottom:1rem; }
  .btn-sm { padding:0.4rem 1rem; font-size:0.9rem; margin-bottom:0.8rem; }
  .material-links { margin:0; font-size:0.9rem; color:var(--color-muted); }
  .timer-box { text-align:right; color:var(--color-muted); }
  .timer-box strong { display:block; font-size:2rem; color:var(--color-primary); font-family:ui-monospace,SFMono-Regular,Menlo,monospace; }
  .timer-box strong.low { color:#dc2626; }

  .exam-layout { display:grid; grid-template-columns: 1.35fr 1fr; gap:1rem; align-items:start; }
  .booklet-pane, .answer-pane { border:1px solid var(--color-border); border-radius:var(--radius); padding:0.75rem; background:#fff; }
  .booklet-frame { width:100%; min-height:950px; border:none; border-radius:8px; background:#f8fafc; }

  .answer-pane h3 { margin:0 0 0.4rem; }
  .muted { margin:0 0 0.75rem; color:var(--color-muted); font-size:0.9rem; }
  .answer-grid { display:grid; gap:0.35rem; }
  .answer-row { display:grid; grid-template-columns: 42px repeat(5, 1fr); align-items:center; gap:0.45rem; padding:0.35rem; border:1px solid var(--color-border); border-radius:8px; }
  .qno { font-weight:700; color:#334155; text-align:right; }
  .answer-row label { display:flex; align-items:center; gap:0.2rem; justify-content:center; font-size:0.9rem; }

  .actions { margin-top:0.9rem; }
  .results-actions { display:flex; gap:0.8rem; flex-wrap:wrap; margin-top:1rem; }

  @media (max-width: 1100px) {
    .exam-layout { grid-template-columns: 1fr; }
    .booklet-frame { min-height:700px; }
  }
</style>

<script>
  type PassType = 'quant' | 'verbal';

  const PASS_DATA: Record<PassType, { title: string; booklet: string; facit: string }> = {
    quant: {
      title: 'Kvantitativt pass — original ordning',
      booklet: '/Vår%202021/provpass%203%20-%20KVA.pdf',
      facit: '/Vår%202021/facit.pdf'
    },
    verbal: {
      title: 'Verbalt pass — original ordning',
      booklet: '/Vår%202021/provpass%201%20-%20VERB.pdf',
      facit: '/Vår%202021/facit.pdf'
    }
  };

  const DURATION = 55 * 60;
  const QUESTIONS = 40;
  const OPTIONS = ['A', 'B', 'C', 'D', 'E'];

  const setupScreen = document.getElementById('setup-screen') as HTMLElement;
  const examScreen = document.getElementById('exam-screen') as HTMLElement;
  const resultScreen = document.getElementById('result-screen') as HTMLElement;

  const examTitle = document.getElementById('exam-title') as HTMLElement;
  const materialLinks = document.getElementById('material-links') as HTMLElement;
  const bookletFrame = document.getElementById('booklet-frame') as HTMLIFrameElement;
  const answerGrid = document.getElementById('answer-grid') as HTMLElement;
  const answerForm = document.getElementById('answer-form') as HTMLFormElement;

  const timerEl = document.getElementById('timer') as HTMLElement;
  const resultMeta = document.getElementById('result-meta') as HTMLElement;
  const facitLink = document.getElementById('facit-link') as HTMLAnchorElement;

  let currentPass: PassType | null = null;
  let timeLeft = DURATION;
  let timerId: number | null = null;

  const setScreen = (screen: 'setup' | 'exam' | 'result') => {
    setupScreen.hidden = screen !== 'setup';
    examScreen.hidden = screen !== 'exam';
    resultScreen.hidden = screen !== 'result';
  };

  const formatTime = (sec: number) => `${String(Math.floor(sec / 60)).padStart(2, '0')}:${String(sec % 60).padStart(2, '0')}`;

  const updateTimer = () => {
    timerEl.textContent = formatTime(timeLeft);
    timerEl.classList.toggle('low', timeLeft <= 5 * 60);
  };

  const stopTimer = () => {
    if (timerId !== null) {
      clearInterval(timerId);
      timerId = null;
    }
  };

  const renderAnswerRows = () => {
    answerGrid.innerHTML = Array.from({ length: QUESTIONS }, (_, idx) => {
      const q = idx + 1;
      const opts = OPTIONS.map((opt) => `
        <label>
          <input type="radio" name="q-${q}" value="${opt}" />
          <span>${opt}</span>
        </label>
      `).join('');

      return `
        <div class="answer-row">
          <span class="qno">${q}</span>
          ${opts}
        </div>
      `;
    }).join('');
  };

  const startPass = (pass: PassType) => {
    currentPass = pass;
    const data = PASS_DATA[pass];

    examTitle.textContent = data.title;
    materialLinks.innerHTML = `Källa: <a href="${data.booklet}" target="_blank" rel="noopener">original uppgiftshäfte</a> · <a href="${data.facit}" target="_blank" rel="noopener">facit</a>`;
    bookletFrame.src = data.booklet;
    facitLink.href = data.facit;

    renderAnswerRows();

    stopTimer();
    timeLeft = DURATION;
    updateTimer();
    timerId = window.setInterval(() => {
      timeLeft -= 1;
      updateTimer();
      if (timeLeft <= 0) {
        submitPass(true);
      }
    }, 1000);

    setScreen('exam');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  const submitPass = (auto = false) => {
    if (!currentPass) return;
    stopTimer();

    let answered = 0;
    for (let i = 1; i <= QUESTIONS; i += 1) {
      const checked = answerForm.querySelector(`input[name="q-${i}"]:checked`);
      if (checked) answered += 1;
    }

    const used = DURATION - timeLeft;
    resultMeta.textContent = `${auto ? 'Tiden tog slut' : 'Inlämnat'} efter ${Math.floor(used / 60)} min ${used % 60} sek. Besvarade frågor: ${answered}/${QUESTIONS}.`;

    setScreen('result');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  document.querySelectorAll('.pass-card').forEach((btn) => {
    btn.addEventListener('click', () => startPass((btn as HTMLElement).dataset.pass as PassType));
  });

  answerForm.addEventListener('submit', (event) => {
    event.preventDefault();
    submitPass(false);
  });

  document.getElementById('back-btn')!.addEventListener('click', () => {
    stopTimer();
    currentPass = null;
    setScreen('setup');
  });

  document.getElementById('retry-btn')!.addEventListener('click', () => {
    if (currentPass) startPass(currentPass);
  });

  document.getElementById('other-btn')!.addEventListener('click', () => {
    stopTimer();
    currentPass = null;
    setScreen('setup');
  });
</script>
