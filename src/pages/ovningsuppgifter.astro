---
import Base from '../layouts/Base.astro';
---

<Base title="Övningsuppgifter – HPAkuten" description="Öva på matteuppgifter för högskoleprovet. Bråk, procent, ekvationer, geometri och mer.">
  <div class="page-content">
    <div class="container" style="max-width: 800px;">
      <h1>Övningsuppgifter</h1>
      <p class="page-intro">Öva på de viktigaste matteområdena för högskoleprovet. Klicka på ett svar för att se om det stämmer!</p>

      <div id="exercise-app"></div>
    </div>
  </div>

  <script>
    interface Exercise {
      q: string;
      options: string[];
      correct: number;
      explanation: string;
    }

    interface Category {
      id: string;
      name: string;
      exercises: Exercise[];
    }

    const categories: Category[] = [
      {
        id: 'brak', name: 'Bråk',
        exercises: [
          { q: 'Vad är 1/3 + 1/6?', options: ['1/2', '2/9', '1/9', '2/6'], correct: 0, explanation: '1/3 = 2/6, så 2/6 + 1/6 = 3/6 = 1/2.' },
          { q: 'Vad är 2/5 · 3/4?', options: ['6/20', '5/9', '3/10', '6/9'], correct: 2, explanation: '2/5 · 3/4 = 6/20 = 3/10.' },
          { q: 'Vad är 3/4 ÷ 1/2?', options: ['3/8', '3/2', '6/4', '1/2'], correct: 1, explanation: 'Division med bråk = multiplikation med det omvända: 3/4 · 2/1 = 6/4 = 3/2.' },
          { q: 'Förenkla 0,6/0,3.', options: ['0,2', '2', '0,5', '3'], correct: 1, explanation: '0,6 ÷ 0,3 = 6/3 = 2.' },
          { q: 'Vad är 5/8 − 1/4?', options: ['4/4', '3/8', '1/2', '4/8'], correct: 1, explanation: '1/4 = 2/8, så 5/8 − 2/8 = 3/8.' },
        ]
      },
      {
        id: 'procent', name: 'Procent',
        exercises: [
          { q: 'Vad är 15% av 200?', options: ['25', '30', '35', '40'], correct: 1, explanation: '0,15 · 200 = 30.' },
          { q: 'En vara kostar 400 kr och sänks med 20%. Vad kostar den nu?', options: ['300 kr', '320 kr', '350 kr', '380 kr'], correct: 1, explanation: '400 · 0,80 = 320 kr.' },
          { q: 'Andelen kvinnor ökade från 40% till 48%. Hur många procentenheter är ökningen?', options: ['8 procentenheter', '20%', '8%', '20 procentenheter'], correct: 0, explanation: '48 − 40 = 8 procentenheter. Procentuell ökning vore (8/40)·100 = 20%.' },
          { q: 'En aktie går upp 50% och sedan ner 50%. Var är den nu jämfört med start?', options: ['Samma', 'Lägre', 'Högre', 'Beror på startpriset'], correct: 1, explanation: '100 → +50% → 150 → −50% → 75. Alltså 25% lägre.' },
          { q: 'Vad är förändringsfaktorn för en ökning med 12%?', options: ['0,12', '1,12', '0,88', '12'], correct: 1, explanation: 'Förändringsfaktor = 1 + 0,12 = 1,12.' },
        ]
      },
      {
        id: 'ekvationer', name: 'Ekvationer',
        exercises: [
          { q: 'Lös 3x + 7 = 22.', options: ['x = 3', 'x = 5', 'x = 7', 'x = 15'], correct: 1, explanation: '3x = 22 − 7 = 15, x = 15/3 = 5.' },
          { q: 'Förenkla 2(3x − 4) + x.', options: ['7x − 8', '6x − 4', '7x − 4', '5x − 8'], correct: 0, explanation: '6x − 8 + x = 7x − 8.' },
          { q: 'Lös x/4 = 3.', options: ['x = 7', 'x = 12', 'x = 3/4', 'x = 0,75'], correct: 1, explanation: 'x = 3 · 4 = 12.' },
          { q: 'Lös 5x − 3 = 2x + 9.', options: ['x = 2', 'x = 3', 'x = 4', 'x = 6'], correct: 2, explanation: '5x − 2x = 9 + 3, 3x = 12, x = 4.' },
          { q: 'Vad är x om 2(x + 3) = x + 10?', options: ['x = 4', 'x = 7', 'x = 3', 'x = 5'], correct: 0, explanation: '2x + 6 = x + 10, x = 4.' },
        ]
      },
      {
        id: 'lagesmatt', name: 'Lägesmått (median, medelvärde)',
        exercises: [
          { q: 'Vad är medelvärdet av 3, 7, 8, 10, 12?', options: ['7', '8', '9', '10'], correct: 1, explanation: '(3+7+8+10+12)/5 = 40/5 = 8.' },
          { q: 'Vad är medianen av 4, 1, 9, 3, 7?', options: ['3', '4', '5', '7'], correct: 1, explanation: 'Sorterat: 1, 3, 4, 7, 9. Mittersta = 4.' },
          { q: 'Medelvärdet av 5 tal är 12. Summan av talen är?', options: ['50', '60', '70', '24'], correct: 1, explanation: 'Summa = medelvärde · antal = 12 · 5 = 60.' },
          { q: 'Medianen av 2, 5, 8, 11 är?', options: ['5', '6,5', '7', '8'], correct: 1, explanation: 'Jämnt antal: (5+8)/2 = 6,5.' },
        ]
      },
      {
        id: 'geometri', name: 'Geometri',
        exercises: [
          { q: 'Två linjer skär varandra. En vinkel är 65°. Hur stor är den motstående vinkeln?', options: ['25°', '65°', '115°', '90°'], correct: 1, explanation: 'Motstående (vertikala) vinklar är lika stora.' },
          { q: 'Vad är arean av en cirkel med radie 3?', options: ['6π', '9π', '3π', '12π'], correct: 1, explanation: 'A = πr² = π·9 = 9π.' },
          { q: 'En rektangel har sidorna 5 och 8. Vad är arean?', options: ['13', '26', '40', '80'], correct: 2, explanation: 'A = 5 · 8 = 40.' },
          { q: 'Vinkelsumman i en triangel är?', options: ['90°', '180°', '270°', '360°'], correct: 1, explanation: 'Alltid 180° i en triangel.' },
          { q: 'En cylinder har radie 2 och höjd 5. Vad är volymen?', options: ['10π', '20π', '25π', '40π'], correct: 1, explanation: 'V = πr²h = π·4·5 = 20π.' },
        ]
      },
      {
        id: 'trianglar', name: 'Trianglar & Pythagoras',
        exercises: [
          { q: 'En rätvinklig triangel har kateter 3 och 4. Hur lång är hypotenusan?', options: ['5', '6', '7', '√7'], correct: 0, explanation: 'c² = 3² + 4² = 9 + 16 = 25, c = 5.' },
          { q: 'En rätvinklig triangel har hypotenusan 13 och en katet 5. Den andra kateten?', options: ['8', '10', '12', '√144'], correct: 2, explanation: 'b² = 13² − 5² = 169 − 25 = 144, b = 12.' },
          { q: 'Kan en triangel ha sidorna 3, 4, 8?', options: ['Ja', 'Nej'], correct: 1, explanation: '3 + 4 = 7 < 8. Triangelolikheten uppfylls inte.' },
        ]
      },
      {
        id: 'potenser', name: 'Potenser & roten ur',
        exercises: [
          { q: 'Vad är 2³ · 2⁴?', options: ['2⁷', '2¹²', '4⁷', '4¹²'], correct: 0, explanation: 'Samma bas: addera exponenterna. 2³⁺⁴ = 2⁷.' },
          { q: 'Förenkla (3²)³.', options: ['3⁵', '3⁶', '9³', '3⁸'], correct: 1, explanation: '(aᵐ)ⁿ = aᵐⁿ = 3⁶.' },
          { q: 'Vad är √50 förenklat?', options: ['5√2', '25√2', '√25', '10√5'], correct: 0, explanation: '√50 = √(25·2) = 5√2.' },
          { q: 'Vad är 4⁰?', options: ['0', '1', '4', 'Odefinierat'], correct: 1, explanation: 'Allt upphöjt i 0 = 1 (utom 0⁰).' },
          { q: 'Vad är 2⁻³?', options: ['−8', '−6', '1/8', '1/6'], correct: 2, explanation: '2⁻³ = 1/2³ = 1/8.' },
        ]
      },
      {
        id: 'olikheter', name: 'Olikheter',
        exercises: [
          { q: 'Lös 2x + 1 > 7.', options: ['x > 3', 'x > 4', 'x < 3', 'x > 6'], correct: 0, explanation: '2x > 6, x > 3.' },
          { q: 'Lös −3x < 12.', options: ['x < −4', 'x > −4', 'x < 4', 'x > 4'], correct: 1, explanation: 'Dividera med −3 och vänd tecknet: x > −4.' },
          { q: 'Om x > 2 och y < 0, vad gäller om xy?', options: ['xy > 0', 'xy < 0', 'xy = 0', 'Kan inte avgöras'], correct: 1, explanation: 'Positivt · negativt = negativt, alltså xy < 0.' },
        ]
      },
      {
        id: 'rorelse', name: 'Rörelse (svt)',
        exercises: [
          { q: 'En bil kör 90 km/h i 2 timmar. Hur långt?', options: ['45 km', '90 km', '180 km', '360 km'], correct: 2, explanation: 's = v · t = 90 · 2 = 180 km.' },
          { q: 'Du springer 400 m på 80 sekunder. Vad är hastigheten i m/s?', options: ['3 m/s', '4 m/s', '5 m/s', '6 m/s'], correct: 2, explanation: 'v = s/t = 400/80 = 5 m/s.' },
          { q: 'En cyklist cyklar 15 km/h. Hur lång tid tar 45 km?', options: ['2 h', '2,5 h', '3 h', '3,5 h'], correct: 2, explanation: 't = s/v = 45/15 = 3 h.' },
        ]
      },
      {
        id: 'sannolikhet', name: 'Sannolikhet',
        exercises: [
          { q: 'Du kastar en tärning. Vad är sannolikheten att få 6?', options: ['1/3', '1/6', '1/2', '1/12'], correct: 1, explanation: '1 gynnsamt utfall av 6 möjliga = 1/6.' },
          { q: 'I en påse finns 3 röda och 7 blå kulor. Sannolikheten att dra en röd?', options: ['3/7', '7/10', '3/10', '1/3'], correct: 2, explanation: '3/(3+7) = 3/10.' },
          { q: 'Du kastar två mynt. Sannolikheten för två krona?', options: ['1/2', '1/3', '1/4', '1/8'], correct: 2, explanation: '1/2 · 1/2 = 1/4.' },
        ]
      },
      {
        id: 'prioritering', name: 'Prioriteringsordning',
        exercises: [
          { q: 'Vad är 3 + 4 · 2?', options: ['14', '11', '10', '9'], correct: 1, explanation: 'Multiplikation före addition: 3 + 8 = 11.' },
          { q: 'Vad är (3 + 4) · 2?', options: ['11', '14', '10', '24'], correct: 1, explanation: 'Parentesen först: 7 · 2 = 14.' },
          { q: 'Vad är 20 − 3 · 4 + 2?', options: ['10', '70', '8', '12'], correct: 0, explanation: '20 − 12 + 2 = 10.' },
        ]
      },
      {
        id: 'heltal', name: 'Heltal & negativa tal',
        exercises: [
          { q: 'Vad är (−3) · (−4)?', options: ['−12', '12', '−7', '7'], correct: 1, explanation: 'Minus gånger minus = plus. (−3)·(−4) = 12.' },
          { q: 'Vad är −5 − (−3)?', options: ['−8', '−2', '2', '8'], correct: 1, explanation: '−5 − (−3) = −5 + 3 = −2.' },
          { q: 'Vilket tal är jämnt: 17, 24, 31, 43?', options: ['17', '24', '31', '43'], correct: 1, explanation: '24 är delbart med 2.' },
        ]
      },
      {
        id: 'funktioner', name: 'Funktioner',
        exercises: [
          { q: 'f(x) = 2x + 3. Vad är f(4)?', options: ['8', '11', '14', '7'], correct: 1, explanation: 'f(4) = 2·4 + 3 = 11.' },
          { q: 'En linje har k = 3 och m = −1. Vilken punkt ligger på linjen?', options: ['(0, −1)', '(0, 3)', '(1, 1)', '(−1, 0)'], correct: 0, explanation: 'y = 3x − 1. Vid x=0: y = −1. Alltså (0, −1).' },
          { q: 'Var skär y = 2x − 4 x-axeln?', options: ['x = −2', 'x = 2', 'x = 4', 'x = −4'], correct: 1, explanation: '0 = 2x − 4, 2x = 4, x = 2.' },
          { q: 'Vad är lutningen (k) för linjen y = −3x + 7?', options: ['7', '−3', '3', '−7'], correct: 1, explanation: 'k är koefficienten framför x, alltså −3.' },
        ]
      },
      {
        id: 'huvudrakning', name: 'Huvudräkning & uppskattning',
        exercises: [
          { q: 'Uppskatta 498 · 21.', options: ['Ca 5 000', 'Ca 10 000', 'Ca 15 000', 'Ca 20 000'], correct: 1, explanation: '500 · 20 = 10 000. (Exakt: 10 458)' },
          { q: 'Förenkla bråket 24/36.', options: ['2/3', '4/6', '3/4', '12/18'], correct: 0, explanation: 'GCD(24,36) = 12. 24/12 = 2, 36/12 = 3. Alltså 2/3.' },
          { q: 'Vad är ungefär √90?', options: ['Ca 8', 'Ca 9', 'Ca 9,5', 'Ca 10'], correct: 2, explanation: '9² = 81, 10² = 100. √90 ≈ 9,5.' },
          { q: 'Förläng 3/5 så att nämnaren blir 20.', options: ['12/20', '6/20', '15/20', '9/20'], correct: 0, explanation: '5 · 4 = 20, så 3 · 4 = 12. Alltså 12/20.' },
        ]
      },
    ];

    const root = document.getElementById('exercise-app')!;
    let currentCat: Category | null = null;
    let currentIdx = 0;
    const answered: Map<string, Map<number, number>> = new Map(); // cat.id -> idx -> chosen option

    function renderCategoryList() {
      root.innerHTML = `
        <div class="ex-cats">
          ${categories.map(cat => {
            const done = answered.get(cat.id)?.size || 0;
            return `<button class="ex-cat-btn" data-cat="${cat.id}">
              <span class="ex-cat-name">${cat.name}</span>
              <span class="ex-cat-count">${done}/${cat.exercises.length}</span>
            </button>`;
          }).join('')}
        </div>
      `;
      root.querySelectorAll('.ex-cat-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          currentCat = categories.find(c => c.id === btn.getAttribute('data-cat')!)!;
          currentIdx = 0;
          renderExercise();
        });
      });
    }

    function renderExercise() {
      if (!currentCat) return;
      const ex = currentCat.exercises[currentIdx];
      const catAnswers = answered.get(currentCat.id) || new Map();
      const chosen = catAnswers.get(currentIdx);
      const isAnswered = chosen !== undefined;
      const labels = ['A', 'B', 'C', 'D', 'E'];

      root.innerHTML = `
        <div class="prov-top-bar">
          <span class="prov-section-tag">${currentCat.name}</span>
          <button class="btn-timer-toggle" id="btn-back-cats" title="Alla kategorier">✕</button>
        </div>
        <div class="pq-progress">Uppgift ${currentIdx + 1} av ${currentCat.exercises.length}</div>
        <div class="pq-card">
          <div class="pq-question"><span class="pq-num">${currentIdx + 1}.</span><span class="pq-text">${ex.q}</span></div>
          <div class="pq-options">
            ${ex.options.map((opt, i) => {
              let cls = 'pq-opt';
              if (isAnswered && i === ex.correct) cls += ' ex-opt--correct';
              if (isAnswered && i === chosen && i !== ex.correct) cls += ' ex-opt--wrong';
              if (isAnswered && i === chosen) cls += ' pq-opt--sel';
              return `<label class="${cls}" ${isAnswered ? '' : `data-oi="${i}"`}>
                <span class="pq-letter" ${isAnswered && i === ex.correct ? 'style="background:#22c55e; color:#fff; border-color:#22c55e;"' : isAnswered && i === chosen && i !== ex.correct ? 'style="background:#ef4444; color:#fff; border-color:#ef4444;"' : ''}>${labels[i]}</span>
                <span class="pq-opt-text">${opt}</span>
              </label>`;
            }).join('')}
          </div>
          ${isAnswered ? `<div class="ex-fb ${chosen === ex.correct ? 'ex-fb--ok' : 'ex-fb--no'}" style="margin-top:1rem;">${chosen === ex.correct ? '✓ Rätt!' : '✗ Fel.'} ${ex.explanation}</div>` : ''}
        </div>
        <div class="pq-nav">
          <div class="pq-nav-main">
            <button class="btn btn-outline btn-sm" id="btn-prev" ${currentIdx === 0 ? 'disabled' : ''}>Föregående</button>
            <button class="btn btn-primary btn-sm" id="btn-next">${currentIdx === currentCat.exercises.length - 1 ? 'Tillbaka till kategorier' : 'Nästa'}</button>
          </div>
        </div>
        <div class="pq-dots">${currentCat.exercises.map((_, i) => {
          const a = catAnswers.get(i);
          let dotCls = 'pq-dot';
          if (i === currentIdx) dotCls += ' pq-dot--cur';
          if (a !== undefined) dotCls += ' pq-dot--ans';
          return `<span class="${dotCls}" data-i="${i}">${i+1}</span>`;
        }).join('')}</div>
      `;

      // Bind events
      if (!isAnswered) {
        root.querySelectorAll('[data-oi]').forEach(el => {
          el.addEventListener('click', () => {
            const oi = Number(el.getAttribute('data-oi'));
            if (!catAnswers.has(currentIdx)) {
              if (!answered.has(currentCat!.id)) answered.set(currentCat!.id, new Map());
              answered.get(currentCat!.id)!.set(currentIdx, oi);
              renderExercise();
            }
          });
        });
      }

      document.getElementById('btn-prev')?.addEventListener('click', () => { currentIdx--; renderExercise(); });
      document.getElementById('btn-next')?.addEventListener('click', () => {
        if (currentIdx === currentCat!.exercises.length - 1) {
          currentCat = null;
          renderCategoryList();
        } else {
          currentIdx++;
          renderExercise();
        }
      });
      document.getElementById('btn-back-cats')?.addEventListener('click', () => { currentCat = null; renderCategoryList(); });
      root.querySelectorAll('.pq-dot').forEach(el => {
        el.addEventListener('click', () => { currentIdx = Number(el.getAttribute('data-i')); renderExercise(); });
      });
    }

    renderCategoryList();
  </script>

  <style is:global>
    /* Prov-layout styles for exercises */
    .prov-top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; padding: 0.6rem 1rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); }
    .prov-section-tag { font-weight: 700; font-size: 0.85rem; color: var(--color-primary); text-transform: uppercase; letter-spacing: 0.06em; }
    .btn-timer-toggle { background: none; border: none; font-size: 1rem; cursor: pointer; padding: 0.2rem; color: var(--color-muted); }
    .btn-timer-toggle:hover { color: var(--color-text); }
    .pq-progress { text-align: center; font-size: 0.8rem; color: var(--color-muted); margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.06em; }
    .pq-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 2rem 2rem 1.5rem; box-shadow: var(--shadow); margin-bottom: 2rem; }
    .pq-question { margin-bottom: 1.8rem; font-size: 1.05rem; line-height: 1.7; }
    .pq-num { font-weight: 700; margin-right: 0.5rem; }
    .pq-options { display: flex; flex-direction: column; gap: 0; margin-left: 1.2rem; }
    .pq-opt { display: flex; align-items: center; gap: 0.8rem; padding: 0.65rem 1rem; cursor: pointer; border-radius: var(--radius); transition: background 0.12s; border: 2px solid transparent; }
    .pq-opt:hover { background: #f5f7ff; }
    .pq-opt--sel { background: #eef2ff; border-color: var(--color-primary); }
    .pq-letter { width: 30px; height: 30px; border-radius: 50%; background: #f1f5f9; border: 1.5px solid var(--color-border); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.85rem; flex-shrink: 0; }
    .pq-opt-text { font-size: 1.05rem; line-height: 1.5; }
    .pq-nav { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.8rem; }
    .pq-nav-main { display: flex; gap: 0.8rem; }
    .pq-dots { display: flex; justify-content: center; gap: 0.25rem; margin-top: 1.5rem; flex-wrap: wrap; }
    .pq-dot { width: 28px; height: 28px; border-radius: 50%; border: 1.5px solid var(--color-border); display: flex; align-items: center; justify-content: center; font-size: 0.65rem; font-weight: 600; cursor: pointer; background: var(--color-surface); }
    .pq-dot:hover { border-color: var(--color-primary); color: var(--color-primary); }
    .pq-dot--cur { border-color: var(--color-primary); color: var(--color-primary); box-shadow: 0 0 0 2px rgba(37,99,235,0.15); }
    .pq-dot--ans { background: var(--color-primary); color: #fff; border-color: var(--color-primary); }
    @media (max-width: 480px) { .pq-card { padding: 1.2rem; } .pq-options { margin-left: 0; } }

    /* Exercise-specific */
    .ex-cats { display: flex; flex-direction: column; gap: 0.6rem; }
    .ex-cat-btn { display: flex; justify-content: space-between; align-items: center; padding: 1rem 1.2rem; background: var(--color-surface); border: 1.5px solid var(--color-border); border-radius: var(--radius); cursor: pointer; font-family: var(--font-sans); transition: all 0.15s; }
    .ex-cat-btn:hover { border-color: var(--color-primary); transform: translateY(-1px); box-shadow: var(--shadow-md); }
    .ex-cat-name { font-weight: 700; font-size: 1.05rem; }
    .ex-cat-count { color: var(--color-muted); font-size: 0.85rem; font-weight: 600; }
    .ex-opt--correct { background: #ecfdf5 !important; border-color: #22c55e !important; }
    .ex-opt--wrong { background: #fef2f2 !important; border-color: #ef4444 !important; }
    .ex-fb { padding: 0.8rem 1rem; border-radius: var(--radius); font-size: 0.9rem; line-height: 1.6; }
    .ex-fb--ok { background: #ecfdf5; color: #065f46; }
    .ex-fb--no { background: #fef2f2; color: #991b1b; }
  </style>
</Base>
