---
import Base from '../layouts/Base.astro';
import { getSessionFromCookies } from '../lib/auth.js';
import pool from '../lib/db.js';

const ADMIN_EMAIL = 'snillsparv@gmail.com';

const user = await getSessionFromCookies(Astro.request.headers.get('cookie'));

if (!user || user.email !== ADMIN_EMAIL) {
  return Astro.redirect('/');
}

// Stats
const { rows: [userCount] } = await pool.query('SELECT COUNT(*) as count FROM users');
const { rows: [resultCount] } = await pool.query('SELECT COUNT(*) as count FROM test_results');
const { rows: [threadCount] } = await pool.query('SELECT COUNT(*) as count FROM threads');
const { rows: [replyCount] } = await pool.query('SELECT COUNT(*) as count FROM replies');

// Recent users
const { rows: recentUsers } = await pool.query(`
  SELECT id, name, email, avatar_color, train_step, created_at
  FROM users ORDER BY created_at DESC LIMIT 20
`);

// Test results per test
const { rows: resultsByTest } = await pool.query(`
  SELECT test_id, COUNT(*) as count, ROUND(AVG(score)::numeric, 1) as avg_score
  FROM test_results GROUP BY test_id ORDER BY test_id
`);

// Recent results
const { rows: recentResults } = await pool.query(`
  SELECT tr.test_id, tr.score, tr.total, tr.created_at, u.name, u.email
  FROM test_results tr JOIN users u ON tr.user_id = u.id
  ORDER BY tr.created_at DESC LIMIT 20
`);

// Question difficulty stats
import { subTests as kvant1Tests } from '../lib/questions-ht2021.js';
import { subTests as kvant2Tests } from '../lib/questions-kvant2-ht2021.js';
import { verbalSubTests as verbal1Tests } from '../lib/questions-verbal-ht2021.js';
import { verbalSubTests2 as verbal2Tests } from '../lib/questions-verbal2-ht2021.js';

const { rows: allResults } = await pool.query('SELECT test_id, answers FROM test_results');

const testQSets: Record<string, { num: number; correct: number; subTest: string }[]> = {};
for (const [tid, sts] of Object.entries({ 'kvant-ht2021': kvant1Tests, 'kvant2-ht2021': kvant2Tests, 'verbal-ht2021': verbal1Tests, 'verbal2-ht2021': verbal2Tests })) {
  const qs: { num: number; correct: number; subTest: string }[] = [];
  for (const st of sts as any[]) {
    for (const q of st.questions) qs.push({ num: q.num, correct: q.correct, subTest: st.shortName });
  }
  testQSets[tid] = qs;
}

interface QStat { testId: string; num: number; subTest: string; answered: number; correctCount: number; rate: number; }
const qStats: QStat[] = [];

for (const [tid, qs] of Object.entries(testQSets)) {
  const counters = qs.map(() => ({ answered: 0, correct: 0 }));
  const testResults = allResults.filter((r: any) => r.test_id === tid);
  for (const r of testResults) {
    const ans = typeof r.answers === 'string' ? JSON.parse(r.answers) : r.answers;
    if (!Array.isArray(ans)) continue;
    ans.forEach((a: any, i: number) => {
      if (i < qs.length && a !== null && a !== undefined) {
        counters[i].answered++;
        if (Number(a) === qs[i].correct) counters[i].correct++;
      }
    });
  }
  qs.forEach((q, i) => {
    if (counters[i].answered > 0) {
      qStats.push({ testId: tid, num: q.num, subTest: q.subTest, answered: counters[i].answered, correctCount: counters[i].correct, rate: Math.round((counters[i].correct / counters[i].answered) * 100) });
    }
  });
}

const hardestQuestions = [...qStats].filter(q => q.answered >= 3).sort((a, b) => a.rate - b.rate).slice(0, 20);
const easiestQuestions = [...qStats].filter(q => q.answered >= 3).sort((a, b) => b.rate - a.rate).slice(0, 10);

function timeAgo(d: string) {
  const diff = Date.now() - new Date(d).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 60) return `${mins}m sedan`;
  const hours = Math.floor(mins / 60);
  if (hours < 24) return `${hours}h sedan`;
  const days = Math.floor(hours / 24);
  return `${days}d sedan`;
}
---

<Base title="Admin – HPAkuten">
  <div class="page-content">
    <div class="container">
      <h1>Admin</h1>

      <div class="admin-stats">
        <div class="admin-stat">
          <div class="admin-stat-num">{userCount.count}</div>
          <div class="admin-stat-label">Användare</div>
        </div>
        <div class="admin-stat">
          <div class="admin-stat-num">{resultCount.count}</div>
          <div class="admin-stat-label">Provresultat</div>
        </div>
        <div class="admin-stat">
          <div class="admin-stat-num">{threadCount.count}</div>
          <div class="admin-stat-label">Forumtrådar</div>
        </div>
        <div class="admin-stat">
          <div class="admin-stat-num">{replyCount.count}</div>
          <div class="admin-stat-label">Foruminlägg</div>
        </div>
      </div>

      <h2>Resultat per prov</h2>
      <table>
        <thead>
          <tr><th>Prov</th><th>Antal</th><th>Snittpoäng</th></tr>
        </thead>
        <tbody>
          {resultsByTest.map(r => (
            <tr><td>{r.test_id}</td><td>{r.count}</td><td>{r.avg_score}</td></tr>
          ))}
        </tbody>
      </table>

      <h2>Senaste användare</h2>
      <table>
        <thead>
          <tr><th>Namn</th><th>E-post</th><th>Steg</th><th>Registrerad</th></tr>
        </thead>
        <tbody>
          {recentUsers.map(u => (
            <tr>
              <td>{u.name}</td>
              <td style="font-size:0.85rem; color:var(--color-muted);">{u.email}</td>
              <td>{u.train_step || 1}</td>
              <td style="font-size:0.85rem;">{timeAgo(u.created_at)}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <h2>Senaste provresultat</h2>
      <table>
        <thead>
          <tr><th>Användare</th><th>Prov</th><th>Poäng</th><th>När</th></tr>
        </thead>
        <tbody>
          {recentResults.map(r => (
            <tr>
              <td>{r.name}</td>
              <td style="font-size:0.85rem;">{r.test_id}</td>
              <td>{r.score}/{r.total}</td>
              <td style="font-size:0.85rem;">{timeAgo(r.created_at)}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <h2>Svåraste frågorna (min 3 svar)</h2>
      <table>
        <thead>
          <tr><th>Prov</th><th>Del</th><th>Fråga</th><th>Rätt</th><th>Svar</th><th>%</th></tr>
        </thead>
        <tbody>
          {hardestQuestions.map(q => (
            <tr>
              <td style="font-size:0.8rem;">{q.testId}</td>
              <td>{q.subTest}</td>
              <td><strong>{q.num}</strong></td>
              <td>{q.correctCount}/{q.answered}</td>
              <td>{q.answered}</td>
              <td style={`font-weight:700; color:${q.rate < 30 ? '#ef4444' : q.rate < 50 ? '#f59e0b' : '#3b82f6'};`}>{q.rate}%</td>
            </tr>
          ))}
        </tbody>
      </table>

      <h2>Lättaste frågorna</h2>
      <table>
        <thead>
          <tr><th>Prov</th><th>Del</th><th>Fråga</th><th>Rätt</th><th>Svar</th><th>%</th></tr>
        </thead>
        <tbody>
          {easiestQuestions.map(q => (
            <tr>
              <td style="font-size:0.8rem;">{q.testId}</td>
              <td>{q.subTest}</td>
              <td><strong>{q.num}</strong></td>
              <td>{q.correctCount}/{q.answered}</td>
              <td>{q.answered}</td>
              <td style="font-weight:700; color:#22c55e;">{q.rate}%</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Base>

<style>
  .admin-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin: 1.5rem 0;
  }

  .admin-stat {
    text-align: center;
    padding: 1.2rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .admin-stat-num {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-primary);
  }

  .admin-stat-label {
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  table {
    width: 100%;
    margin-bottom: 2rem;
  }

  @media (max-width: 600px) {
    .admin-stats {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
