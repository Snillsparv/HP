  // ============================================================
  // Quiz engine
  // ============================================================
  let currentSection = '';
  let currentQuestionIndex = 0;
  let score = 0;
  let answers: (number | null)[] = [];

  const selectorEl = document.getElementById('trana-selector')!;
  const quizArea = document.getElementById('quiz-area')!;
  const resultsArea = document.getElementById('results-area')!;

  // Start quiz
  document.querySelectorAll('.trana-card').forEach(card => {
    card.addEventListener('click', () => {
      const section = (card as HTMLElement).dataset.section!;
      startQuiz(section);
    });
  });

  function startQuiz(section: string) {
    currentSection = section;
    currentQuestionIndex = 0;
    score = 0;
    answers = [];

    selectorEl.style.display = 'none';
    resultsArea.style.display = 'none';
    quizArea.style.display = 'block';

    document.getElementById('quiz-title')!.textContent = questionBank[section].title;
    showQuestion();
  }

  function showQuestion() {
    const questions = questionBank[currentSection].questions;
    const q = questions[currentQuestionIndex];
    const total = questions.length;

    document.getElementById('quiz-progress-text')!.textContent =
      `Fråga ${currentQuestionIndex + 1} av ${total}`;
    (document.getElementById('progress-fill') as HTMLElement).style.width =
      `${((currentQuestionIndex + 1) / total) * 100}%`;

    const questionEl = document.getElementById('quiz-question')!;
    let html = '';
    if (q.reading) {
      html += `<div class="reading-text">${q.reading}</div>`;
    }
    html += `<p><strong>${q.question}</strong></p>`;
    questionEl.innerHTML = html;

    const optionsEl = document.getElementById('quiz-options')!;
    optionsEl.innerHTML = q.options.map((opt, i) =>
      `<button class="quiz-option" data-index="${i}">${String.fromCharCode(65 + i)}. ${opt}</button>`
    ).join('');

    optionsEl.querySelectorAll('.quiz-option').forEach(btn => {
      btn.addEventListener('click', () => selectAnswer(parseInt((btn as HTMLElement).dataset.index!)));
    });

    document.getElementById('quiz-feedback')!.style.display = 'none';
    document.getElementById('next-btn')!.style.display = 'none';
  }

  function selectAnswer(index: number) {
    const q = questionBank[currentSection].questions[currentQuestionIndex];
    const buttons = document.querySelectorAll('.quiz-option');
    const isCorrect = index === q.correct;

    buttons.forEach(btn => {
      btn.classList.add('disabled');
      const btnIndex = parseInt((btn as HTMLElement).dataset.index!);
      if (btnIndex === q.correct) btn.classList.add('correct');
      if (btnIndex === index && !isCorrect) btn.classList.add('incorrect');
      if (btnIndex === index) btn.classList.add('selected');
    });

    if (isCorrect) score++;
    answers.push(index);

    const feedbackEl = document.getElementById('quiz-feedback')!;
    feedbackEl.style.display = 'block';
    feedbackEl.className = `quiz-feedback tip-box ${isCorrect ? 'success' : 'warning'}`;
    feedbackEl.innerHTML = `<strong>${isCorrect ? 'Rätt!' : 'Fel!'}</strong> ${q.explanation}`;

    document.getElementById('next-btn')!.style.display = 'inline-block';
  }

  document.getElementById('next-btn')!.addEventListener('click', () => {
    currentQuestionIndex++;
    if (currentQuestionIndex < questionBank[currentSection].questions.length) {
      showQuestion();
    } else {
      showResults();
    }
  });

  function showResults() {
    quizArea.style.display = 'none';
    resultsArea.style.display = 'block';

    const questions = questionBank[currentSection].questions;
    const total = questions.length;
    const pct = Math.round((score / total) * 100);

    document.getElementById('results-score')!.textContent = `${score} / ${total} (${pct}%)`;

    const breakdownEl = document.getElementById('results-breakdown')!;
    breakdownEl.innerHTML = questions.map((q, i) => {
      const correct = answers[i] === q.correct;
      const icon = correct ? '✓' : '✗';
      const cls = correct ? 'correct' : 'incorrect';
      const shortQ = q.question.replace(/<[^>]*>/g, '').substring(0, 60) + '...';
      return `<div class="result-item ${cls}"><span>${icon} ${shortQ}</span></div>`;
    }).join('');
  }

  document.getElementById('back-btn')!.addEventListener('click', () => {
    quizArea.style.display = 'none';
    selectorEl.style.display = 'block';
  });

  document.getElementById('retry-btn')!.addEventListener('click', () => {
    resultsArea.style.display = 'none';
    startQuiz(currentSection);
  });

  document.getElementById('other-btn')!.addEventListener('click', () => {
    resultsArea.style.display = 'none';
    selectorEl.style.display = 'block';
  });
</script>
